flowchart TD
    subgraph Capa1 ["1. Data Space Layer"]
        DS["Data Assets (CSV, Parquet, JSON)"]
        Apps["Data Apps (Algorithms, Services)"]
    end

    subgraph Capa2 ["2. Semantic Layer (EDAAnOWL v1.2.0)"]
        Asset["DataAsset (Supply)"]
        Dist["dcat:Distribution"]
        Prof["DataProfile (Overview)"]
        Map["FieldMapping (Column level)"]
        Unit["qudt:Unit"]
        Metric["Metric (Quality/Observation)"]
        Spec["DataSpecification (Semantic Unit)"]
        FOI["FeatureOfInterest"]
        OP["ObservableProperty"]
        App["SmartDataApp (Demand)"]
        InProf["InputProfile / OutputProfile"]
        Cons["DataConstraint (Quality Thresholds)"]

        Asset -->|"dcat:distribution"| Dist
        Dist -->|"hasProfile"| Prof
        Dist -->|"hasFieldMapping"| Map
        Prof -->|"hasDataSpecification"| Spec
        Map -->|"mapsToSpecification"| Spec
        Map -->|"hasUnit"| Unit
        Map -->|"hasMetric"| Metric
        
        Spec -->|"hasFeatureOfInterest"| FOI
        Spec -->|"hasObservableProperty"| OP

        App -->|"hasInputProfile"| InProf
        InProf -->|"hasDataSpecification"| Spec
        InProf -->|"hasConstraint"| Cons
        Cons -.->|"requires (e.g. Unit/Metric)"| Unit
    end

    DS -.-> Asset
    Apps -.-> App

    classDef edaan fill:#d4edda,stroke:#28a745,color:#155724,stroke-width:2px;
    classDef space fill:#e2e3e5,stroke:#383d41,color:#383d41,stroke-width:2px;
    class Asset,Dist,Prof,Map,Spec,FOI,OP,App,InProf,Cons,Unit,Metric edaan;
    class DS,Apps space;
