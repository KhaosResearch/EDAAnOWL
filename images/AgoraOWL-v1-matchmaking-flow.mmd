flowchart LR
    subgraph Supply Side
        Dist["dcat:Distribution"]
        Prof["DataProfile<br/>(File Grouping)"]
        Map["FieldMapping<br/>(Column mapping)"]
        Unit["qudt:Unit"]
        Metric["Metric"]
        Dist -->|"hasProfile"| Prof
        Dist -->|"hasFieldMapping"| Map
        Map -->|"hasUnit"| Unit
        Map -->|"hasMetric"| Metric
    end

    subgraph Demand Side
        App["DataApp"]
        InProf["InputProfile"]
        OutProf["OutputProfile"]
        Cons["DataConstraint"]
        App -->|"hasInputProfile"| InProf
        App -->|"hasOutputProfile"| OutProf
        InProf -->|"hasConstraint"| Cons
    end

    subgraph Matchmaking Core
        Spec["DataSpecification"]
        FOI["FeatureOfInterest"]
        OP["ObservableProperty"]
        Prof -->|"hasDataSpecification"| Spec
        Map -->|"mapsToSpecification"| Spec
        InProf -->|"hasDataSpecification"| Spec
        OutProf -->|"hasDataSpecification"| Spec
        Spec -->|"hasFeatureOfInterest"| FOI
        Spec -->|"hasObservableProperty"| OP
    end

    classDef agoraowl fill:#d4edda,stroke:#28a745,color:#155724,stroke-width:2px;
    class Dist,Prof,Map,App,InProf,OutProf,Spec,FOI,OP,Unit,Metric,Cons agoraowl;
