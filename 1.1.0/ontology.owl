     -->


    


    <!-- http://purl.org/dc/terms/alternative -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/alternative"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/description">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An account of the resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripcion del recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">descripcion</rdfs:label>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An unambiguous reference to the resource within a given context (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una referencia inequívoca al recurso dentro de un contexto dado (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">identificador</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/issued">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">La fecha de publicación formal del recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The date of formal issuance/publication of the resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">date issued</rdfs:label>
        <rdfs:label xml:lang="es">fecha de publicación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/modified">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">La fecha mas reciente en la que se cambio el recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The most recent date on which the resource was changed (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">date modified</rdfs:label>
        <rdfs:label xml:lang="es">fecha de modificacion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/title">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A name given to the resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un nombre dado al recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:label xml:lang="es">titulo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/adms#versionNotes -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/adms#versionNotes">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A description of changes between this version and the previous version (ADMS).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción de los cambios entre esta versión y la versión anterior (ADMS).</rdfs:comment>
        <rdfs:label xml:lang="es">notas de versión</rdfs:label>
        <rdfs:label xml:lang="en">version notes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#byteSize -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#byteSize">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="es">El tamaño de una Distribución en bytes (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The size of a Distribution in bytes (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">byte size</rdfs:label>
        <rdfs:label xml:lang="es">tamaño en bytes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#keyword -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#keyword">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A keyword or tag describing the Dataset (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una palabra clave o etiqueta que describe el Dataset (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">keyword</rdfs:label>
        <rdfs:label xml:lang="es">palabra clave</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#spatialResolutionInDegrees -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#spatialResolutionInDegrees">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#spatialResolutionInMeters -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#spatialResolutionInMeters">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#temporalResolution -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#temporalResolution">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dqv#value -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dqv#value"/>
    


    <!-- http://www.w3.org/ns/odrl/2/rightOperand -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/odrl/2/rightOperand">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">El valor del operando derecho de una Restriccion ODRL. Esta alineacion ligera modela el caso literal habitual usado en los ejemplos CRED.</rdfs:comment>
        <rdfs:comment xml:lang="en">The right operand value of an ODRL Constraint. This lightweight alignment models the common literal case used in CRED examples.</rdfs:comment>
        <rdfs:label xml:lang="es">operando derecho</rdfs:label>
        <rdfs:label xml:lang="en">right operand</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/prov#generatedAtTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#generatedAtTime"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">El nombre de un Agente (persona u organización) (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The name of an Agent (person or organization) (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <rdfs:label xml:lang="es">nombre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/thumbnailUrl -->


    <owl:DatatypeProperty rdf:about="https://schema.org/thumbnailUrl">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/accessType -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/accessType">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :accessTypeConcept instead. Indicates the primary access mode for the resource (e.g., download, compute, ...).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :accessTypeConcept en su lugar. Indica el modo de acceso principal para el recurso (p. ej., descarga, cómputo, ...).</rdfs:comment>
        <rdfs:label xml:lang="en">access type (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">tipo de acceso (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/alternativeName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/alternativeName">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/alternative"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Alternative title or name for a resource.</rdfs:comment>
        <rdfs:comment xml:lang="es">Título o nombre alternativo para un recurso.</rdfs:comment>
        <rdfs:label xml:lang="en">alternate name</rdfs:label>
        <rdfs:label xml:lang="es">nombre alternativo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/anonymizationTechnique -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/anonymizationTechnique">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">La técnica utilizada para anonimizar datos personales (p. ej., &apos;k-anonymity&apos;, &apos;privacidad diferencial&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The technique used to anonymize personal data (e.g., &apos;k-anonymity&apos;, &apos;differential privacy&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">anonymization technique</rdfs:label>
        <rdfs:label xml:lang="es">técnica de anonimización</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/appliesToFeature -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/appliesToFeature">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :appliesToFeatureConcept for formal schema pointers. Indicates the specific feature, column, or attribute to which a metric refers (e.g., &apos;column_name&apos;, &apos;user.address.city&apos;, &apos;$.user.address.city&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :appliesToFeatureConcept para punteros formales a esquema. Indica la característica, columna o atributo específico al que se refiere una métrica (p. ej., &apos;column_name&apos;, &apos;user.address.city&apos;, &apos;$.user.address.city&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">applies to feature (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">se aplica a característica (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/auditLogAvailable -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/auditLogAvailable">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si los registros de auditoría para el uso del recurso están disponibles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates if audit logs for the resource usage are available.</rdfs:comment>
        <rdfs:label xml:lang="en">audit log available</rdfs:label>
        <rdfs:label xml:lang="es">registro de auditoría disponible</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/certificationLevel -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/certificationLevel">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/CertificationReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El nivel de certificación alcanzado (p. ej., &apos;Gaia-X Label 1&apos;, &apos;Gold&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The level of certification achieved (e.g., &apos;Gaia-X Label 1&apos;, &apos;Gold&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">certification level</rdfs:label>
        <rdfs:label xml:lang="es">nivel de certificación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/collectionMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/collectionMethod">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El método utilizado para recolectar los datos (p. ej., &apos;sensor&apos;, &apos;encuesta&apos;, &apos;satélite&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The method used to collect the data (e.g., &apos;sensor&apos;, &apos;survey&apos;, &apos;satellite&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">collection method</rdfs:label>
        <rdfs:label xml:lang="es">método de recolección</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/computedAt -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/computedAt">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#generatedAtTime"/>
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La marca de tiempo que indica cuándo se calculó o validó el valor de la métrica. Alineada con prov:generatedAtTime para interoperabilidad de procedencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">The timestamp indicating when the metric&apos;s value was computed or validated. Aligned with prov:generatedAtTime for provenance interoperability.</rdfs:comment>
        <rdfs:label xml:lang="es">calculado en</rdfs:label>
        <rdfs:label xml:lang="en">computed at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/constraintOperator -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/constraintOperator">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataConstraint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Define el operador de comparación para una restricción de calidad (p. ej., &apos;&gt;=&apos;, &apos;==&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the comparison operator for a quality constraint (e.g., &apos;&gt;=&apos;, &apos;==&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">constraint operator</rdfs:label>
        <rdfs:label xml:lang="es">operador de restricción</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/constraintValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/constraintValue">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataConstraint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">Define el valor umbral para una restricción de calidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the threshold value for a quality constraint.</rdfs:comment>
        <rdfs:label xml:lang="en">constraint value</rdfs:label>
        <rdfs:label xml:lang="es">valor de restricción</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/containsPersonalData -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/containsPersonalData">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el recurso incluye información de identificación personal (PII) o datos sujetos a GDPR.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the resource includes Personally Identifiable Information (PII) or data subject to GDPR.</rdfs:comment>
        <rdfs:label xml:lang="en">contains personal data</rdfs:label>
        <rdfs:label xml:lang="es">contiene datos personales</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/isAlive -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/isAlive">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el conjunto de datos se mantiene activamente y espera actualizaciones futuras.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates if the dataset is actively maintained and expects future updates.</rdfs:comment>
        <rdfs:label xml:lang="es">está activo</rdfs:label>
        <rdfs:label xml:lang="en">is alive</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/isStreaming -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/isStreaming">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si los datos de esta distribución se proporcionan en tiempo real como un flujo continuo (streaming) en lugar de un conjunto de datos estático.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the data in this distribution is provided in real-time as a continuous stream instead of a static dataset.</rdfs:comment>
        <rdfs:label xml:lang="es">es flujo continuo (streaming)</rdfs:label>
        <rdfs:label xml:lang="en">is streaming</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/knownLimitations -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/knownLimitations">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Descripción legible de cualquier limitación conocida, sesgo o problema de calidad del recurso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Human-readable description of any known limitations, biases, or quality issues of the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">known limitations</rdfs:label>
        <rdfs:label xml:lang="es">limitaciones conocidas</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/mapsField -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/mapsField">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/FieldMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El identificador físico (nombre de columna, JSONPath, XPath) del campo en la distribución que corresponde al perfil atómico vinculado.</rdfs:comment>
        <rdfs:comment xml:lang="en">The physical identifier (column name, JSONPath, XPath) of the field in the distribution that corresponds to the bound atomic profile.</rdfs:comment>
        <rdfs:label xml:lang="en">maps to field</rdfs:label>
        <rdfs:label xml:lang="es">se mapea al campo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricName">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable name or identifier for the metric (e.g., &apos;recordCount&apos;, &apos;missing_ratio&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un nombre o identificador legible para la métrica (p. ej., &apos;recordCount&apos;, &apos;missing_ratio&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">metric name</rdfs:label>
        <rdfs:label xml:lang="es">nombre de métrica</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricUnit -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricUnit">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :hasMetricStandard instead. The unit of measurement for the metric value (e.g., &apos;%&apos;, &apos;kg/ha&apos;, &apos;ppm&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :hasMetricStandard en su lugar. La unidad de medida para el valor de la métrica (p. ej., &apos;%&apos;, &apos;kg/ha&apos;, &apos;ppm&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">metric unit (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">unidad de métrica (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricValue">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dqv#value"/>
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">El valor de la medición de la métrica. Alineado con dqv:value para interoperabilidad DQV. El rango es rdfs:Literal para soportar múltiples tipos de datos (p. ej., xsd:boolean, xsd:integer, xsd:string, xsd:decimal).</rdfs:comment>
        <rdfs:comment xml:lang="en">The value of the metric measurement. Aligned with dqv:value for DQV interoperability. Range is rdfs:Literal to support multiple datatypes (e.g., xsd:boolean, xsd:integer, xsd:string, xsd:decimal).</rdfs:comment>
        <rdfs:label xml:lang="en">metric value</rdfs:label>
        <rdfs:label xml:lang="es">valor de métrica</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/nullPercentage -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/nullPercentage">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="es">El porcentaje de valores nulos en una columna (0.0 a 1.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The percentage of null values in a column (0.0 to 1.0).</rdfs:comment>
        <rdfs:label xml:lang="en">null percentage</rdfs:label>
        <rdfs:label xml:lang="es">porcentaje de nulos</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/paymentModelDescription -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/paymentModelDescription">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable description of the pricing or payment model (e.g., &apos;Monthly Subscription&apos;, &apos;Pay-per-use&apos;). This complements the formal ODRL policy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción legible del modelo de precios o pago (p. ej., &apos;Suscripción Mensual&apos;, &apos;Pago por uso&apos;). Esto complementa la política formal ODRL.</rdfs:comment>
        <rdfs:label xml:lang="es">descripción del modelo de pago</rdfs:label>
        <rdfs:label xml:lang="en">payment model description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileCRS -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileCRS">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">CRS de perfil</rdfs:label>
        <rdfs:label xml:lang="en">profile CRS</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileSpatialResolution -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileSpatialResolution">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Deprecated. Use dcat:spatialResolutionInMeters or dcat:spatialResolutionInDegrees.</rdfs:comment>
        <rdfs:comment xml:lang="es">Obsoleto. Use dcat:spatialResolutionInMeters o dcat:spatialResolutionInDegrees.</rdfs:comment>
        <rdfs:label xml:lang="en">profile spatial resolution</rdfs:label>
        <rdfs:label xml:lang="es">resolución espacial de perfil</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileTemporalResolution -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileTemporalResolution">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="en">Deprecated. Use dcat:temporalResolution for temporal resolution of datasets/profiles.</rdfs:comment>
        <rdfs:comment xml:lang="es">Obsoleto. Use dcat:temporalResolution para la resolución temporal de conjuntos de datos/perfiles.</rdfs:comment>
        <rdfs:label xml:lang="en">profile temporal resolution</rdfs:label>
        <rdfs:label xml:lang="es">resolución temporal de perfil</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/dcat#temporalResolution"/>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/qualityReportURI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/qualityReportURI">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/QualityReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="es">El URI del informe de calidad completo y legible (p. ej., un documento PDF o HTML).</rdfs:comment>
        <rdfs:comment xml:lang="en">The URI of the full, human-readable quality report (e.g., a PDF or HTML document).</rdfs:comment>
        <rdfs:label xml:lang="es">URI de informe de calidad</rdfs:label>
        <rdfs:label xml:lang="en">quality report URI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/qualityScore -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/qualityScore">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/QualityReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A quantitative quality score (e.g., 0-100) assigned by the external quality report.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una puntuación de calidad cuantitativa (p. ej., 0-100) asignada por el informe de calidad externo.</rdfs:comment>
        <rdfs:label xml:lang="es">puntuación de calidad</rdfs:label>
        <rdfs:label xml:lang="en">quality score</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/recommendedUse -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/recommendedUse">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Descripción legible de los casos de uso previstos o recomendados para el recurso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Human-readable description of the intended or recommended use cases for the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">recommended use</rdfs:label>
        <rdfs:label xml:lang="es">uso recomendado</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/refundPolicy -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/refundPolicy">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A text description of the refund policy applicable to the resource.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción textual de la política de reembolso aplicable al recurso.</rdfs:comment>
        <rdfs:label xml:lang="es">política de reembolso</rdfs:label>
        <rdfs:label xml:lang="en">refund policy</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/reportDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/reportDate">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/CertificationReport"/>
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/QualityReport"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha en que se emitió el informe.</rdfs:comment>
        <rdfs:comment xml:lang="en">The date when the report was issued.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha del informe</rdfs:label>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/sampleValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/sampleValue">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A representative sample value for a column.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un valor de muestra representativo para una columna.</rdfs:comment>
        <rdfs:label xml:lang="en">sample value</rdfs:label>
        <rdfs:label xml:lang="es">valor de muestra</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/securityClassification -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/securityClassification">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El nivel de clasificación de seguridad del recurso (por ejemplo, Público, Confidencial).</rdfs:comment>
        <rdfs:comment xml:lang="en">The security classification level of the resource (e.g., Public, Confidential).</rdfs:comment>
        <rdfs:label xml:lang="es">clasificación de seguridad</rdfs:label>
        <rdfs:label xml:lang="en">security classification</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/spatialGranularity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/spatialGranularity">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">granularidad espacial</rdfs:label>
        <rdfs:label xml:lang="en">spatial granularity</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/uniquenessRatio -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/uniquenessRatio">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="es">El ratio de valores únicos frente al total de filas en una columna (0.0 a 1.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The ratio of unique values to total rows in a column (0.0 to 1.0).</rdfs:comment>
        <rdfs:label xml:lang="es">ratio de unicidad</rdfs:label>
        <rdfs:label xml:lang="en">uniqueness ratio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/accessURL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/accessURL">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Endpoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appDocumentation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appDocumentation">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appEndpointPort -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appEndpointPort">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/AppEndpoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appEndpointProtocol -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appEndpointProtocol">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/AppEndpoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appEnvironmentVariables -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appEnvironmentVariables">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appStorageConfiguration -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appStorageConfiguration">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/checkSum -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/checkSum">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Artifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/dataAppDistributionService -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/dataAppDistributionService">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/AppRepresentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/endpointURI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/endpointURI">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/fileName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/fileName">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Artifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://www.w3.org/2018/credentials#expirationDate -->


    <owl:DatatypeProperty rdf:about="https://www.w3.org/2018/credentials#expirationDate"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://data.europa.eu/r5r/LegalResource -->


    <owl:Class rdf:about="http://data.europa.eu/r5r/LegalResource">
        <rdfs:comment xml:lang="en">A legal resource (legislation, directive, regulation) that relates to a dataset or service (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un recurso legal (legislación, directiva, reglamento) relacionado con un conjunto de datos o servicio (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Legal Resource</rdfs:label>
        <rdfs:label xml:lang="es">Recurso Legal</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/Frequency -->


    <owl:Class rdf:about="http://purl.org/dc/terms/Frequency">
        <rdfs:comment xml:lang="en">A rate at which something recurs. Used for dct:accrualPeriodicity (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una tasa a la que algo se repite. Usado para dct:accrualPeriodicity (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">Frecuencia</rdfs:label>
        <rdfs:label xml:lang="en">Frequency</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/LicenseDocument -->


    <owl:Class rdf:about="http://purl.org/dc/terms/LicenseDocument">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
        <rdfs:comment xml:lang="en">A legal document giving official permission to do something with a resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un documento legal que otorga permiso oficial para hacer algo con un recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">Documento de Licencia</rdfs:label>
        <rdfs:label xml:lang="en">License Document</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/LinguisticSystem -->


    <owl:Class rdf:about="http://purl.org/dc/terms/LinguisticSystem">
        <rdfs:comment xml:lang="en">A system of signs, symbols, sounds, gestures, or rules used in communication, e.g., a language (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un sistema de signos, símbolos, sonidos, gestos o reglas utilizado en la comunicación, p. ej., un idioma (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Linguistic System</rdfs:label>
        <rdfs:label xml:lang="es">Sistema Lingüístico</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/Location -->


    <owl:Class rdf:about="http://purl.org/dc/terms/Location">
        <rdfs:comment xml:lang="en">A spatial region or named place. Used for dct:spatial coverage of datasets (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una región espacial o lugar con nombre. Usado para la cobertura dct:spatial de datasets (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Location</rdfs:label>
        <rdfs:label xml:lang="es">Ubicación</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/MediaTypeOrExtent -->


    <owl:Class rdf:about="http://purl.org/dc/terms/MediaTypeOrExtent">
        <rdfs:comment xml:lang="en">A media type or extent. Used for dct:format on distributions (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un tipo de medio o extensión. Usado para dct:format en distribuciones (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Media Type or Extent</rdfs:label>
        <rdfs:label xml:lang="es">Tipo de Medio o Extensión</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/RightsStatement -->


    <owl:Class rdf:about="http://purl.org/dc/terms/RightsStatement">
        <rdfs:comment xml:lang="en">A statement about the intellectual property rights (IPR) held in or over a resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una declaración sobre los derechos de propiedad intelectual (DPI) sobre un recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">Declaración de Derechos</rdfs:label>
        <rdfs:label xml:lang="en">Rights Statement</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/Standard -->


    <owl:Class rdf:about="http://purl.org/dc/terms/Standard"/>
    


    <!-- http://qudt.org/vocab/unit/Unit -->


    <owl:Class rdf:about="http://qudt.org/vocab/unit/Unit"/>
    


    <!-- http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter -->


    <owl:Class rdf:about="http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter"/>
    


    <!-- http://www.opmw.org/ontology/WorkflowTemplate -->


    <owl:Class rdf:about="http://www.opmw.org/ontology/WorkflowTemplate"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#Resource -->


    <owl:Class rdf:about="http://www.w3.org/2000/01/rdf-schema#Resource"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- http://www.w3.org/2006/time#DurationDescription -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#DurationDescription">
        <rdfs:comment xml:lang="en">A description of the extent of a time duration using calendar/clock terms (OWL-Time).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción de la extensión de una duración temporal usando términos de calendario/reloj (OWL-Time).</rdfs:comment>
        <rdfs:label xml:lang="es">Descripción de Duración</rdfs:label>
        <rdfs:label xml:lang="en">Duration Description</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Interval -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval"/>
    


    <!-- http://www.w3.org/2006/vcard/ns#Kind -->


    <owl:Class rdf:about="http://www.w3.org/2006/vcard/ns#Kind"/>
    


    <!-- http://www.w3.org/ns/dcat#Catalog -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Catalog">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:comment xml:lang="en">A curated collection of metadata about datasets and data services (DCAT-AP 3.0). In the CRED model, a Catalog aggregates all semantic resources of a data space.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una colección curada de metadatos sobre conjuntos de datos y servicios de datos (DCAT-AP 3.0). En el modelo CRED, un Catálogo agrega todos los recursos semánticos de un espacio de datos.</rdfs:comment>
        <rdfs:label xml:lang="en">Catalog</rdfs:label>
        <rdfs:label xml:lang="es">Catálogo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dcat#DataService -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#DataService">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
        <rdfs:comment xml:lang="en">A collection of operations accessible through an interface (API) that provides access to one or more datasets or data processing functions (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una colección de operaciones accesibles a través de una interfaz (API) que proporciona acceso a uno o más conjuntos de datos o funciones de procesamiento de datos (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Data Service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de Datos</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dcat#Dataset -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Dataset">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dcat#Distribution -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Distribution">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/declaresDataClass"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/BIGOWLData/Data"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasMetric"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasFieldMapping"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/dcat#spatialResolutionInMeters"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/dcat#temporalResolution"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dcat#Resource -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Resource">
        <rdfs:comment xml:lang="es">Recurso publicado o curado por un solo agente (DCAT 3). En DCAT-AP, esta es la clase base abstracta para Dataset y DataService.</rdfs:comment>
        <rdfs:comment xml:lang="en">Resource published or curated by a single agent (DCAT 3). In DCAT-AP, this is the abstract base class for Dataset and DataService.</rdfs:comment>
        <rdfs:label xml:lang="es">Recurso</rdfs:label>
        <rdfs:label xml:lang="en">Resource</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dqv#Metric -->


    <owl:Class rdf:about="http://www.w3.org/ns/dqv#Metric"/>
    


    <!-- http://www.w3.org/ns/dqv#QualityMeasurement -->


    <owl:Class rdf:about="http://www.w3.org/ns/dqv#QualityMeasurement"/>
    


    <!-- http://www.w3.org/ns/dqv#QualityMetadata -->


    <owl:Class rdf:about="http://www.w3.org/ns/dqv#QualityMetadata"/>
    


    <!-- http://www.w3.org/ns/dqv#QualityMetric -->


    <owl:Class rdf:about="http://www.w3.org/ns/dqv#QualityMetric"/>
    


    <!-- http://www.w3.org/ns/locn#Geometry -->


    <owl:Class rdf:about="http://www.w3.org/ns/locn#Geometry"/>
    


    <!-- http://www.w3.org/ns/odrl/2/Asset -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Asset">
        <rdfs:comment xml:lang="en">An abstract concept of content that can be subject to an ODRL Policy (ODRL 2.2). In DCAT, Catalog, Dataset and Distribution are assets.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un concepto abstracto de contenido que puede estar sujeto a una Política ODRL (ODRL 2.2). En DCAT, Catalog, Dataset y Distribution son activos.</rdfs:comment>
        <rdfs:label xml:lang="es">Activo</rdfs:label>
        <rdfs:label xml:lang="en">Asset</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/odrl/2/Constraint -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Constraint">
        <rdfs:comment xml:lang="en">A Boolean expression that refines the semantics of an ODRL Rule (ODRL 2.2).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una expresión booleana que refina la semántica de una Regla ODRL (ODRL 2.2).</rdfs:comment>
        <rdfs:label xml:lang="en">Constraint</rdfs:label>
        <rdfs:label xml:lang="es">Restricción</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/odrl/2/Offer -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Offer">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/odrl/2/Policy"/>
        <rdfs:comment xml:lang="en">A Policy that proposes terms of use for an Asset (ODRL 2.2). In the CRED model, used to attach usage conditions to Datasets and Distributions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una Política que propone términos de uso para un Activo (ODRL 2.2). En el modelo CRED, se usa para adjuntar condiciones de uso a Datasets y Distribuciones.</rdfs:comment>
        <rdfs:label xml:lang="es">Oferta</rdfs:label>
        <rdfs:label xml:lang="en">Offer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/odrl/2/Policy -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Policy">
        <rdfs:comment xml:lang="en">A non-empty group of Permissions and/or Prohibitions and/or Obligations (ODRL 2.2). Base class for Offer, Agreement, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un grupo no vacío de Permisos y/o Prohibiciones y/o Obligaciones (ODRL 2.2). Clase base para Offer, Agreement, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Policy</rdfs:label>
        <rdfs:label xml:lang="es">Política</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/odrl/2/Rule -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Rule">
        <rdfs:comment xml:lang="en">An abstract concept for a Permission, Prohibition, or Obligation (ODRL 2.2).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un concepto abstracto para un Permiso, Prohibición u Obligación (ODRL 2.2).</rdfs:comment>
        <rdfs:label xml:lang="es">Regla</rdfs:label>
        <rdfs:label xml:lang="en">Rule</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Organization -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Organization"/>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty"/>
    


    <!-- http://xmlns.com/foaf/0.1/Agent -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Agent">
        <rdfs:comment xml:lang="en">An agent (person, organization, or software) that is associated with a resource as publisher, creator, or contact (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un agente (persona, organización, o software) asociado con un recurso como editor, creador o contacto (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">Agent</rdfs:label>
        <rdfs:label xml:lang="es">Agente</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Document -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Document"/>
    


    <!-- https://w3id.org/BIGOWLData/Column -->


    <owl:Class rdf:about="https://w3id.org/BIGOWLData/Column"/>
    


    <!-- https://w3id.org/BIGOWLData/Data -->


    <owl:Class rdf:about="https://w3id.org/BIGOWLData/Data"/>
    


    <!-- https://w3id.org/BIGOWLWorkflows/Component -->


    <owl:Class rdf:about="https://w3id.org/BIGOWLWorkflows/Component"/>
    


    <!-- https://w3id.org/EDAAnOWL/Accuracy -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/Accuracy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/QualityMetric"/>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/AnalyzerApp -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/AnalyzerApp">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataApp"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/SmartDataApp"/>
        <rdfs:comment xml:lang="en">A smart data app for descriptive/diagnostic analysis (profiling, summarization, outlier detection).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una aplicación de datos inteligente para análisis descriptivo/diagnóstico (perfilado, resumen, detección de valores atípicos).</rdfs:comment>
        <rdfs:label xml:lang="en">Analyzer App</rdfs:label>
        <rdfs:label xml:lang="es">Aplicación Analizadora</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/CertificationReport -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/CertificationReport">
        <rdfs:comment xml:lang="en">A report attesting that a resource or profile complies with a specific standard or regulation (e.g., Gaia-X).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un informe que atestigua que un recurso o perfil cumple con un estándar o regulación específica (p. ej., Gaia-X).</rdfs:comment>
        <rdfs:label xml:lang="en">Certification Report</rdfs:label>
        <rdfs:label xml:lang="es">Informe de Certificación</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/Completeness -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/Completeness">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/QualityMetric"/>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/ConstraintOperator -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/ConstraintOperator"/>
    


    <!-- https://w3id.org/EDAAnOWL/DataApp -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataApp">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:comment xml:lang="es">Especialización de ids:DataApp para EDAAnOWL. Permite la declaración de requisitos de entrada (hasInputProfile), perfiles de salida (producesProfile) y métricas de rendimiento (hasPerformanceMetric).</rdfs:comment>
        <rdfs:comment xml:lang="en">Specialization of ids:DataApp for EDAAnOWL. Enables declaration of input requirements (hasInputProfile), output profiles (producesProfile), and performance metrics (hasPerformanceMetric).</rdfs:comment>
        <rdfs:label xml:lang="es">Aplicación de Datos</rdfs:label>
        <rdfs:label xml:lang="en">Data App</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/DataAsset -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataAsset">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DataResource"/>
        <rdfs:comment xml:lang="es">Especializa ids:DataResource para añadir la capa semántica específica de EDAAnOWL. Los perfiles se vinculan mediante ids:representation → dcat:Distribution → hasFieldMapping → mapsToSpecification. Puede vincularse a la DataApp que lo generó usando prov:wasGeneratedBy.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specialises ids:DataResource to add the EDAAnOWL domain-specific semantic layer. Profiles are linked via ids:representation → dcat:Distribution → hasFieldMapping → mapsToSpecification. Can be linked to the DataApp that generated it using prov:wasGeneratedBy.</rdfs:comment>
        <rdfs:label xml:lang="es">Activo de Datos</rdfs:label>
        <rdfs:label xml:lang="en">Data Asset</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/DataConstraint -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataConstraint">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/constraintMetricType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/EDAAnOWL/MetricType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/constraintOperator"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/constraintValue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Define una restricción de umbral de calidad (p. ej., completitud &gt;= 0.9) para ser utilizada en el matchmaking.</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines a quality threshold constraint (e.g., completeness &gt;= 0.9) to be used in matchmaking.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Constraint</rdfs:label>
        <rdfs:label xml:lang="es">Restricción de Calidad</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/DataProfile -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataProfile">
        <rdfs:comment xml:lang="en">A grouping of multiple DataSpecifications. Useful to represent the set of variables that a dataset offers or an application requires.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una agrupación de múltiples DataSpecifications. Útil para representar el conjunto de variables que ofrece un dataset o requiere una aplicación.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Profile</rdfs:label>
        <rdfs:label xml:lang="es">Perfil de Datos</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/DataRepresentation -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataRepresentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DataRepresentation"/>
        <rdfs:comment xml:lang="en">Physical representation of (structured) data. Specializes ids:DataRepresentation 
    from the IDSA taxonomy to add EDAAnOWL-specific semantics for data profiles and quality metrics.
    
    Alignment: ids:DataRepresentation extends dcat:Distribution (W3C DCAT 2+), 
    ensuring interoperability with DCAT-based catalogs while maintaining IDSA compliance.</rdfs:comment>
        <rdfs:comment xml:lang="es">Representación física de datos (estructurados). Especializa ids:DataRepresentation 
    de la taxonomía IDSA para añadir semántica específica de EDAAnOWL para perfiles de datos y métricas de calidad.
    
    Alineación: ids:DataRepresentation extiende dcat:Distribution (W3C DCAT 2+), 
    asegurando interoperabilidad con catálogos basados en DCAT mientras mantiene conformidad IDSA.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Representation</rdfs:label>
        <rdfs:label xml:lang="es">Representación de Datos</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/DataSpecification -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/DataSpecification">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/terms/Standard"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasFeatureOfInterest"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/EDAAnOWL/FeatureOfInterest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasObservableProperty"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/EDAAnOWL/ObservableProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Atomic and reusable semantic unit that describes WHAT is being observed (Feature of Interest) and WHICH property is measured (Observable Property).
    
DataSpecifications are schema-agnostic. They do not contain mapping information (mapsField), units, or technical distribution details (resolutions, CRS), which belong to Distribution, FieldMapping, or explicit constraints.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad semántica atómica y reutilizable que describe QUÉ se está observando (Feature of Interest), QUÉ propiedad se mide (Observable Property) y CÓMO se representa (Tipo de Dato, Estándar de Métrica).
    
Los DataSpecifications son ahora independientes del esquema. Ya no contienen información de mapeo (mapsField) ni detalles técnicos de la distribución (resoluciones, CRS), los cuales se han movido a Distribution o FieldMapping.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Specification</rdfs:label>
        <rdfs:label xml:lang="es">Perfil de Datos</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/FeatureOfInterest -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/FeatureOfInterest">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:comment xml:lang="es">De lo que se habla o lo que se observa (el objeto real o fenómeno). Ejemplos: una naranja, una parcela, un lote de aceite. RECOMENDADO: Usar SIEX o AGROVOC para clasificar el tipo de objeto.</rdfs:comment>
        <rdfs:comment xml:lang="en">The phenomenon or entity being observed or described (the &apos;thing&apos; itself). Examples: an orange, a plot of land, a batch of oil. RECOMMENDED: Use SIEX or AGROVOC to classify the object type.</rdfs:comment>
        <rdfs:label xml:lang="es">Característica de Interés</rdfs:label>
        <rdfs:label xml:lang="en">Feature of Interest</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/FieldMapping -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/FieldMapping">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasMetric"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/mapsToSpecification"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/mapsField"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">La clase &apos;puente&apos; que instancia un DataSpecification reutilizable para un campo específico en una distribución. Mapea el concepto semántico a un identificador físico (mapsField) y proporciona métricas de calidad específicas del campo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The &apos;bridge&apos; class that instantiates a reusable DataSpecification for a specific field in a distribution. It maps the semantic concept to a physical identifier (mapsField) and carries field-level technical details such as unit, data type, observation metric, and quality metrics.</rdfs:comment>
        <rdfs:label xml:lang="en">Field Mapping</rdfs:label>
        <rdfs:label xml:lang="es">Vínculo de Perfil</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/InputProfile -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/InputProfile">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasConstraint"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/EDAAnOWL/DataConstraint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/hasDataSpecification"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Define un requisito estructurado para una entrada de DataApp, especificando exactamente qué DataSpecification se necesita y qué umbrales de calidad deben cumplirse.</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines a structured requirement for a DataApp input, specifying exactly which DataSpecification is needed and what quality thresholds must be met.</rdfs:comment>
        <rdfs:label xml:lang="en">Input Profile</rdfs:label>
        <rdfs:label xml:lang="es">Requisito de Entrada</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/Metric -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/Metric">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dqv#QualityMeasurement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/metricName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/EDAAnOWL/metricValue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A class representing a single, measurable characteristic (measurement) of an asset or profile. Aligned with dqv:QualityMeasurement. Use :metricType to link to the standardized metric definition (dqv:Metric).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una clase que representa una característica única y medible (medición) de un activo o perfil. Alineada con dqv:QualityMeasurement. Use :metricType para vincular a la definición de métrica estandarizada (dqv:Metric).</rdfs:comment>
        <rdfs:label xml:lang="en">Metric (Measurement)</rdfs:label>
        <rdfs:label xml:lang="es">Métrica (Medición)</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/MetricType -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/MetricType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dqv#Metric"/>
        <rdfs:comment xml:lang="en">A controlled vocabulary term for standardized metric definitions (e.g., completeness, recordCount, cloudCoverage). Aligned with dqv:Metric. RECOMMENDED: Use external vocabularies like DDI (SummaryStatisticType), STATO (Statistical Methods Ontology), or W3C DQV for quality metrics. Use :metricType to link a measurement (:Metric) to its definition.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un término de vocabulario controlado para definiciones de métricas estandarizadas (p. ej., completitud, recuento de registros, cobertura de nubes). Alineado con dqv:Metric. RECOMENDADO: Usar vocabularios externos como DDI (SummaryStatisticType), STATO (Statistical Methods Ontology) o W3C DQV para métricas de calidad. Use :metricType para vincular una medición (:Metric) con su definición.</rdfs:comment>
        <rdfs:label xml:lang="es">Definición de Métrica (Tipo)</rdfs:label>
        <rdfs:label xml:lang="en">Metric Definition (Type)</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/ObservableProperty -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/ObservableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="es">La variable semántica que describe un activo de datos o que un servicio requiere/produce. RECOMENDADO: Usar AGROVOC para conceptos agrícolas o EuroSciVoc para ciencia general.</rdfs:comment>
        <rdfs:comment xml:lang="en">The semantic variable that a data asset describes or a service requires/produces. RECOMMENDED: Use AGROVOC for agricultural concepts or EuroSciVoc for general science.</rdfs:comment>
        <rdfs:label xml:lang="en">Observable Property</rdfs:label>
        <rdfs:label xml:lang="es">Propiedad Observable</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/ObservationMetric -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/ObservationMetric">
        <rdfs:comment xml:lang="en">Statistical or aggregation metric of the observation (e.g., DailyAverage, Maximum, Instantaneous).</rdfs:comment>
        <rdfs:label xml:lang="en">Observation Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/OutputProfile -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/OutputProfile">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:comment xml:lang="en">Specifies the profile of output data a DataApp produces.</rdfs:comment>
        <rdfs:label xml:lang="en">Output Profile</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/PerformanceMetric -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/PerformanceMetric">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:comment xml:lang="en">A metric that describes the performance of a DataApp or service (e.g., accuracy, execution time).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una métrica que describe el rendimiento de una DataApp o servicio (p. ej., precisión, tiempo de ejecución).</rdfs:comment>
        <rdfs:label xml:lang="es">Métrica de Rendimiento</rdfs:label>
        <rdfs:label xml:lang="en">Performance Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/PredictionApp -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/PredictionApp">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataApp"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/SmartDataApp"/>
        <rdfs:comment xml:lang="en">A smart data app that produces predictions/inferences from input data using a model or algorithm.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una aplicación de datos inteligente que produce predicciones/inferencias a partir de datos de entrada usando un modelo o algoritmo.</rdfs:comment>
        <rdfs:label xml:lang="es">Aplicación de Predicción</rdfs:label>
        <rdfs:label xml:lang="en">Prediction App</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/QualityMetric -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/QualityMetric">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dqv#QualityMetric"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/MetricType"/>
        <rdfs:comment xml:lang="en">A quality metric definition describing a qualitative or quantitative aspect of data quality (e.g., completeness, uniqueness, record count). Aligned with dqv:QualityMetric. Individual measurements belong to :Metric / dqv:QualityMeasurement and should link here via :metricType.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una métrica que describe un aspecto cualitativo o cuantitativo de la calidad de datos (p. ej., completitud, unicidad, recuento de registros). Alineada con dqv:QualityMetric.</rdfs:comment>
        <rdfs:label xml:lang="es">Métrica de Calidad</rdfs:label>
        <rdfs:label xml:lang="en">Quality Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/QualityReport -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/QualityReport">
        <rdfs:comment xml:lang="en">An external, structured quality report containing metadata about a quality assessment (e.g., a PDF report URL, a quality score).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un informe de calidad externo y estructurado que contiene metadatos sobre una evaluación de calidad (p. ej., una URL de informe PDF, una puntuación de calidad).</rdfs:comment>
        <rdfs:label xml:lang="es">Informe de Calidad</rdfs:label>
        <rdfs:label xml:lang="en">Quality Report</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/SpatialTemporalAsset -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/SpatialTemporalAsset">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataAsset"/>
        <rdfs:comment xml:lang="es">Subclase de DataAsset para datos con cobertura espacial y temporal, como datos de Observación de la Tierra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Subclass of DataAsset for data with spatial and temporal coverage, such as Earth Observation data.</rdfs:comment>
        <rdfs:label xml:lang="es">Activo Espacio-Temporal</rdfs:label>
        <rdfs:label xml:lang="en">Spatial Temporal Asset</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/Uniqueness -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/Uniqueness">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/QualityMetric"/>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/VerifiableDataSpecification -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/VerifiableDataSpecification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataSpecification"/>
        <rdfs:comment xml:lang="en">A DataSpecification that is intended to be cryptographically verified. It should be linked to a Verifiable Credential using :hasCredential. This enables trusted quality assertions in data spaces by separating the profile metadata from its cryptographic proof.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un DataSpecification destinado a ser verificado criptográficamente. Debe vincularse a una Credencial Verificable usando :hasCredential. Esto permite aserciones de calidad confiables en espacios de datos separando los metadatos del perfil de su prueba criptográfica.</rdfs:comment>
        <rdfs:label xml:lang="es">Perfil de Datos Verificable</rdfs:label>
        <rdfs:label xml:lang="en">Verifiable Data Specification</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/EDAAnOWL/VisualizationApp -->


    <owl:Class rdf:about="https://w3id.org/EDAAnOWL/VisualizationApp">
        <rdfs:subClassOf rdf:resource="https://w3id.org/EDAAnOWL/DataApp"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/SmartDataApp"/>
        <rdfs:comment xml:lang="en">A smart data app that renders data into visual views/reports without altering underlying data.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una aplicación de datos inteligente que renderiza datos en vistas/informes visuales sin alterar los datos subyacentes.</rdfs:comment>
        <rdfs:label xml:lang="es">Aplicación de Visualización</rdfs:label>
        <rdfs:label xml:lang="en">Visualization App</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/AppEndpoint -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/AppEndpoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Endpoint"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/AppRepresentation -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/AppRepresentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/SoftwareRepresentation"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/AppResource -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/AppResource">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Resource"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/AppRoute -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/AppRoute">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Described"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/Artifact -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/Artifact">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/odrl/2/Asset"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Described"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/RepresentationInstance"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/ConnectorEndpoint -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/ConnectorEndpoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Endpoint"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/ContractOffer -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/ContractOffer"/>
    


    <!-- https://w3id.org/idsa/core/DataApp -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/DataApp"/>
    


    <!-- https://w3id.org/idsa/core/DataRepresentation -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/DataRepresentation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/DataResource -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/DataResource">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Resource"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/Described -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/Described"/>
    


    <!-- https://w3id.org/idsa/core/DescribedSemantically -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/DescribedSemantically"/>
    


    <!-- https://w3id.org/idsa/core/DigitalContent -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/DigitalContent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Described"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/Endpoint -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/Endpoint"/>
    


    <!-- https://w3id.org/idsa/core/ManagedEntity -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/ManagedEntity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/Described"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/RepresentationInstance -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/RepresentationInstance"/>
    


    <!-- https://w3id.org/idsa/core/Resource -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/Resource">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/odrl/2/Asset"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DescribedSemantically"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DigitalContent"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/ManagedEntity"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/RouteStep -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/RouteStep">
