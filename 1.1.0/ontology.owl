    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/Accuracy">
        <rdfs:comment xml:lang="en">Metric representing the degree to which data values correctly represent the real-world entity or event.</rdfs:comment>
        <rdfs:comment xml:lang="es">Métrica que representa el grado en que los valores de los datos representan correctamente la entidad o evento del mundo real.</rdfs:comment>
        <rdfs:label xml:lang="en">Accuracy</rdfs:label>
        <rdfs:label xml:lang="es">Exactitud</rdfs:label>
        <skos:inScheme rdf:resource="https://w3id.org/EDAAnOWL/metric-types"/>
        <skos:prefLabel xml:lang="en">Accuracy</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Exactitud</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/Completeness">
        <rdfs:comment xml:lang="en">Metric representing the degree to which all required data is present.</rdfs:comment>
        <rdfs:comment xml:lang="es">Métrica que representa el grado en que todos los datos requeridos están presentes.</rdfs:comment>
        <rdfs:label xml:lang="en">Completeness</rdfs:label>
        <rdfs:label xml:lang="es">Completitud</rdfs:label>
        <skos:inScheme rdf:resource="https://w3id.org/EDAAnOWL/metric-types"/>
        <skos:prefLabel xml:lang="en">Completeness</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Completitud</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/Uniqueness">
        <rdfs:comment xml:lang="en">Metric representing the degree to which data values are unique.</rdfs:comment>
        <rdfs:comment xml:lang="es">Métrica que representa el grado en que los valores de los datos son únicos.</rdfs:comment>
        <rdfs:label xml:lang="es">Unicidad</rdfs:label>
        <rdfs:label xml:lang="en">Uniqueness</rdfs:label>
        <skos:inScheme rdf:resource="https://w3id.org/EDAAnOWL/metric-types"/>
        <skos:prefLabel xml:lang="es">Unicidad</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Uniqueness</skos:prefLabel>
    </rdf:Description>
