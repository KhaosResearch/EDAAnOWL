    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/SmartDataApp -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/SmartDataApp">
        <rdfs:subClassOf rdf:resource="https://w3id.org/idsa/core/DataApp"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/SoftwareRepresentation -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/SoftwareRepresentation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
    </owl:Class>
    


    <!-- https://w3id.org/idsa/core/UsagePolicyClass -->


    <owl:Class rdf:about="https://w3id.org/idsa/core/UsagePolicyClass"/>
    


