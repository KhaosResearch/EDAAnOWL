    <!-- https://w3id.org/EDAAnOWL/ -->


    <owl:NamedIndividual rdf:about="https://w3id.org/EDAAnOWL/">
        <terms:creator rdf:resource="https://github.com/MartinM10"/>
        <terms:creator rdf:resource="https://khaos.uma.es/"/>
        <terms:creator rdf:resource="https://www.linkedin.com/in/martin-jeronimo-salvachua/"/>
        <terms:language rdf:resource="http://publications.europa.eu/resource/authority/language/ENG"/>
        <terms:language rdf:resource="http://publications.europa.eu/resource/authority/language/SPA"/>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:publisher rdf:resource="http://datos.gob.es/recurso/sector-publico/org/Organismo/E00123456"/>
        <dcat:theme rdf:resource="http://datos.gob.es/kos/sector-publico/sector/ciencia-tecnologia"/>
        <dcat:theme rdf:resource="http://publications.europa.eu/resource/authority/data-theme/TECH"/>
        <terms:description xml:lang="en">Ontology for data spaces that bridges the IDSA Information Model with the BIGOWL analytical family. Version 1.1.0 ensures full alignment with DCAT-AP-ES 1.0.0 and DCAT 3.0. It refines technical distribution constraints (SHACL) to prevent semantic leakage and standardizes metadata for official Spanish data portals (DIR3 IRIs, vCard conventions).</terms:description>
        <terms:description xml:lang="es">Ontología para espacios de datos que conecta el Modelo de Información IDSA con la familia analítica BIGOWL. La versión 1.1.0 asegura el alineamiento total con DCAT-AP-ES 1.0.0 y DCAT 3.0. Refina las restricciones técnicas de las distribuciones (SHACL) para evitar fugas semánticas y estandariza los metadatos para portales oficiales españoles (IRIs DIR3, convenciones vCard).</terms:description>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</terms:modified>
        <terms:title xml:lang="en">EDAAnOWL Ontology</terms:title>
        <terms:title xml:lang="es">Ontología EDAAnOWL</terms:title>
    </owl:NamedIndividual>
    


