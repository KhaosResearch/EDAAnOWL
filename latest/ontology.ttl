###  http://www.w3.org/ns/odrl/2/leftOperand
<http://www.w3.org/ns/odrl/2/leftOperand> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <http://www.w3.org/ns/odrl/2/Constraint> ;
                                          rdfs:range rdfs:Resource ;
                                          rdfs:comment "El operando izquierdo de una Restriccion ODRL (ODRL 2.2)."@es ,
                                                       "The left operand of an ODRL Constraint (ODRL 2.2)."@en ;
                                          rdfs:label "left operand"@en ,
                                                     "operando izquierdo"@es .


###  http://www.w3.org/ns/odrl/2/obligation
<http://www.w3.org/ns/odrl/2/obligation> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://www.w3.org/ns/odrl/2/Policy> ;
                                         rdfs:range <http://www.w3.org/ns/odrl/2/Rule> ;
                                         rdfs:comment "A Rule that obliges a party to perform an Action (ODRL 2.2)."@en ,
                                                      "Una Regla que obliga a una parte a realizar una Acción (ODRL 2.2)."@es ;
                                         rdfs:label "obligación"@es ,
                                                    "obligation"@en .


###  http://www.w3.org/ns/odrl/2/operator
<http://www.w3.org/ns/odrl/2/operator> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <http://www.w3.org/ns/odrl/2/Constraint> ;
                                       rdfs:range rdfs:Resource ;
                                       rdfs:comment "El operador usado en una Restriccion ODRL (ODRL 2.2)."@es ,
                                                    "The operator used in an ODRL Constraint (ODRL 2.2)."@en ;
                                       rdfs:label "operador"@es ,
                                                  "operator"@en .


###  http://www.w3.org/ns/odrl/2/permission
<http://www.w3.org/ns/odrl/2/permission> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://www.w3.org/ns/odrl/2/Policy> ;
                                         rdfs:range <http://www.w3.org/ns/odrl/2/Rule> ;
                                         rdfs:comment "A Rule that permits an Action on an Asset (ODRL 2.2)."@en ,
                                                      "Una Regla que permite una Accion sobre un Activo (ODRL 2.2)."@es ;
                                         rdfs:label "permiso"@es ,
                                                    "permission"@en .


###  http://www.w3.org/ns/odrl/2/prohibition
<http://www.w3.org/ns/odrl/2/prohibition> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <http://www.w3.org/ns/odrl/2/Policy> ;
                                          rdfs:range <http://www.w3.org/ns/odrl/2/Rule> ;
                                          rdfs:comment "A Rule that prohibits an Action on an Asset (ODRL 2.2)."@en ,
                                                       "Una Regla que prohíbe una Acción sobre un Activo (ODRL 2.2)."@es ;
                                          rdfs:label "prohibición"@es ,
                                                     "prohibition"@en .


###  http://www.w3.org/ns/odrl/2/target
<http://www.w3.org/ns/odrl/2/target> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <http://www.w3.org/ns/odrl/2/Rule> ;
                                     rdfs:range <http://www.w3.org/ns/odrl/2/Asset> ;
                                     rdfs:comment "El Activo objetivo de una Regla ODRL (ODRL 2.2)."@es ,
                                                  "The target Asset of an ODRL Rule (ODRL 2.2)."@en ;
                                     rdfs:label "objetivo"@es ,
                                                "target"@en .


###  http://www.w3.org/ns/prov#wasDerivedFrom
<http://www.w3.org/ns/prov#wasDerivedFrom> rdf:type owl:ObjectProperty ;
                                           rdfs:domain :DataAsset ;
                                           rdfs:range :DataAsset .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty ;
                                           rdfs:comment "Links a resource to the activity or DataApp that generated it. In AgoraOWL, typically links a DataAsset to the DataApp that produced it. Compatible with DCAT-AP-ES (prov:Activity) and AgoraOWL (agoraowl:DataApp)."@en ,
                                                        "Vincula un recurso con la actividad o DataApp que lo generó. En AgoraOWL, típicamente vincula un DataAsset con la DataApp que lo produjo. Compatible con DCAT-AP-ES (prov:Activity) y AgoraOWL (agoraowl:DataApp)."@es ;
                                           rdfs:label "fue generado por"@es ,
                                                      "was generated by"@en .


###  https://w3id.org/AgoraOWL/accessTypeConcept
:accessTypeConcept rdf:type owl:ObjectProperty ;
                   rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                   rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                   rdfs:comment "Links a resource to a SKOS concept describing its access mode (e.g., 'download', 'compute-in-place'). Replaces the deprecated :accessType string property."@en ,
                                "Vincula un recurso con un concepto SKOS que describe su modo de acceso (p. ej., 'descarga', 'cómputo-in-situ'). Reemplaza la propiedad string obsoleta :accessType."@es ;
                   rdfs:label "access type (concept)"@en ,
                              "tipo de acceso (concepto)"@es .


###  https://w3id.org/AgoraOWL/appliesToFeatureConcept
:appliesToFeatureConcept rdf:type owl:ObjectProperty ;
                         rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                         rdfs:comment "Links a metric to a formal schema element (as a SKOS Concept) describing the feature/column it applies to. Use this when a formal schema definition exists. For simple JSONPath strings, the deprecated :appliesToFeature (string) may still be used."@en ,
                                      "Vincula una métrica con un elemento de esquema formal (como un Concepto SKOS) que describe la característica/columna a la que aplica. Use esto cuando exista una definición de esquema formal. Para strings JSONPath simples, aún puede usarse la obsoleta :appliesToFeature (string)."@es ;
                         rdfs:label "applies to feature (concept)"@en ,
                                    "se aplica a característica (concepto)"@es .


###  https://w3id.org/AgoraOWL/conformsToSchema
:conformsToSchema rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf <http://purl.org/dc/terms/conformsTo> ;
                  rdfs:domain :DataSpecification ;
                  rdfs:comment "DEPRECATED: Use dcat:Distribution with dct:conformsTo instead. Links a profile to a formal technical schema (e.g., JSON Schema, XSD, SQL DDL)."@en ,
                               "OBSOLETO: Use dcat:Distribution con dct:conformsTo en su lugar. Vincula un perfil con un esquema técnico formal (p. ej., JSON Schema, XSD, SQL DDL)."@es ;
                  rdfs:label "conforms to schema (deprecated)"@en ,
                             "se ajusta al esquema (obsoleto)"@es ;
                  owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/constraintMetricType
:constraintMetricType rdf:type owl:ObjectProperty ;
                      rdfs:domain :DataConstraint ;
                      rdfs:range :MetricType ;
                      rdfs:comment "Identifica el tipo de métrica de calidad al que se aplica una restricción."@es ,
                                   "Identifies the type of quality metric a constraint applies to."@en ;
                      rdfs:label "constraint metric type"@en ,
                                 "tipo de métrica de restricción"@es .


###  https://w3id.org/AgoraOWL/constraintOperator
:constraintOperator rdf:type owl:ObjectProperty ;
                    rdfs:domain :DataConstraint ;
                    rdfs:range :ConstraintOperator ;
                    rdfs:comment "Links a quality constraint to a formal comparison operator (e.g., :GreaterOrEqual, :Equal). Replaces the previous string-based approach."@en ,
                                 "Vincula una restricción de calidad con un operador de comparación formal (p. ej., :GreaterOrEqual, :Equal). Reemplaza el enfoque anterior basado en strings."@es ;
                    rdfs:label "constraint operator"@en ,
                               "operador de restricción"@es .


###  https://w3id.org/AgoraOWL/consumesAppRepresentation
:consumesAppRepresentation rdf:type owl:ObjectProperty ;
                           rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                           rdfs:range <https://w3id.org/idsa/core/AppRepresentation> ;
                           rdfs:comment "Links a BIGOWL Component to an IDSA AppRepresentation it consumes. Use this for software/app flows."@en ,
                                        "Vincula un Componente BIGOWL con una AppRepresentation IDSA que consume. Use esto para flujos de software/apps."@es ;
                           rdfs:label "consume representación de app"@es ,
                                      "consumes app representation"@en .


###  https://w3id.org/AgoraOWL/consumesDataRepresentation
:consumesDataRepresentation rdf:type owl:ObjectProperty ;
                            rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                            rdfs:range :DataRepresentation ;
                            rdfs:comment "Links a BIGOWL Component to an AgoraOWL DataRepresentation it consumes as input. Use this for data flows."@en ,
                                         "Vincula un Componente BIGOWL con una DataRepresentation AgoraOWL que consume como entrada. Use esto para flujos de datos."@es ;
                            rdfs:label "consume representación de datos"@es ,
                                       "consumes data representation"@en .


###  https://w3id.org/AgoraOWL/consumesResource
:consumesResource rdf:type owl:ObjectProperty ;
                  rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                  rdfs:range <http://www.w3.org/ns/dcat#Distribution> ;
                  rdfs:comment "DEPRECATED: Use consumesDataRepresentation or consumesAppRepresentation instead. Links a BIGOWL Component to an IDSA Representation it consumes as input."@en ,
                               "OBSOLETO: Use consumesDataRepresentation o consumesAppRepresentation en su lugar. Vincula un Componente BIGOWL con una Representación IDSA que consume como entrada."@es ;
                  rdfs:label "consume representación (obsoleto)"@es ,
                             "consumes representation (deprecated)"@en ;
                  owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/declaresDataClass
:declaresDataClass rdf:type owl:ObjectProperty ;
                   rdfs:range <https://w3id.org/BIGOWLData/Data> ;
                   rdfs:comment "Links a DataSpecification to a BIGOWL Data class (e.g., bigdat:TabularDataSet, bigdat:Image)."@en ,
                                "Vincula un DataSpecification con una clase de Datos BIGOWL (p. ej., bigdat:TabularDataSet, bigdat:Image)."@es ;
                   rdfs:label "declara clase de datos"@es ,
                              "declares data class"@en .


###  https://w3id.org/AgoraOWL/externalQualityReport
:externalQualityReport rdf:type owl:ObjectProperty ;
                       rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                       rdfs:range :QualityReport ;
                       rdfs:comment "Links a resource to a structured object describing an external quality report."@en ,
                                    "Vincula un recurso con un objeto estructurado que describe un informe de calidad externo."@es ;
                       rdfs:label "external quality report"@en ,
                                  "informe de calidad externo"@es .


###  https://w3id.org/AgoraOWL/hasCRS
:hasCRS rdf:type owl:ObjectProperty ;
        rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
        rdfs:comment "Links a resource (Profile, Distribution, or Asset) to a SKOS Concept representing its Coordinate Reference System (e.g., EPSG:4326)."@en ,
                     "Vincula un recurso (Perfil, Distribución o Activo) con un concepto SKOS que representa su Sistema de Referencia de Coordenadas (p. ej., EPSG:4326)."@es ;
        rdfs:label "has CRS"@en ,
                   "tiene CRS"@es .


###  https://w3id.org/AgoraOWL/hasCertification
:hasCertification rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :DataApp
                                              :DataSpecification
                                              <https://w3id.org/idsa/core/Resource>
                                            )
                              ] ;
                  rdfs:range :CertificationReport ;
                  rdfs:comment "Links a Data Asset, Data App or Data Specification to a Certification Report attesting compliance with a standard (e.g., Gaia-X Label)."@en ,
                               "Vincula un Activo de Datos, una Data App o una Especificación de Datos con un Informe de Certificación que atestigua el cumplimiento de un estándar (p. ej., Etiqueta Gaia-X)."@es ;
                  rdfs:label "has certification"@en ,
                             "tiene certificación"@es .


###  https://w3id.org/AgoraOWL/hasConstraint
:hasConstraint rdf:type owl:ObjectProperty ;
               rdfs:domain :InputProfile ;
               rdfs:range :DataConstraint ;
               rdfs:comment "Links an input requirement to a specific quality or technical constraint that must be met by the data."@en ,
                            "Vincula un requisito de entrada con una restricción técnica o de calidad específica que deben cumplir los datos."@es ;
               rdfs:label "has constraint"@en ,
                          "tiene restricción"@es .


###  https://w3id.org/AgoraOWL/hasCredential
:hasCredential rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :DataApp
                                           :DataSpecification
                                           <https://w3id.org/idsa/core/Resource>
                                         )
                           ] ;
               rdfs:range <https://www.w3.org/2018/credentials#VerifiableCredential> ;
               rdfs:comment "Links a data space entity to a Verifiable Credential attesting its properties, quality metrics, or compliance certifications."@en ,
                            "Vincula una entidad de espacio de datos con una Credencial Verificable que certifica sus propiedades, métricas de calidad o certificaciones de conformidad."@es ;
               rdfs:label "has credential"@en ,
                          "tiene credencial"@es .


###  https://w3id.org/AgoraOWL/hasDPIA
:hasDPIA rdf:type owl:ObjectProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :DataApp
                                     <https://w3id.org/idsa/core/Resource>
                                   )
                     ] ;
         rdfs:range <http://xmlns.com/foaf/0.1/Document> ;
         rdfs:comment "Links an asset or DataApp to its Data Protection Impact Assessment (DPIA) document."@en ,
                      "Vincula un activo o DataApp con su documento de Evaluación de Impacto de Protección de Datos (DPIA)."@es ;
         rdfs:label "has DPIA"@en ,
                    "tiene DPIA"@es .


###  https://w3id.org/AgoraOWL/hasDataConstraint
:hasDataConstraint rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasConstraint ;
                   rdfs:domain :InputProfile ;
                   rdfs:range :DataConstraint ;
                   rdfs:comment "LEGACY: Use :hasConstraint instead. Links an input requirement to a specific quality threshold that must be met by the data."@en ,
                                "LEGADO: Use :hasConstraint en su lugar. Vincula un requisito de entrada con un umbral de calidad específico que deben cumplir los datos."@es ;
                   rdfs:label "has quality constraint (legacy)"@en ,
                              "tiene restricción de calidad (legado)"@es ;
                   owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/hasDataSpecification
:hasDataSpecification rdf:type owl:ObjectProperty ;
                      rdfs:domain :DataProfile ;
                      rdfs:range :DataSpecification ;
                      rdfs:comment "Links a DataProfile (or any of its subclasses: InputProfile, OutputProfile) to the DataSpecifications it contains or requires."@en ,
                                   "Vincula un DataProfile (o cualquiera de sus subclases: InputProfile, OutputProfile) con las DataSpecifications que contiene o requiere."@es ;
                      rdfs:label "has data specification"@en ,
                                 "tiene especificación de datos"@es .


###  https://w3id.org/AgoraOWL/hasDataType
:hasDataType rdf:type owl:ObjectProperty ;
             rdfs:domain :FieldMapping ;
             rdfs:range rdfs:Datatype ;
             rdfs:comment "Physical data type encoding of the field in the distribution (e.g., xsd:float, xsd:dateTime)."@en ,
                          "Tipo de dato físico del campo en la distribución (p. ej., xsd:float, xsd:dateTime)."@es ;
             rdfs:label "has data type"@en ,
                        "tiene tipo de dato"@es .


###  https://w3id.org/AgoraOWL/hasDomainSector
:hasDomainSector rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <http://www.w3.org/ns/dcat#theme> ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :DataApp
                                             <https://w3id.org/idsa/core/Resource>
                                           )
                             ] ;
                 rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment """A sub-property of dcat:theme linking a resource to its domain sector.

RECOMMENDED: Use EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):
  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agriculture
  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energy
  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Health
  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transport
  http://publications.europa.eu/resource/authority/data-theme/ENVI  # Environment
  http://publications.europa.eu/resource/authority/data-theme/TECH  # Science/Technology

Reference: http://publications.europa.eu/resource/authority/data-theme"""@en ,
                              """Una sub-propiedad de dcat:theme que vincula un recurso con su sector de dominio.

RECOMENDADO: Usar EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):
  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agricultura
  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energía
  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Salud
  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transporte

Referencia: http://publications.europa.eu/resource/authority/data-theme"""@es ;
                 rdfs:label "has domain sector"@en ,
                            "tiene sector de dominio"@es .


###  https://w3id.org/AgoraOWL/hasFeatureOfInterest
:hasFeatureOfInterest rdf:type owl:ObjectProperty ;
                      rdfs:range :FeatureOfInterest ;
                      rdfs:comment "Links a DataAsset, Metric, or DataSpecification to the entity or phenomenon it concerns (e.g., a specific crop or product). Used to define atomic semantic specifications."@en ,
                                   "Vincula un activo de datos, métrica o Perfil de Datos con la entidad o fenómeno sobre el que versa (p. ej., un cultivo específico). Se usa para definir especificaciones semánticas atómicas."@es ;
                      rdfs:label "has feature of interest"@en ,
                                 "tiene característica de interés"@es .


###  https://w3id.org/AgoraOWL/hasFieldMapping
:hasFieldMapping rdf:type owl:ObjectProperty ;
                 rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
                 rdfs:range :FieldMapping ;
                 rdfs:comment "Links a distribution to a FieldMapping, which maps an atomic semantic profile to a specific field in the physical file."@en ,
                              "Vincula una distribución con un FieldMapping, que mapea un perfil semántico atómico a un campo específico en el archivo físico."@es ;
                 rdfs:label "has field mapping"@en ,
                            "tiene mapeo de campo"@es .


###  https://w3id.org/AgoraOWL/hasInputProfile
:hasInputProfile rdf:type owl:ObjectProperty ;
                 rdfs:domain :DataApp ;
                 rdfs:range :InputProfile ;
                 rdfs:comment "Links a DataApp to a structured input requirement, aggregating a required profile and optional quality constraints."@en ,
                              "Vincula una DataApp con un requisito de entrada estructurado, agregando un perfil requerido y restricciones de calidad opcionales."@es ;
                 rdfs:label "has input requirement"@en ,
                            "tiene requisito de entrada"@es .


###  https://w3id.org/AgoraOWL/hasMetric
:hasMetric rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( <http://www.w3.org/ns/dcat#Distribution>
                                       :DataAsset
                                       :DataSpecification
                                       :FieldMapping
                                     )
                       ] ;
           rdfs:range :Metric ;
           rdfs:comment "Links a FieldMapping, DataSpecification, DataAsset, or Distribution to a quality, performance, or descriptive metric."@en ,
                        "Vincula un FieldMapping, DataSpecification, DataAsset o Distribution con una métrica de calidad, rendimiento o descriptiva."@es ;
           rdfs:label "has metric"@en ,
                      "tiene métrica"@es .


###  https://w3id.org/AgoraOWL/hasMetricStandard
:hasMetricStandard rdf:type owl:ObjectProperty ;
                   rdfs:comment "Links a metric or field-level value constraint to the standard or reference system used for its value. It can be a unit of measurement (QUDT) or a concept scheme/vocabulary (SKOS). Unifies the previous hasMetricUnit and usesVocabulary properties."@en ,
                                "Vincula una métrica o perfil con el estándar o sistema de referencia utilizado para su valor. Puede ser una unidad de medida (QUDT) o un esquema de conceptos/vocabulario (SKOS). Unifica las propiedades anteriores hasMetricUnit y usesVocabulary."@es ;
                   rdfs:label "has metric standard"@en ,
                              "tiene estándar de métrica"@es .


###  https://w3id.org/AgoraOWL/hasMetricUnit
:hasMetricUnit rdf:type owl:ObjectProperty ;
               rdfs:domain :Metric ;
               rdfs:comment "DEPRECATED: Use :hasMetricStandard instead. The unit of measurement for the metric value referencing a URI (e.g., qudt:KiloGM, unit:PERCENT)."@en ,
                            "OBSOLETO: Use :hasMetricStandard en su lugar. La unidad de medida para el valor de la métrica referenciando una URI (p. ej., qudt:KiloGM, unit:PERCENT)."@es ;
               rdfs:label "has metric unit (deprecated)"@en ,
                          "tiene unidad de métrica (obsoleto)"@es ;
               owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/hasObservableProperty
:hasObservableProperty rdf:type owl:ObjectProperty ;
                       rdfs:range :ObservableProperty ;
                       rdfs:comment "Links a DataAsset, Metric, or DataSpecification to the specific characteristic or phenomenon being measured. Used to define atomic semantic specifications."@en ,
                                    "Vincula un activo de datos, métrica o Perfil de Datos con el fenómeno o característica específica que se mide. Se usa para definir especificaciones semánticas atómicas."@es ;
                       rdfs:label "has observable property"@en ,
                                  "tiene propiedad observable"@es .


###  https://w3id.org/AgoraOWL/hasObservationMetric
:hasObservationMetric rdf:type owl:ObjectProperty ;
                      rdfs:domain :FieldMapping ;
                      rdfs:range :ObservationMetric ;
                      rdfs:comment "Links a FieldMapping to the statistical or aggregation metric of the observation (e.g., DailyAverage, Maximum)."@en ,
                                   "Vincula un FieldMapping con la métrica estadística o de agregación de la observación (p. ej., MediaDiaria, Máximo)."@es ;
                      rdfs:label "has observation metric"@en ,
                                 "tiene métrica de observación"@es .


###  https://w3id.org/AgoraOWL/hasOutputProfile
:hasOutputProfile rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataApp ;
                  rdfs:range :OutputProfile ;
                  rdfs:comment "Links a DataApp to a structured output declaration, specifying which DataSpecifications the application produces."@en ,
                               "Vincula una DataApp con una declaración de salida estructurada, especificando qué DataSpecifications produce la aplicación."@es ;
                  rdfs:label "has output profile"@en ,
                             "tiene perfil de salida"@es .


###  https://w3id.org/AgoraOWL/hasPerformanceMetric
:hasPerformanceMetric rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasMetric ;
                      rdfs:domain :DataApp ;
                      rdfs:range :PerformanceMetric ;
                      rdfs:comment "Links a DataApp to a specific performance metric (e.g., accuracy, execution time)."@en ,
                                   "Vincula una DataApp con una métrica de rendimiento específica (p. ej., precisión, tiempo de ejecución)."@es ;
                      rdfs:label "has performance metric"@en ,
                                 "tiene métrica de rendimiento"@es .


###  https://w3id.org/AgoraOWL/hasProfile
:hasProfile rdf:type owl:ObjectProperty ;
            rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
            rdfs:range :DataProfile ;
            rdfs:comment "Links a Distribution to a DataProfile grouping multiple DataSpecifications. For field-level semantic linking, prefer using :hasFieldMapping instead."@en ,
                         "Vincula una Distribución con un DataProfile que agrupa múltiples DataSpecifications. Para vinculación semántica a nivel de campo, prefiera usar :hasFieldMapping."@es ;
            rdfs:label "has profile"@en ,
                       "tiene perfil"@es .


###  https://w3id.org/AgoraOWL/hasSchemaType
:hasSchemaType rdf:type owl:ObjectProperty ;
               rdfs:domain :DataSpecification ;
               rdfs:comment "DEPRECATED: Technical schema details belong to the Distribution or FieldMapping layer. Identifies the technology or standard of the associated technical schema."@en ,
                            "OBSOLETO: Los detalles técnicos del esquema pertenecen a la capa de Distribution o FieldMapping. Identifica la tecnología o estándar del esquema técnico asociado."@es ;
               rdfs:label "has schema type (deprecated)"@en ,
                          "tiene tipo de esquema (obsoleto)"@es ;
               owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/hasSpatialCoverage
:hasSpatialCoverage rdf:type owl:ObjectProperty ;
                    rdfs:domain :SpatialTemporalAsset ;
                    rdfs:range <http://www.w3.org/ns/locn#Geometry> ;
                    rdfs:comment "Define la cobertura espacial del activo de datos requerido por las CUs de Observación de la Tierra."@es ,
                                 "Defines the spatial coverage of the data asset required by Earth Observation CUs."@en ;
                    rdfs:label "has spatial coverage"@en ,
                               "tiene cobertura espacial"@es .


###  https://w3id.org/AgoraOWL/hasTemporalCoverage
:hasTemporalCoverage rdf:type owl:ObjectProperty ;
                     rdfs:domain :SpatialTemporalAsset ;
                     rdfs:range <http://www.w3.org/2006/time#Interval> ;
                     rdfs:comment "Define la cobertura temporal del activo de datos requerido por las CUs de Observación de la Tierra."@es ,
                                  "Defines the temporal coverage of the data asset required by Earth Observation CUs."@en ;
                     rdfs:label "has temporal coverage"@en ,
                                "tiene cobertura temporal"@es .


###  https://w3id.org/AgoraOWL/hasUnit
:hasUnit rdf:type owl:ObjectProperty ;
         rdfs:domain :FieldMapping ;
         rdfs:range <http://qudt.org/vocab/unit/Unit> ;
         rdfs:comment "Links a FieldMapping to the QUDT unit of measurement for the physical field (e.g., qudt:DEG_C, qudt:PERCENT)."@en ,
                      "Vincula un FieldMapping con la unidad de medida QUDT del campo físico (p. ej., qudt:DEG_C, qudt:PERCENT)."@es ;
         rdfs:label "has unit"@en ,
                    "tiene unidad"@es .


###  https://w3id.org/AgoraOWL/implementsComponent
:implementsComponent rdf:type owl:ObjectProperty ;
                     rdfs:domain :DataApp ;
                     rdfs:range <https://w3id.org/BIGOWLWorkflows/Component> ;
                     rdfs:comment "Links an IDSA DataApp to the BIGOWL workflow Component it implements."@en ,
                                  "Vincula una DataApp IDSA con el Componente de flujo de trabajo BIGOWL que implementa."@es ;
                     rdfs:label "implementa componente"@es ,
                                "implements component"@en .


###  https://w3id.org/AgoraOWL/legalContact
:legalContact rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf <http://www.w3.org/ns/dcat#contactPoint> ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :DataApp
                                          <https://w3id.org/idsa/core/Resource>
                                        )
                          ] ;
              rdfs:range <http://www.w3.org/2006/vcard/ns#Kind> ;
              rdfs:comment "A specific contact point for legal inquiries about the asset or DataApp."@en ,
                           "Un punto de contacto específico para consultas legales sobre el activo o DataApp."@es ;
              rdfs:label "contacto legal"@es ,
                         "legal contact"@en .


###  https://w3id.org/AgoraOWL/mapsToSpecification
:mapsToSpecification rdf:type owl:ObjectProperty ;
                     rdfs:domain :FieldMapping ;
                     rdfs:range :DataSpecification ;
                     rdfs:comment "Links a FieldMapping to the atomic reusable DataSpecification it instantiates for a specific field."@en ,
                                  "Vincula un FieldMapping con el DataSpecification atómico reutilizable que instancia para un campo específico."@es ;
                     rdfs:label "binds profile"@en ,
                                "vincula perfil"@es .


###  https://w3id.org/AgoraOWL/measuresProperty
:measuresProperty rdf:type owl:ObjectProperty ;
                  rdfs:domain :Metric ;
                  rdfs:range :ObservableProperty ;
                  rdfs:comment "Links a metric (measurement) to the observable property it is quantifying. This indirectly associates a Unit of Measure (via Metric) with a physical phenomenon (ObservableProperty)."@en ,
                               "Vincula una métrica (medición) con la propiedad observable que está cuantificando. De este modo, se asocia de forma indirecta una Unidad de Medida (vía Metric) con un fenómeno físico (ObservableProperty)."@es ;
                  rdfs:label "measures property"@en ,
                             "mide la propiedad"@es .


###  https://w3id.org/AgoraOWL/metricType
:metricType rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://www.w3.org/ns/dqv#isMeasurementOf> ;
            rdfs:domain :Metric ;
            rdfs:range :MetricType ;
            rdfs:comment "Links a Metric measurement to a standardized MetricType definition from the controlled vocabulary. Aligned with dqv:isMeasurementOf for DQV interoperability."@en ,
                         "Vincula una medición de Métrica con una definición de MetricType estandarizada del vocabulario controlado. Alineada con dqv:isMeasurementOf para interoperabilidad DQV."@es ;
            rdfs:label "metric type"@en ,
                       "tipo de métrica"@es .


###  https://w3id.org/AgoraOWL/parameter
:parameter rdf:type owl:ObjectProperty ;
           rdfs:domain :DataApp ;
           rdfs:range <http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter> ;
           rdfs:comment "Links a DataApp to an execution parameter it accepts."@en ,
                        "Vincula una DataApp con un parámetro de ejecución que acepta."@es ;
           rdfs:label "parameter"@en ,
                      "parámetro"@es .


###  https://w3id.org/AgoraOWL/producesAppRepresentation
:producesAppRepresentation rdf:type owl:ObjectProperty ;
                           rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                           rdfs:range <https://w3id.org/idsa/core/AppRepresentation> ;
                           rdfs:comment "Links a BIGOWL Component to an IDSA AppRepresentation it produces. Use this for software/app flows."@en ,
                                        "Vincula un Componente BIGOWL con una AppRepresentation IDSA que produce. Use esto para flujos de software/apps."@es ;
                           rdfs:label "produce representación de app"@es ,
                                      "produces app representation"@en .


###  https://w3id.org/AgoraOWL/producesDataRepresentation
:producesDataRepresentation rdf:type owl:ObjectProperty ;
                            rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                            rdfs:range :DataRepresentation ;
                            rdfs:comment "Links a BIGOWL Component to an AgoraOWL DataRepresentation it produces as output. Use this for data flows."@en ,
                                         "Vincula un Componente BIGOWL con una DataRepresentation AgoraOWL que produce como salida. Use esto para flujos de datos."@es ;
                            rdfs:label "produce representación de datos"@es ,
                                       "produces data representation"@en .


###  https://w3id.org/AgoraOWL/producesProfile
:producesProfile rdf:type owl:ObjectProperty ;
                 rdfs:domain :DataApp ;
                 rdfs:range :DataSpecification ;
                 rdfs:comment "DEPRECATED: Use :hasOutputProfile and :hasDataSpecification instead. Links a DataApp to a DataSpecification it produces as output."@en ,
                              "OBSOLETO: Use :hasOutputProfile y :hasDataSpecification en su lugar. Vincula una DataApp con un DataSpecification que produce como salida."@es ;
                 rdfs:label "produce perfil (obsoleto)"@es ,
                            "produces profile (deprecated)"@en ;
                 owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/producesResource
:producesResource rdf:type owl:ObjectProperty ;
                  rdfs:domain <https://w3id.org/BIGOWLWorkflows/Component> ;
                  rdfs:range <http://www.w3.org/ns/dcat#Distribution> ;
                  rdfs:comment "DEPRECATED: Use producesDataRepresentation or producesAppRepresentation instead. Links a BIGOWL Component to an IDSA Representation it produces as output."@en ,
                               "OBSOLETO: Use producesDataRepresentation o producesAppRepresentation en su lugar. Vincula un Componente BIGOWL con una Representación IDSA que produce como salida."@es ;
                  rdfs:label "produce representación (obsoleto)"@es ,
                             "produces representation (deprecated)"@en ;
                  owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/realizesWorkflow
:realizesWorkflow rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataApp ;
                  rdfs:range <http://www.opmw.org/ontology/WorkflowTemplate> ;
                  rdfs:comment """DEPRECATED: A DataApp implements a Component, not a Workflow.

Use :implementsComponent instead to link a DataApp to the BIGOWL Component it implements.
A Workflow is a pipeline composed of multiple Components connected via Tasks.

If you need to indicate workflow membership, consider using bigwf:hasComponent (inverse)."""@en ,
                               """OBSOLETO: Una DataApp implementa un Component, no un Workflow.

Use :implementsComponent para vincular una DataApp con el Component BIGOWL que implementa.
Un Workflow es un pipeline compuesto por múltiples Components conectados via Tasks."""@es ;
                  rdfs:label "realiza flujo de trabajo (obsoleto)"@es ,
                             "realizes workflow (deprecated)"@en ;
                  owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/reportingEntity
:reportingEntity rdf:type owl:ObjectProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :CertificationReport
                                             :QualityReport
                                           )
                             ] ;
                 rdfs:range <http://www.w3.org/ns/org#Organization> ;
                 rdfs:comment "La organización que emitió el informe de calidad o certificación."@es ,
                              "The organization that issued the quality or certification report."@en ;
                 rdfs:label "entidad reportadora"@es ,
                            "reporting entity"@en .


###  https://w3id.org/AgoraOWL/requiresDataType
:requiresDataType rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataConstraint ;
                  rdfs:range rdfs:Datatype ;
                  rdfs:comment "Indica un requisito técnico de un tipo de dato específico para el puerto de entrada de la aplicación."@es ,
                               "Indicates a technical requirement for a specific data type at the application input port."@en ;
                  rdfs:label "requiere tipo de dato"@es ,
                             "requires data type"@en .


###  https://w3id.org/AgoraOWL/requiresMetric
:requiresMetric rdf:type owl:ObjectProperty ;
                rdfs:domain :DataConstraint ;
                rdfs:range :ObservationMetric ;
                rdfs:comment "Especifica la métrica de observación (p. ej., MediaDiaria) requerida por una DataConstraint para el emparejamiento."@es ,
                             "Specifies the observation metric (e.g., DailyAverage) required by a DataConstraint for matchmaking."@en ;
                rdfs:label "requiere métrica"@es ,
                           "requires metric"@en .


###  https://w3id.org/AgoraOWL/requiresProfile
:requiresProfile rdf:type owl:ObjectProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :DataApp
                                             :InputProfile
                                           )
                             ] ;
                 rdfs:range :DataSpecification ;
                 rdfs:comment "DEPRECATED: Use :hasInputProfile and :hasDataSpecification instead. Links a DataApp or InputProfile to a DataSpecification it requires as input."@en ,
                              "OBSOLETO: Use :hasInputProfile y :hasDataSpecification en su lugar. Vincula una DataApp o InputProfile con un DataSpecification que requiere como entrada."@es ;
                 rdfs:label "requiere perfil (obsoleto)"@es ,
                            "requires profile (deprecated)"@en ;
                 owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/requiresUnit
:requiresUnit rdf:type owl:ObjectProperty ;
              rdfs:domain :DataConstraint ;
              rdfs:range <http://qudt.org/vocab/unit/Unit> ;
              rdfs:comment "Especifica la unidad de medida (QUDT) requerida por una DataConstraint para el emparejamiento."@es ,
                           "Specifies the unit of measurement (QUDT) required by a DataConstraint for matchmaking."@en ;
              rdfs:label "requiere unidad"@es ,
                         "requires unit"@en .


###  https://w3id.org/AgoraOWL/spatialGranularityConcept
:spatialGranularityConcept rdf:type owl:ObjectProperty ;
                           rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                           rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                           rdfs:comment """Links a resource to a SKOS concept describing its spatial granularity.

RECOMMENDED vocabularies (DCAT-AP 3.0.1):
- EU NUTS: http://publications.europa.eu/resource/authority/nuts
- INSPIRE Codelists: http://inspire.ec.europa.eu/codelist/
- ISO 3166 (Countries): http://publications.europa.eu/resource/authority/country

Examples: NUTS level 1 (country), NUTS level 2 (region), NUTS level 3 (province)."""@en ,
                                        """Vincula un recurso con un concepto SKOS que describe su granularidad espacial.

Vocabularios RECOMENDADOS (DCAT-AP 3.0.1):
- EU NUTS: http://publications.europa.eu/resource/authority/nuts
- INSPIRE Codelsits: http://inspire.ec.europa.eu/codelist/
- ISO 3166 (Countries): http://publications.europa.eu/resource/authority/country

Ejemplos: NUTS nivel 1 (país), NUTS nivel 2 (región), NUTS nivel 3 (provincia)."""@es ;
                           rdfs:label "granularidad espacial (concepto)"@es ,
                                      "spatial granularity (concept)"@en .


###  https://w3id.org/AgoraOWL/supportContact
:supportContact rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/dcat#contactPoint> ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :DataApp
                                            <https://w3id.org/idsa/core/Resource>
                                          )
                            ] ;
                rdfs:range <http://www.w3.org/2006/vcard/ns#Kind> ;
                rdfs:comment "Punto de contacto estándar para soporte sobre el activo o DataApp, usando vCard."@es ,
                             "Standard contact point for support about the asset or DataApp, using vCard."@en ;
                rdfs:label "contacto de soporte"@es ,
                           "support contact"@en .


###  https://w3id.org/AgoraOWL/topic
:topic rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf <http://purl.org/dc/terms/subject> ;
       rdfs:domain [ rdf:type owl:Class ;
                     owl:unionOf ( :DataApp
                                   <https://w3id.org/idsa/core/Resource>
                                 )
                   ] ;
       rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
       rdfs:comment "A sub-property of dct:subject for linking an asset or DataApp to a descriptive SKOS concept (e.g., from AGROVOC)."@en ,
                    "Una sub-propiedad de dct:subject para vincular un activo o DataApp con un concepto SKOS descriptivo (p. ej., de AGROVOC)."@es ;
       rdfs:label "tema"@es ,
                  "topic"@en .


###  https://w3id.org/AgoraOWL/usesVocabulary
:usesVocabulary rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :DataSpecification
                                            :Metric
                                          )
                            ] ;
                rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                rdfs:comment "DEPRECATED: Use :hasMetricStandard instead. Links a profile or a metric to a concept scheme (controlled vocabulary) that defines the allowed values for the data (e.g., a SIEX or AGROVOC thesaurus). Useful for categorical columns."@en ,
                             "OBSOLETO: Use :hasMetricStandard en su lugar. Vincula un perfil o una métrica con un esquema de conceptos (vocabulario controlado) que define los valores permitidos para los datos (p. ej., un tesauro SIEX o AGROVOC). Útil para columnas categóricas."@es ;
                rdfs:label "usa vocabulario (obsoleto)"@es ,
                           "uses vocabulary (deprecated)"@en ;
                owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/idsa/core/appEndpoint
<https://w3id.org/idsa/core/appEndpoint> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <https://w3id.org/idsa/core/DataApp> ;
                                         rdfs:range <https://w3id.org/idsa/core/AppEndpoint> .


###  https://w3id.org/idsa/core/contractOffer
<https://w3id.org/idsa/core/contractOffer> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                                           rdfs:range <https://w3id.org/idsa/core/ContractOffer> .


###  https://w3id.org/idsa/core/dataAppInformation
<https://w3id.org/idsa/core/dataAppInformation> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <https://w3id.org/idsa/core/AppRepresentation> ;
                                                rdfs:range <https://w3id.org/idsa/core/DataApp> .


###  https://w3id.org/idsa/core/dataTypeSchema
<https://w3id.org/idsa/core/dataTypeSchema> rdf:type owl:ObjectProperty ;
                                            rdfs:domain :DataRepresentation ;
                                            rdfs:range <https://w3id.org/idsa/core/Resource> .


###  https://w3id.org/idsa/core/defaultRepresentation
<https://w3id.org/idsa/core/defaultRepresentation> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://w3id.org/idsa/core/DigitalContent> ;
                                                   rdfs:range <http://www.w3.org/ns/dcat#Distribution> .


###  https://w3id.org/idsa/core/endpointArtifact
<https://w3id.org/idsa/core/endpointArtifact> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/idsa/core/ConnectorEndpoint> ;
                                              rdfs:range <https://w3id.org/idsa/core/Artifact> .


###  https://w3id.org/idsa/core/instance
<https://w3id.org/idsa/core/instance> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
                                      rdfs:range <https://w3id.org/idsa/core/RepresentationInstance> .


###  https://w3id.org/idsa/core/listedAppResource
<https://w3id.org/idsa/core/listedAppResource> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <http://www.w3.org/ns/dcat#dataset> ;
                                               rdfs:domain <https://w3id.org/idsa/core/AppResourceCatalog> ;
                                               rdfs:range <https://w3id.org/idsa/core/AppResource> ;
                                               rdfs:comment "An AppResource that is part of an AppResourceCatalog."@en ;
                                               rdfs:label "listed AppResource"@en .


###  https://w3id.org/idsa/core/representation
<https://w3id.org/idsa/core/representation> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                                            rdfs:range <http://www.w3.org/ns/dcat#Distribution> .


###  https://w3id.org/idsa/core/requiredDataApp
<https://w3id.org/idsa/core/requiredDataApp> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/idsa/core/RouteStep> ;
                                             rdfs:range <https://w3id.org/idsa/core/AppRepresentation> .


###  https://w3id.org/idsa/core/resourceEndpoint
<https://w3id.org/idsa/core/resourceEndpoint> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                                              rdfs:range <https://w3id.org/idsa/core/ConnectorEndpoint> .


###  https://w3id.org/idsa/core/supportedUsagePolicies
<https://w3id.org/idsa/core/supportedUsagePolicies> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/idsa/core/DataApp> ;
                                                    rdfs:range <https://w3id.org/idsa/core/UsagePolicyClass> .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/alternative
<http://purl.org/dc/terms/alternative> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:DatatypeProperty ;
                                       rdfs:range rdfs:Literal ;
                                       rdfs:comment "An account of the resource (DCAT-AP 3.0)."@en ,
                                                    "Una descripción del recurso (DCAT-AP 3.0)."@es ;
                                       rdfs:label "descripción"@es ,
                                                  "description"@en .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "An unambiguous reference to the resource within a given context (DCAT-AP 3.0)."@en ,
                                                   "Una referencia inequívoca al recurso dentro de un contexto dado (DCAT-AP 3.0)."@es ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:DatatypeProperty ;
                                  rdfs:range rdfs:Literal ;
                                  rdfs:comment "La fecha de publicación formal del recurso (DCAT-AP 3.0)."@es ,
                                               "The date of formal issuance/publication of the resource (DCAT-AP 3.0)."@en ;
                                  rdfs:label "date issued"@en ,
                                             "fecha de publicación"@es .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:DatatypeProperty ;
                                 rdfs:range rdfs:Literal ;
                                 rdfs:comment "A name given to the resource (DCAT-AP 3.0)."@en ,
                                              "Un nombre dado al recurso (DCAT-AP 3.0)."@es ;
                                 rdfs:label "title"@en ,
                                            "título"@es .


###  http://www.w3.org/ns/adms#versionNotes
<http://www.w3.org/ns/adms#versionNotes> rdf:type owl:DatatypeProperty ;
                                         rdfs:range rdfs:Literal ;
                                         rdfs:comment "A description of changes between this version and the previous version (ADMS)."@en ,
                                                      "Una descripción de los cambios entre esta versión y la versión anterior (ADMS)."@es ;
                                         rdfs:label "notas de versión"@es ,
                                                    "version notes"@en .


###  http://www.w3.org/ns/dcat#byteSize
<http://www.w3.org/ns/dcat#byteSize> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
                                     rdfs:range xsd:nonNegativeInteger ;
                                     rdfs:comment "El tamaño de una Distribución en bytes (DCAT-AP 3.0)."@es ,
                                                  "The size of a Distribution in bytes (DCAT-AP 3.0)."@en ;
                                     rdfs:label "byte size"@en ,
                                                "tamaño en bytes"@es .


###  http://www.w3.org/ns/dcat#keyword
<http://www.w3.org/ns/dcat#keyword> rdf:type owl:DatatypeProperty ;
                                    rdfs:range rdfs:Literal ;
                                    rdfs:comment "A keyword or tag describing the Dataset (DCAT-AP 3.0)."@en ,
                                                 "Una palabra clave o etiqueta que describe el Dataset (DCAT-AP 3.0)."@es ;
                                    rdfs:label "keyword"@en ,
                                               "palabra clave"@es .


###  http://www.w3.org/ns/dcat#spatialResolutionInDegrees
<http://www.w3.org/ns/dcat#spatialResolutionInDegrees> rdf:type owl:DatatypeProperty ;
                                                       rdfs:range xsd:decimal ;
                                                       rdfs:comment "La distancia mínima para distinguir dos objetos, medida en grados (DCAT 3)."@es ,
                                                                    "The minimum distance to distinguish two objects, measured in degrees (DCAT 3)."@en ;
                                                       rdfs:label "resolución espacial (grados)"@es ,
                                                                  "spatial resolution (degrees)"@en .


###  http://www.w3.org/ns/dcat#spatialResolutionInMeters
<http://www.w3.org/ns/dcat#spatialResolutionInMeters> rdf:type owl:DatatypeProperty ;
                                                      rdfs:range xsd:decimal ;
                                                      rdfs:comment "La distancia mínima para distinguir dos objetos, medida en metros (DCAT 3)."@es ,
                                                                   "The minimum distance to distinguish two objects, measured in meters (DCAT 3)."@en ;
                                                      rdfs:label "resolución espacial (metros)"@es ,
                                                                 "spatial resolution (meters)"@en .


###  http://www.w3.org/ns/dcat#temporalResolution
<http://www.w3.org/ns/dcat#temporalResolution> rdf:type owl:DatatypeProperty ;
                                               rdfs:range xsd:duration ;
                                               rdfs:comment "El periodo de tiempo mínimo para distinguir entre dos eventos (DCAT 3)."@es ,
                                                            "The minimum time period to distinguish between two events (DCAT 3)."@en ;
                                               rdfs:label "resolución temporal"@es ,
                                                          "temporal resolution"@en .


###  http://www.w3.org/ns/dqv#value
<http://www.w3.org/ns/dqv#value> rdf:type owl:DatatypeProperty .


###  http://www.w3.org/ns/odrl/2/rightOperand
<http://www.w3.org/ns/odrl/2/rightOperand> rdf:type owl:DatatypeProperty ;
                                           rdfs:range rdfs:Literal ;
                                           rdfs:comment "El valor del operando derecho de una Restriccion ODRL. Esta alineacion ligera modela el caso literal habitual usado en los ejemplos CRED."@es ,
                                                        "The right operand value of an ODRL Constraint. This lightweight alignment models the common literal case used in CRED examples."@en ;
                                           rdfs:label "operando derecho"@es ,
                                                      "right operand"@en .


###  http://www.w3.org/ns/prov#generatedAtTime
<http://www.w3.org/ns/prov#generatedAtTime> rdf:type owl:DatatypeProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain <http://xmlns.com/foaf/0.1/Agent> ;
                                 rdfs:range rdfs:Literal ;
                                 rdfs:comment "El nombre de un Agente (persona u organización) (FOAF / DCAT-AP 3.0)."@es ,
                                              "The name of an Agent (person or organization) (FOAF / DCAT-AP 3.0)."@en ;
                                 rdfs:label "name"@en ,
                                            "nombre"@es .


###  https://schema.org/thumbnailUrl
<https://schema.org/thumbnailUrl> rdf:type owl:DatatypeProperty ;
                                  rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                                  rdfs:range xsd:anyURI .


###  https://w3id.org/AgoraOWL/accessType
:accessType rdf:type owl:DatatypeProperty ;
            rdfs:domain <https://w3id.org/idsa/core/Resource> ;
            rdfs:range xsd:string ;
            rdfs:comment "DEPRECATED: Use :accessTypeConcept instead. Indicates the primary access mode for the resource (e.g., download, compute, ...)."@en ,
                         "OBSOLETO: Use :accessTypeConcept en su lugar. Indica el modo de acceso principal para el recurso (p. ej., descarga, cómputo, ...)."@es ;
            rdfs:label "access type (deprecated)"@en ,
                       "tipo de acceso (obsoleto)"@es ;
            owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/alternativeName
:alternativeName rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf <http://purl.org/dc/terms/alternative> ;
                 rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                 rdfs:range rdfs:Literal ;
                 rdfs:comment "Alternative title or name for a resource."@en ,
                              "Título o nombre alternativo para un recurso."@es ;
                 rdfs:label "alternate name"@en ,
                            "nombre alternativo"@es .


###  https://w3id.org/AgoraOWL/anonymizationTechnique
:anonymizationTechnique rdf:type owl:DatatypeProperty ;
                        rdfs:domain :DataSpecification ,
                                    <https://w3id.org/idsa/core/Resource> ;
                        rdfs:range xsd:string ;
                        rdfs:comment "La técnica utilizada para anonimizar datos personales (p. ej., 'k-anonymity', 'privacidad diferencial')."@es ,
                                     "The technique used to anonymize personal data (e.g., 'k-anonymity', 'differential privacy')."@en ;
                        rdfs:label "anonymization technique"@en ,
                                   "técnica de anonimización"@es .


###  https://w3id.org/AgoraOWL/appliesToFeature
:appliesToFeature rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Metric ;
                  rdfs:range xsd:string ;
                  rdfs:comment "DEPRECATED: Use :appliesToFeatureConcept for formal schema pointers. Indicates the specific feature, column, or attribute to which a metric refers (e.g., 'column_name', 'user.address.city', '$.user.address.city')."@en ,
                               "OBSOLETO: Use :appliesToFeatureConcept para punteros formales a esquema. Indica la característica, columna o atributo específico al que se refiere una métrica (p. ej., 'column_name', 'user.address.city', '$.user.address.city')."@es ;
                  rdfs:label "applies to feature (deprecated)"@en ,
                             "se aplica a característica (obsoleto)"@es ;
                  owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/auditLogAvailable
:auditLogAvailable rdf:type owl:DatatypeProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :DataApp
                                               <https://w3id.org/idsa/core/Resource>
                                             )
                               ] ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Indica si los registros de auditoría para el uso del activo o DataApp están disponibles."@es ,
                                "Indicates if audit logs for the asset or DataApp usage are available."@en ;
                   rdfs:label "audit log available"@en ,
                              "registro de auditoría disponible"@es .


###  https://w3id.org/AgoraOWL/certificationLevel
:certificationLevel rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CertificationReport ;
                    rdfs:range xsd:string ;
                    rdfs:comment "El nivel de certificación alcanzado (p. ej., 'Gaia-X Label 1', 'Gold')."@es ,
                                 "The level of certification achieved (e.g., 'Gaia-X Label 1', 'Gold')."@en ;
                    rdfs:label "certification level"@en ,
                               "nivel de certificación"@es .


###  https://w3id.org/AgoraOWL/collectionMethod
:collectionMethod rdf:type owl:DatatypeProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :DataApp
                                              <https://w3id.org/idsa/core/Resource>
                                            )
                              ] ;
                  rdfs:range xsd:string ;
                  rdfs:comment "El método utilizado para recolectar los datos o el modo de adquisición de la App (p. ej., 'sensor', 'encuesta', 'satélite')."@es ,
                               "The method used to collect the data or the App's acquisition mode (e.g., 'sensor', 'survey', 'satellite')."@en ;
                  rdfs:label "collection method"@en ,
                             "método de recolección"@es .


###  https://w3id.org/AgoraOWL/computedAt
:computedAt rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://www.w3.org/ns/prov#generatedAtTime> ;
            rdfs:domain :Metric ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "La marca de tiempo que indica cuándo se calculó o validó el valor de la métrica. Alineada con prov:generatedAtTime para interoperabilidad de procedencia."@es ,
                         "The timestamp indicating when the metric's value was computed or validated. Aligned with prov:generatedAtTime for provenance interoperability."@en ;
            rdfs:label "calculado en"@es ,
                       "computed at"@en .


###  https://w3id.org/AgoraOWL/constraintValue
:constraintValue rdf:type owl:DatatypeProperty ;
                 rdfs:domain :DataConstraint ;
                 rdfs:range rdfs:Literal ;
                 rdfs:comment "Define el valor umbral para una restricción de calidad."@es ,
                              "Defines the threshold value for a quality constraint."@en ;
                 rdfs:label "constraint value"@en ,
                            "valor de restricción"@es .


###  https://w3id.org/AgoraOWL/containsPersonalData
:containsPersonalData rdf:type owl:DatatypeProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( :DataApp
                                                  :DataSpecification
                                                  <https://w3id.org/idsa/core/Resource>
                                                )
                                  ] ;
                      rdfs:range xsd:boolean ;
                      rdfs:comment "Indica si el recurso (especificación, activo o App) incluye información de identificación personal (PII) o datos sujetos a GDPR."@es ,
                                   "Indicates whether the resource (specification, asset or App) includes Personally Identifiable Information (PII) or data subject to GDPR."@en ;
                      rdfs:label "contains personal data"@en ,
                                 "contiene datos personales"@es .


###  https://w3id.org/AgoraOWL/isAlive
:isAlive rdf:type owl:DatatypeProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :DataApp
                                     <https://w3id.org/idsa/core/Resource>
                                   )
                     ] ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Indica si el activo o la App se mantiene activamente y espera actualizaciones futuras."@es ,
                      "Indicates if the asset or App is actively maintained and expects future updates."@en ;
         rdfs:label "está activo"@es ,
                    "is alive"@en .


###  https://w3id.org/AgoraOWL/isStreaming
:isStreaming rdf:type owl:DatatypeProperty ;
             rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Indica si los datos de esta distribución se proporcionan en tiempo real como un flujo continuo (streaming) en lugar de un conjunto de datos estático."@es ,
                          "Indicates whether the data in this distribution is provided in real-time as a continuous stream instead of a static dataset."@en ;
             rdfs:label "es flujo continuo (streaming)"@es ,
                        "is streaming"@en .


###  https://w3id.org/AgoraOWL/knownLimitations
:knownLimitations rdf:type owl:DatatypeProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :DataApp
                                              <https://w3id.org/idsa/core/Resource>
                                            )
                              ] ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Descripción legible de cualquier limitación conocida, sesgo o problema de calidad del activo o DataApp."@es ,
                               "Human-readable description of any known limitations, biases, or quality issues of the asset or DataApp."@en ;
                  rdfs:label "known limitations"@en ,
                             "limitaciones conocidas"@es .


###  https://w3id.org/AgoraOWL/mapsField
:mapsField rdf:type owl:DatatypeProperty ;
           rdfs:domain :FieldMapping ;
           rdfs:range xsd:string ;
           rdfs:comment "El identificador físico (nombre de columna, JSONPath, XPath) del campo en la distribución que corresponde al perfil atómico vinculado."@es ,
                        "The physical identifier (column name, JSONPath, XPath) of the field in the distribution that corresponds to the bound atomic profile."@en ;
           rdfs:label "maps to field"@en ,
                      "se mapea al campo"@es .


###  https://w3id.org/AgoraOWL/metricName
:metricName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Metric ;
            rdfs:range xsd:string ;
            rdfs:comment "A human-readable name or identifier for the metric (e.g., 'recordCount', 'missing_ratio')."@en ,
                         "Un nombre o identificador legible para la métrica (p. ej., 'recordCount', 'missing_ratio')."@es ;
            rdfs:label "metric name"@en ,
                       "nombre de métrica"@es .


###  https://w3id.org/AgoraOWL/metricUnit
:metricUnit rdf:type owl:DatatypeProperty ;
            rdfs:domain :Metric ;
            rdfs:range xsd:string ;
            rdfs:comment "DEPRECATED: Use :hasMetricStandard instead. The unit of measurement for the metric value (e.g., '%', 'kg/ha', 'ppm')."@en ,
                         "OBSOLETO: Use :hasMetricStandard en su lugar. La unidad de medida para el valor de la métrica (p. ej., '%', 'kg/ha', 'ppm')."@es ;
            rdfs:label "metric unit (deprecated)"@en ,
                       "unidad de métrica (obsoleto)"@es ;
            owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/metricValue
:metricValue rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://www.w3.org/ns/dqv#value> ;
             rdfs:domain :Metric ;
             rdfs:range rdfs:Literal ;
             rdfs:comment "El valor de la medición de la métrica. Alineado con dqv:value para interoperabilidad DQV. El rango es rdfs:Literal para soportar múltiples tipos de datos (p. ej., xsd:boolean, xsd:integer, xsd:string, xsd:decimal)."@es ,
                          "The value of the metric measurement. Aligned with dqv:value for DQV interoperability. Range is rdfs:Literal to support multiple datatypes (e.g., xsd:boolean, xsd:integer, xsd:string, xsd:decimal)."@en ;
             rdfs:label "metric value"@en ,
                        "valor de métrica"@es .


###  https://w3id.org/AgoraOWL/nullPercentage
:nullPercentage rdf:type owl:DatatypeProperty ;
                rdfs:domain <https://w3id.org/BIGOWLData/Column> ;
                rdfs:range xsd:decimal ;
                rdfs:comment "El porcentaje de valores nulos en una columna (0.0 a 1.0)."@es ,
                             "The percentage of null values in a column (0.0 to 1.0)."@en ;
                rdfs:label "null percentage"@en ,
                           "porcentaje de nulos"@es .


###  https://w3id.org/AgoraOWL/paymentModelDescription
:paymentModelDescription rdf:type owl:DatatypeProperty ;
                         rdfs:domain [ rdf:type owl:Class ;
                                       owl:unionOf ( :DataApp
                                                     <https://w3id.org/idsa/core/Resource>
                                                   )
                                     ] ;
                         rdfs:range xsd:string ;
                         rdfs:comment "A human-readable description of the pricing or payment model (e.g., 'Monthly Subscription', 'Pay-per-use') for the asset or App."@en ,
                                      "Una descripción legible del modelo de precios o pago (p. ej., 'Suscripción Mensual', 'Pago por uso') para el activo o App."@es ;
                         rdfs:label "descripción del modelo de pago"@es ,
                                    "payment model description"@en .


###  https://w3id.org/AgoraOWL/profileCRS
:profileCRS rdf:type owl:DatatypeProperty ;
            rdfs:domain :DataSpecification ;
            rdfs:range xsd:string ;
            rdfs:label "CRS de perfil"@es ,
                       "profile CRS"@en ;
            owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/profileSpatialResolution
:profileSpatialResolution rdf:type owl:DatatypeProperty ;
                          rdfs:domain :DataSpecification ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Deprecated. Use dcat:spatialResolutionInMeters or dcat:spatialResolutionInDegrees."@en ,
                                       "Obsoleto. Use dcat:spatialResolutionInMeters o dcat:spatialResolutionInDegrees."@es ;
                          rdfs:label "profile spatial resolution"@en ,
                                     "resolución espacial de perfil"@es ;
                          owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/profileTemporalResolution
:profileTemporalResolution rdf:type owl:DatatypeProperty ;
                           rdfs:domain :DataSpecification ;
                           rdfs:range xsd:duration ;
                           rdfs:comment "Deprecated. Use dcat:temporalResolution for temporal resolution of datasets/profiles."@en ,
                                        "Obsoleto. Use dcat:temporalResolution para la resolución temporal de conjuntos de datos/perfiles."@es ;
                           rdfs:label "profile temporal resolution"@en ,
                                      "resolución temporal de perfil"@es ;
                           rdfs:seeAlso <http://www.w3.org/ns/dcat#temporalResolution> ;
                           owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/AgoraOWL/qualityReportURI
:qualityReportURI rdf:type owl:DatatypeProperty ;
                  rdfs:domain :QualityReport ;
                  rdfs:range xsd:anyURI ;
                  rdfs:comment "El URI del informe de calidad completo y legible (p. ej., un documento PDF o HTML)."@es ,
                               "The URI of the full, human-readable quality report (e.g., a PDF or HTML document)."@en ;
                  rdfs:label "URI de informe de calidad"@es ,
                             "quality report URI"@en .


###  https://w3id.org/AgoraOWL/qualityScore
:qualityScore rdf:type owl:DatatypeProperty ;
              rdfs:domain :QualityReport ;
              rdfs:range xsd:integer ;
              rdfs:comment "A quantitative quality score (e.g., 0-100) assigned by the external quality report."@en ,
                           "Una puntuación de calidad cuantitativa (p. ej., 0-100) asignada por el informe de calidad externo."@es ;
              rdfs:label "puntuación de calidad"@es ,
                         "quality score"@en .


###  https://w3id.org/AgoraOWL/recommendedUse
:recommendedUse rdf:type owl:DatatypeProperty ;
                rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                rdfs:range xsd:string ;
                rdfs:comment "Descripción legible de los casos de uso previstos o recomendados para el recurso."@es ,
                             "Human-readable description of the intended or recommended use cases for the resource."@en ;
                rdfs:label "recommended use"@en ,
                           "uso recomendado"@es .


###  https://w3id.org/AgoraOWL/refundPolicy
:refundPolicy rdf:type owl:DatatypeProperty ;
              rdfs:domain <https://w3id.org/idsa/core/Resource> ;
              rdfs:range xsd:string ;
              rdfs:comment "A text description of the refund policy applicable to the resource."@en ,
                           "Una descripción textual de la política de reembolso aplicable al recurso."@es ;
              rdfs:label "política de reembolso"@es ,
                         "refund policy"@en .


###  https://w3id.org/AgoraOWL/reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( :CertificationReport
                                        :QualityReport
                                      )
                        ] ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "La fecha en que se emitió el informe."@es ,
                         "The date when the report was issued."@en ;
            rdfs:label "fecha del informe"@es ,
                       "report date"@en .


###  https://w3id.org/AgoraOWL/sampleValue
:sampleValue rdf:type owl:DatatypeProperty ;
             rdfs:domain <https://w3id.org/BIGOWLData/Column> ;
             rdfs:range rdfs:Literal ;
             rdfs:comment "A representative sample value for a column."@en ,
                          "Un valor de muestra representativo para una columna."@es ;
             rdfs:label "sample value"@en ,
                        "valor de muestra"@es .


###  https://w3id.org/AgoraOWL/securityClassification
:securityClassification rdf:type owl:DatatypeProperty ;
                        rdfs:domain <https://w3id.org/idsa/core/Resource> ;
                        rdfs:range xsd:string ;
                        rdfs:comment "El nivel de clasificación de seguridad del recurso (por ejemplo, Público, Confidencial)."@es ,
                                     "The security classification level of the resource (e.g., Public, Confidential)."@en ;
                        rdfs:label "clasificación de seguridad"@es ,
                                   "security classification"@en .


