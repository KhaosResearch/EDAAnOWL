<https://w3id.org/EDAAnOWL/0.7.0/vocabularies/siex> a owl:Ontology ;
    dct:description "Ontology for representing SIEX (Sistema de Información de Explotaciones Agrarias) codes as SKOS concepts. Aligned with version 0.7.0."@en ;
    dct:title "SIEX Ontology Alignment"@en,
        "Ontología de Alineación SIEX"@es ;
    rdfs:comment "Provisional local SKOS representation of the official SIEX (FEGA) catalogs. Codes are automatically transformed from CSV official catalogs to facilitate government aid compliance (CAP/PAC) for Spanish participants."@en ;
    owl:versionInfo "0.7.0" .

