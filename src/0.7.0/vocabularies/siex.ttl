@prefix : <https://w3id.org/EDAAnOWL/0.7.0/vocabularies/siex/> .
@prefix kos: <https://w3id.org/EDAAnOWL/0.7.0/vocabularies/siex/kos/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@base <https://w3id.org/EDAAnOWL/0.7.0/vocabularies/siex/> .

<https://w3id.org/EDAAnOWL/0.7.0/vocabularies/siex> a owl:Ontology ;
    dct:title "SIEX Ontology Alignment"@en , "Ontología de Alineación SIEX"@es ;
    dct:description "Ontology for representing SIEX (Sistema de Información de Explotaciones Agrarias) codes as SKOS concepts. Aligned with version 0.7.0."@en ;
    rdfs:comment "Provisional local SKOS representation of the official SIEX (FEGA) catalogs. Since there is no official RDF/SKOS publication for these codes, they are curated here to support the EDAAn Data Space (Spanish Agri-food sector). The codes are automatically transformed from CSV official catalogs (https://www3.sede.fega.gob.es/bdcsixpor/catalogos) to facilitate government aid compliance (CAP/PAC) for Spanish participants."@en ;
    owl:versionInfo "0.7.0" .

#################################################################
#    Object Properties
#################################################################

:siexConcept a owl:ObjectProperty ;
    rdfs:label "siex concept"@en , "concepto siex"@es ;
    rdfs:comment "Links an entity to a SIEX SKOS Concept."@en ;
    rdfs:range skos:Concept .

#################################################################
#    Concept Schemes (SIEX Catalogs)
#################################################################

kos:siexCropProductValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Crop Product Value Codes"@en , "Códigos de Producto Vegetal SIEX"@es .

kos:siexCropTypeValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Crop Type Value Codes"@en , "Códigos de Tipo de Cultivo SIEX"@es .

kos:siexFarmingSystemValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Farming System Value Codes"@en , "Códigos de Sistema de Cultivo SIEX"@es .

kos:siexFertilizationMethodValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilization Method Value Codes"@en , "Códigos de Método de Aplicación de Fertilizante SIEX"@es .

kos:siexFertilizationTypeValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilization Type Value Codes"@en , "Códigos de Tipo de Fertilización SIEX"@es .

kos:siexFertilizerMaterialValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilizer Material Value Codes"@en , "Códigos de Material Fertilizante SIEX"@es .

kos:siexIntendedCropUseValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Intended Crop Use Value Codes"@en , "Códigos de Finalidad de la Cosecha SIEX"@es .

kos:siexIrrigationWaterSourceValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Irrigation Water Source Value Codes"@en , "Códigos de Procedencia del Agua de Riego SIEX"@es .

kos:siexRootstockValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Rootstock Value Codes"@en , "Códigos de Portainjerto SIEX"@es .

kos:siexSoilCoverActivityValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Soil Cover Activity Value Codes"@en , "Códigos de Actividad de Cobertura del Suelo SIEX"@es .

kos:siexSoilCoverTypeValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Soil Cover Type Value Codes"@en , "Códigos de Tipo de Cobertura del Suelo SIEX"@es .

kos:siexTreatmentEffectivenessValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Treatment Effectiveness Value Codes"@en , "Códigos de Eficacia del Tratamiento SIEX"@es .

kos:siexTrellisingSystemValueCode a skos:ConceptScheme ;
    rdfs:label "SIEX Trellising System Value Codes"@en , "Códigos de Sistema de Conducción SIEX"@es .
