@prefix : <https://w3id.org/EDAAnOWL/siex/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@base <https://w3id.org/EDAAnOWL/siex/> .

<https://w3id.org/EDAAnOWL/siex/> a owl:Ontology ;
    dct:title "SIEX Ontology Alignment"@en , "Ontología de Alineación SIEX"@es ;
    dct:description "Ontology for representing SIEX (Sistema de Información de Explotaciones Agrarias) codes as SKOS concepts. Rebranded from Agrixels to official EDAAnOWL namespace."@en ;
    owl:versionInfo "0.7.0" .

#################################################################
#    Object Properties
#################################################################

:siexConcept a owl:ObjectProperty ;
    rdfs:label "siex concept"@en , "concepto siex"@es ;
    rdfs:comment "Links an entity to a SIEX SKOS Concept."@en ;
    rdfs:range skos:Concept .

#################################################################
#    Concept Schemes (SIEX Catalogs)
#################################################################

<https://w3id.org/EDAAnOWL/siex/kos/siexCropProductValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Crop Product Value Codes"@en , "Códigos de Producto Vegetal SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexCropTypeValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Crop Type Value Codes"@en , "Códigos de Tipo de Cultivo SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexFarmingSystemValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Farming System Value Codes"@en , "Códigos de Sistema de Cultivo SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexFertilizationMethodValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilization Method Value Codes"@en , "Códigos de Método de Aplicación de Fertilizante SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexFertilizationTypeValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilization Type Value Codes"@en , "Códigos de Tipo de Fertilización SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexFertilizerMaterialValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Fertilizer Material Value Codes"@en , "Códigos de Material Fertilizante SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexIntendedCropUseValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Intended Crop Use Value Codes"@en , "Códigos de Finalidad de la Cosecha SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexIrrigationWaterSourceValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Irrigation Water Source Value Codes"@en , "Códigos de Procedencia del Agua de Riego SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexRootstockValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Rootstock Value Codes"@en , "Códigos de Portainjerto SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexSoilCoverActivityValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Soil Cover Activity Value Codes"@en , "Códigos de Actividad de Cobertura del Suelo SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexSoilCoverTypeValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Soil Cover Type Value Codes"@en , "Códigos de Tipo de Cobertura del Suelo SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexTreatmentEffectivenessValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Treatment Effectiveness Value Codes"@en , "Códigos de Eficacia del Tratamiento SIEX"@es .

<https://w3id.org/EDAAnOWL/siex/kos/siexTrellisingSystemValueCode> a skos:ConceptScheme ;
    rdfs:label "SIEX Trellising System Value Codes"@en , "Códigos de Sistema de Conducción SIEX"@es .
