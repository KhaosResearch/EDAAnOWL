@prefix : <https://w3id.org/AgoraOWL/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcatap: <http://data.europa.eu/r5r/> .
@prefix dqv: <http://www.w3.org/ns/dqv#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ids: <https://w3id.org/idsa/core/> .
@prefix bigdat: <https://w3id.org/BIGOWLData/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix theme: <http://publications.europa.eu/resource/authority/data-theme/> .
@prefix agrovoc: <http://aims.fao.org/aos/agrovoc/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

@base <https://w3id.org/AgoraOWL/examples/cred/> .

# ═══════════════════════════════════════════════════════════════
#  CRED-compliant Asset Annotation Example (AgoraOWL v1.0.0)
#
#  This example demonstrates how to annotate a data space asset
#  following the v1.0.0 decoupled Semantic Architecture.
# ═══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
#  1. CATALOG — Semantic resource catalog of a data space
# ─────────────────────────────────────────────────────────────

<catalog/agri-data-space> a dcat:Catalog ;
    dct:title "Catálogo del Espacio de Datos Agrícola"@es ,
              "Agricultural Data Space Catalog"@en ;
    dct:description "Catálogo de recursos semánticos del espacio de datos agrícola de Andalucía"@es ;
    dct:publisher <agent/junta-andalucia> ;
    dcat:dataset <dataset/olive-grove-monitoring> ;
    dcat:service <service/crop-forecast-api> ;
    dcatap:applicableLegislation <https://www.boe.es/eli/es-ga/2024/10/01> .


# ─────────────────────────────────────────────────────────────
#  2. PUBLISHER — FOAF Agent
# ─────────────────────────────────────────────────────────────

<agent/junta-andalucia> a foaf:Agent ;
    foaf:name "Junta de Andalucía"@es ;
    dct:type <http://publications.europa.eu/resource/authority/corporate-body> .

<agent/khaos-research> a foaf:Agent ;
    foaf:name "Khaos Research Group"@en ;
    dct:type <http://publications.europa.eu/resource/authority/corporate-body> .


# ─────────────────────────────────────────────────────────────
#  3. DATASET — Data Asset annotated with DCAT-AP 3.0 metadata
# ─────────────────────────────────────────────────────────────

<dataset/olive-grove-monitoring> a :DataAsset , dcat:Dataset ;
    dct:title "Datos de Monitorización de Olivares"@es ,
              "Olive Grove Monitoring Data"@en ;
    dct:description "Datos de sensores y satélite sobre el estado de olivares en la provincia de Jaén"@es ;
    dct:identifier "olive-grove-monitoring-2026" ;
    dct:modified "2026-03-01"^^xsd:date ;
    dct:issued "2025-06-15"^^xsd:date ;
    dct:publisher <agent/junta-andalucia> ;
    dct:creator <agent/khaos-research> ;
    dct:language <http://publications.europa.eu/resource/authority/language/SPA> ,
                 <http://publications.europa.eu/resource/authority/language/ENG> ;
    dct:type <http://publications.europa.eu/resource/authority/dataset-type/STATISTICAL> ;
    dct:spatial <http://datos.gob.es/recurso/sector-publico/territorio/Autonomia/Andalucia> ;
    dct:accessRights <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    dcat:theme theme:AGRI , theme:ENVI ;
    dcat:keyword "olivar"@es , "NDVI"@en , "teledetección"@es , "remote sensing"@en ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/DAILY> ;
    owl:versionInfo "2.1.0" ;
    dcatap:applicableLegislation <https://www.boe.es/eli/es/rd/2023/12/19/1089> ;
    dcat:landingPage <https://datos.juntadeandalucia.es/olivar-monitoring> ;
    dcat:distribution <distribution/olive-csv> ;
    ids:representation <distribution/olive-csv> ;
    # ── AgoraOWL-specific ──
    :hasDomainSector theme:AGRI ;
    :isAlive true ;
    dct:conformsTo <http://data.europa.eu/r5r/dcat-ap/3.0.1> ;
    dqv:hasQualityMetadata <quality/olive-dataset-assessment> ;
    # ── ODRL policy ──
    odrl:hasPolicy <policy/olive-data-offer> .


# ─────────────────────────────────────────────────────────────
#  4. DISTRIBUTION — Concrete delivery form with DCAT-AP 3.0
# ─────────────────────────────────────────────────────────────

<distribution/olive-csv> a :DataRepresentation , dcat:Distribution ;
    dct:title "Distribución CSV de datos de olivar"@es ,
              "Olive grove CSV distribution"@en ;
    dct:description "Archivo CSV con datos tabulares de monitorización de olivar"@es ;
    dcat:accessURL <https://datos.juntadeandalucia.es/api/v1/olivar/download> ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/csv> ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/CSV> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:rights <https://datos.gob.es/catalogo/derechos-de-access> ;
    dcat:byteSize "15728640"^^xsd:decimal ;
    dct:issued "2025-06-15"^^xsd:date ;
    dct:modified "2026-03-01"^^xsd:date ;
    adms:status <http://purl.org/adms/status/Completed> ;
    # v1.0.0: Technical metadata on Distribution
    dcat:temporalResolution "P1D"^^xsd:duration ;
    dcat:spatialResolutionInMeters "10.0"^^xsd:decimal ;
    :hasCRS <http://www.opengis.net/def/crs/EPSG/0/4326> ;
    # v1.0.0: FieldMapping links to Specification and adds technical details
    :hasFieldMapping [
        a :FieldMapping ;
        :mapsToSpecification <spec/ndvi-daily-spec> ;
        :mapsField "ndvi_daily" ;
        :hasUnit qudt:UNITLESS ;
        :hasDataType xsd:float ;
        :hasObservationMetric :DailyAverage ;
        :hasMetric <metric/olive-record-count> ,
                    <metric/olive-completeness> ,
                    <metric/olive-ndvi-avg>
    ] .


# ─────────────────────────────────────────────────────────────
#  5. DATA SPECIFICATION — Atomic semantic variable (v1.0.0)
# ─────────────────────────────────────────────────────────────

<spec/ontology-schema-spec> a :DataSpecification ;
    rdfs:label "AgoraOWL Ontology Specification"@en ;
    :hasObservableProperty <spec/OntologyConcept> ;
    :hasFeatureOfInterest <spec/OntologyFeature> .

<spec/OntologyConcept> a :ObservableProperty ;
    skos:prefLabel "Ontology"@en .

<spec/OntologyFeature> a :FeatureOfInterest ;
    skos:prefLabel "Software Specification"@en .

<spec/ndvi-daily-spec> a :DataSpecification ;
    rdfs:label "NDVI Daily Specification"@en ;
    :hasObservableProperty agrovoc:c_ce585e0d ;  # NDVI
    :hasFeatureOfInterest agrovoc:c_12926 .      # Olives

<metric/olive-record-count> a :Metric ;
    :metricName "recordCount" ;
    :metricValue "365000"^^xsd:integer ;
    :hasMetricStandard <http://qudt.org/vocab/unit/NUM> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <dataset/olive-grove-monitoring> .

<metric/olive-completeness> a :Metric ;
    :metricType :Completeness ;
    :metricName "completeness" ;
    :metricValue "0.97"^^xsd:decimal ;
    :hasMetricStandard <http://qudt.org/vocab/unit/PERCENT> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <dataset/olive-grove-monitoring> .

<metric/olive-ndvi-avg> a :Metric ;
    :metricName "average_ndvi" ;
    :measuresProperty agrovoc:c_ce585e0d ;
    :metricValue "0.65"^^xsd:decimal ;
    :hasMetricStandard <http://qudt.org/vocab/unit/UNITLESS> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <dataset/olive-grove-monitoring> .

<quality/olive-dataset-assessment> a dqv:QualityMetadata ;
    dqv:hasQualityMeasurement <metric/olive-record-count> ,
                               <metric/olive-completeness> ,
                               <metric/olive-ndvi-avg> .


# ─────────────────────────────────────────────────────────────
#  6. ODRL POLICY — Usage conditions (CRED model)
# ─────────────────────────────────────────────────────────────

<policy/olive-data-offer> a odrl:Offer ;
    odrl:target <dataset/olive-grove-monitoring> ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:assigner <agent/junta-andalucia> ;
        odrl:constraint [
            odrl:leftOperand odrl:purpose ;
            odrl:operator odrl:eq ;
            odrl:rightOperand "research"
        ]
    ] ;
    odrl:prohibition [
        odrl:action odrl:distribute ;
        odrl:assigner <agent/junta-andalucia>
    ] .


# ─────────────────────────────────────────────────────────────
#  7. DATA SERVICE — API endpoint (DCAT-AP 3.0)
# ─────────────────────────────────────────────────────────────

<service/crop-forecast-api> a dcat:DataService ;
    dct:title "Servicio de Predicción de Cosecha"@es ,
              "Crop Forecast Service"@en ;
    dct:description "API REST de predicción de cosecha de olivar basada en machine learning"@es ;
    dcat:endpointURL <https://api.agrispace.es/v1/forecast> ;
    dct:publisher <agent/khaos-research> ;
    dcat:servesDataset <dataset/olive-grove-monitoring> ;
    dcatap:applicableLegislation <https://www.boe.es/eli/es/rd/2023/12/19/1089> .


# ─────────────────────────────────────────────────────────────
#  8. VOCABULARY as DATASET — Library model (CRED Ilustración 17)
# ─────────────────────────────────────────────────────────────

<dataset/agoraowl-catalog-entry> a dcat:Dataset ;
    dct:identifier "agoraowl-ontology" ;
    dct:title "Ontología AgoraOWL"@es ;
    dct:description "Ontología para la anotación semántica de activos en espacios de datos"@es ;
    dct:modified "2026-03-12"^^xsd:date ;
    dct:publisher <agent/khaos-research> ;
    dct:type <http://publications.europa.eu/resource/authority/dataset-type/ONTOLOGY> ;
    owl:versionInfo "1.0.0" ;
    dcat:distribution <distribution/agoraowl-ttl> ;
    dcat:theme theme:TECH ;
    dct:accessRights <https://creativecommons.org/licenses/by/4.0/> .

<distribution/agoraowl-ttl> a dcat:Distribution ;
    dct:description "Serialización Turtle de la ontología AgoraOWL"@es ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/RDF_TURTLE> ;
    dct:rights <https://creativecommons.org/licenses/by/4.0/> ;
    dcat:accessURL <https://github.com/KhaosResearch/AgoraOWL/raw/refs/heads/main/src/1.0.0/AgoraOWL.ttl> ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/turtle> ;
    # Technical file: include a mapping for its semantic nature
    :hasFieldMapping [
        a :FieldMapping ;
        :mapsToSpecification <spec/ontology-schema-spec> ;
        :mapsField "RDF_CONTENT" ;
        :hasDataType xsd:string 
    ] .


# ─────────────────────────────────────────────────────────────
#  9. ACCESS RIGHTS & LICENSE — Supporting instances
# ─────────────────────────────────────────────────────────────

<http://publications.europa.eu/resource/authority/access-right/PUBLIC> a dct:RightsStatement ;
    rdfs:label "Public"@en , "Público"@es .

<https://creativecommons.org/licenses/by/4.0/> a dct:LicenseDocument ;
    skos:inScheme <http://publications.europa.eu/resource/authority/licence> ;
    rdfs:label "Creative Commons Attribution 4.0 International"@en .

<https://datos.gob.es/catalogo/derechos-de-access> a dct:RightsStatement ;
    rdfs:label "Derechos relativos a la reutilización del Catálogo de Datos Abiertos"@es .


# ─────────────────────────────────────────────────────────────
#  10. STUB DEFINITIONS for SHACL Validation
# ─────────────────────────────────────────────────────────────

agrovoc:c_ce585e0d a skos:Concept ;
    skos:prefLabel "NDVI"@en .

agrovoc:c_12926 a skos:Concept ;
    skos:prefLabel "Olive"@en , "Olivo"@es .

<http://www.opengis.net/def/crs/EPSG/0/4326> a skos:Concept ;
    skos:prefLabel "WGS 84"@en .
