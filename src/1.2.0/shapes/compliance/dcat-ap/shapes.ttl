        sh:property     [ sh:nodeKind  sh:IRI;
                          sh:path      dcatap:applicableLegislation;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:nodeKind  sh:BlankNodeOrIRI;
                          sh:path      dct:license;
                          sh:severity  sh:Violation
                        ];
        sh:targetClass  dcat:Catalog .

:CatalogRecord_Shape  rdf:type  sh:NodeShape;
        rdfs:label      "Catalog Record"@en;
        sh:property     [ sh:path      dct:language;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:nodeKind  sh:Literal;
                          sh:path      dct:description;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:minCount  1;
                          sh:node      :DcatResource_Shape;
                          sh:path      foaf:primaryTopic;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:nodeKind  sh:Literal;
                          sh:path      dct:title;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:node      :DateOrDateTimeDataType_Shape;
                          sh:path      dct:issued;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:minCount  1;
                          sh:path      dct:modified;
                          sh:severity  sh:Violation;
                          sh:shape     :DateOrDateTimeDataType_Shape
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:path      dct:source;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:path      dct:conformsTo;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:path      adms:status;
                          sh:severity  sh:Violation
                        ];
        sh:targetClass  dcat:CatalogRecord .

:Agent_Shape  rdf:type  sh:NodeShape;
        rdfs:label      "Agent"@en;
        sh:property     [ sh:maxCount  1;
                          sh:path      dct:type;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:minCount  1;
                          sh:nodeKind  sh:Literal;
                          sh:path      foaf:name;
                          sh:severity  sh:Violation
                        ];
        sh:targetClass  foaf:Agent .

<https://semiceu.github.io/DCAT-AP/releases/3.0.0/html/shacl/shapes.ttl>
