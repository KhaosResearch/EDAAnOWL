                          sh:path      spdx:checksumValue;
                          sh:severity  sh:Violation
                        ];
        sh:property     [ sh:maxCount  1;
                          sh:minCount  1;
                          sh:path      spdx:algorithm;
                          sh:severity  sh:Violation
                        ];
        sh:targetClass  spdx:Checksum .

