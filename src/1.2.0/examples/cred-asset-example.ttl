    odrl:hasPolicy <https://w3id.org/EDAAnOWL/examples/cred/policy/olive-data-offer> .

<https://w3id.org/EDAAnOWL/examples/cred/distribution/olive-csv> a :DataRepresentation , dcat:Distribution ;
    dct:title "Distribución CSV de datos de olivar"@es ,
              "Olive grove CSV distribution"@en ;
    dct:description "Archivo CSV con datos tabulares de monitorización de olivar"@es ,
                    "CSV file with tabular olive grove monitoring data"@en ;
    dcat:accessURL <https://datos.juntadeandalucia.es/api/v1/olivar/download> ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/csv> ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/CSV> ;
    dct:license <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0> ;
    dcatap:availability <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE> ;
    dcatap:applicableLegislation <https://www.boe.es/eli/es/rd/2023/12/19/1089> ;
    dct:rights <https://datos.gob.es/catalogo/derechos-de-access> ;
    dcat:byteSize "15728640"^^xsd:nonNegativeInteger ;
    dct:issued "2025-06-15"^^xsd:date ;
    dct:modified "2026-03-01"^^xsd:date ;
    adms:status <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED> ;
    dcat:temporalResolution "P1D"^^xsd:duration ;
    dcat:spatialResolutionInMeters "10.0"^^xsd:decimal ;
    :hasCRS <http://www.opengis.net/def/crs/EPSG/0/4326> ;
    :hasFieldMapping [
        a :FieldMapping ;
        :mapsToSpecification <https://w3id.org/EDAAnOWL/examples/cred/spec/ndvi-daily-spec> ;
        :mapsField "ndvi_daily" ;
        :hasUnit qudt:UNITLESS ;
        :hasDataType xsd:float ;
        :hasObservationMetric :DailyAverage ;
        :hasMetric <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-record-count> ,
                    <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-completeness> ,
                    <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-ndvi-avg>
    ] .

<https://w3id.org/EDAAnOWL/examples/cred/spec/ndvi-daily-spec> a :DataSpecification ;
    rdfs:label "NDVI Daily Specification"@en , "Especificación diaria de NDVI"@es ;
    :hasObservableProperty agrovoc:c_ce585e0d ;
    :hasFeatureOfInterest agrovoc:c_12926 .

<https://w3id.org/EDAAnOWL/examples/cred/metric/olive-record-count> a :Metric ;
    :metricName "recordCount" ;
    :metricValue "365000"^^xsd:integer ;
    :hasMetricStandard <http://qudt.org/vocab/unit/NUM> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <https://w3id.org/EDAAnOWL/examples/cred/dataset/olive-grove-monitoring> .

<https://w3id.org/EDAAnOWL/examples/cred/metric/olive-completeness> a :Metric ;
    :metricType :Completeness ;
    :metricName "completeness" ;
    :metricValue "0.97"^^xsd:decimal ;
    :hasMetricStandard <http://qudt.org/vocab/unit/PERCENT> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <https://w3id.org/EDAAnOWL/examples/cred/dataset/olive-grove-monitoring> .

:Completeness a :MetricType ; skos:prefLabel "Completeness"@en .

<https://w3id.org/EDAAnOWL/examples/cred/metric/olive-ndvi-avg> a :Metric ;
    :metricName "average_ndvi" ;
    :measuresProperty agrovoc:c_ce585e0d ;
    :metricValue "0.65"^^xsd:decimal ;
    :hasMetricStandard <http://qudt.org/vocab/unit/UNITLESS> ;
    :computedAt "2026-03-01T10:00:00"^^xsd:dateTime ;
    dqv:computedOn <https://w3id.org/EDAAnOWL/examples/cred/dataset/olive-grove-monitoring> .

<https://w3id.org/EDAAnOWL/examples/cred/quality/olive-dataset-assessment> a dqv:QualityMetadata ;
    dqv:hasQualityMeasurement <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-record-count> ,
                               <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-completeness> ,
                               <https://w3id.org/EDAAnOWL/examples/cred/metric/olive-ndvi-avg> .

<https://w3id.org/EDAAnOWL/examples/cred/policy/olive-data-offer> a odrl:Offer ;
    odrl:target <https://w3id.org/EDAAnOWL/examples/cred/dataset/olive-grove-monitoring> ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:assigner <http://datos.gob.es/recurso/sector-publico/org/Organismo/U01100001> ;
