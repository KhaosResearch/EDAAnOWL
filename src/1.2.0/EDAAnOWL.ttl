###  https://github.com/MartinM10
<https://github.com/MartinM10> rdf:type owl:NamedIndividual ,
                                        foaf:Agent ;
                               foaf:name "Martin Jeronimo Salvachua"@en .


###  https://khaos.uma.es/
<https://khaos.uma.es/> rdf:type owl:NamedIndividual ,
                                 foaf:Agent ;
                        foaf:name "Khaos Research Group"@en .


###  https://w3id.org/EDAAnOWL/
<https://w3id.org/EDAAnOWL/> rdf:type owl:NamedIndividual ;
                             dct:creator <https://github.com/MartinM10> ,
                                         <https://khaos.uma.es/> ,
                                         <https://www.linkedin.com/in/martin-jeronimo-salvachua/> ;
                             dct:language <http://publications.europa.eu/resource/authority/language/ENG> ,
                                          <http://publications.europa.eu/resource/authority/language/SPA> ;
                             dct:license <https://creativecommons.org/licenses/by/4.0/> ;
                             dct:publisher <https://khaos.uma.es/> ;
                             dcat:theme <http://datos.gob.es/kos/sector-publico/sector/ciencia-tecnologia> ,
                                        theme:TECH ;
                             dct:description "EDAAnOWL aims to achieve sectoral semantic interoperability within data spaces by decoupling physical data distributions from their semantic specifications. Version 1.2.0 ensures full alignment with DCAT-AP-ES 1.0.0 and DCAT 3.0, and introduces symmetric app profiling (Input/Output Profiles) for formal technical matchmaking. For example, a DataApp requiring 'Soil Moisture' in percentage can automatically discover and consume a Dataset whose distribution (CSV/Parquet) is semantically mapped to that specification through FieldMappings."@en ,
                                             "El objetivo principal de EDAAnOWL es conseguir la interoperabilidad semántica sectorial en los espacios de datos, desacoplando las distribuciones físicas de los activos de sus especificaciones semánticas. La versión 1.2.0 asegura el alineamiento total con DCAT-AP-ES 1.0.0 y DCAT 3.0, e introduce el perfilado simétrico de aplicaciones (Input/Output Profiles) para un emparejamiento técnico formal. Por ejemplo, una aplicación que requiera 'Humedad del Suelo' en porcentaje puede descubrir y consumir automáticamente un Dataset cuya distribución (CSV/Parquet) esté mapeada semánticamente a dicha especificación mediante FieldMappings."@es ;
                             dct:modified "2026-03-26"^^xsd:date ;
                             dct:title "EDAAnOWL Ontology"@en ,
                                       "Ontología EDAAnOWL"@es .


###  https://w3id.org/EDAAnOWL/Accuracy
:Accuracy rdf:type owl:NamedIndividual ,
