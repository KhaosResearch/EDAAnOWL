@prefix dash: <http://datashapes.org/dash#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix agoraowl: <https://w3id.org/AgoraOWL/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

agoraowl:CatalogShape
    a sh:NodeShape ;
    sh:targetClass dcat:Catalog ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A Catalog must have at least one title (DCAT-AP 3.0 mandatory)."@en ;
    ] ;
    sh:property [
        sh:path dct:description ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
    ] ;
    sh:property [
        sh:path dct:publisher ;
        sh:minCount 1 ;
        sh:node agoraowl:AgentShape ;
    ] .

agoraowl:DatasetShape
    a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path dcat:distribution ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A Dataset should have at least one distribution for technical access."@en ;
    ] .

agoraowl:DistributionShape
    a sh:NodeShape ;
    sh:targetClass dcat:Distribution ;
    sh:property [
        sh:path dcat:accessURL ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Violation ;
    ] ;
    sh:property [
        sh:path dcat:mediaType ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
    ] .

agoraowl:DataServiceShape
    a sh:NodeShape ;
    sh:targetClass dcat:DataService ;
    sh:property [
        sh:path dcat:endpointURL ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
    ] .

agoraowl:AgentShape
    a sh:NodeShape ;
    sh:targetClass foaf:Agent ;
    sh:property [
        sh:path foaf:name ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
    ] .

agoraowl:OfferShape
    a sh:NodeShape ;
    sh:targetClass odrl:Offer ;
    sh:property [
        sh:path [ sh:alternativePath (odrl:permission odrl:prohibition odrl:obligation) ] ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "An ODRL Offer must have at least one Rule (Permission, Prohibition or Obligation)."@en ;
    ] .
