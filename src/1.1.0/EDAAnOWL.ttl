#################################################################
#    Standard Individuals (Controlled Vocabularies)
#################################################################

### Constraint Operators
:GreaterOrEqual rdf:type :ConstraintOperator ;
                skos:prefLabel "Greater or Equal"@en , "Mayor o Igual"@es .

:LessOrEqual rdf:type :ConstraintOperator ;
             skos:prefLabel "Less or Equal"@en , "Menor o Igual"@es .

:GreaterThan rdf:type :ConstraintOperator ;
             skos:prefLabel "Greater Than"@en , "Mayor que"@es .

:LessThan rdf:type :ConstraintOperator ;
          skos:prefLabel "Less Than"@en , "Menor que"@es .

:Equal rdf:type :ConstraintOperator ;
       skos:prefLabel "Equal"@en , "Igual"@es .

### Standard Metric Types (Instances of MetricType)
:Accuracy rdf:type :MetricType ;
          skos:prefLabel "Accuracy"@en , "Exactitud"@es .

:Completeness rdf:type :MetricType ;
              skos:prefLabel "Completeness"@en , "Completitud"@es .

:Uniqueness rdf:type :MetricType ;
            skos:prefLabel "Uniqueness"@en , "Unicidad"@es .

:Timeliness rdf:type :MetricType ;
            skos:prefLabel "Timeliness"@en , "Puntualidad"@es .


