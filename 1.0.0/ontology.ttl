#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/r5r/LegalResource
<http://data.europa.eu/r5r/LegalResource> rdf:type owl:Class ;
                                          rdfs:comment "A legal resource (legislation, directive, regulation) that relates to a dataset or service (DCAT-AP 3.0)."@en ,
                                                       "Un recurso legal (legislación, directiva, reglamento) relacionado con un conjunto de datos o servicio (DCAT-AP 3.0)."@es ;
                                          rdfs:label "Legal Resource"@en ,
                                                     "Recurso Legal"@es .


###  http://org.semanticweb.owlapi/error#Error1
<http://org.semanticweb.owlapi/error#Error1> rdf:type owl:Class .


###  http://purl.org/dc/terms/Frequency
<http://purl.org/dc/terms/Frequency> rdf:type owl:Class ;
                                     rdfs:comment "A rate at which something recurs. Used for dct:accrualPeriodicity (DCAT-AP 3.0)."@en ,
                                                  "Una tasa a la que algo se repite. Usado para dct:accrualPeriodicity (DCAT-AP 3.0)."@es ;
                                     rdfs:label "Frecuencia"@es ,
                                                "Frequency"@en .


###  http://purl.org/dc/terms/LicenseDocument
<http://purl.org/dc/terms/LicenseDocument> rdf:type owl:Class ;
                                           rdfs:subClassOf <http://purl.org/dc/terms/RightsStatement> ;
                                           rdfs:comment "A legal document giving official permission to do something with a resource (DCAT-AP 3.0)."@en ,
                                                        "Un documento legal que otorga permiso oficial para hacer algo con un recurso (DCAT-AP 3.0)."@es ;
                                           rdfs:label "Documento de Licencia"@es ,
                                                      "License Document"@en .


###  http://purl.org/dc/terms/LinguisticSystem
<http://purl.org/dc/terms/LinguisticSystem> rdf:type owl:Class ;
                                            rdfs:comment "A system of signs, symbols, sounds, gestures, or rules used in communication, e.g., a language (DCAT-AP 3.0)."@en ,
                                                         "Un sistema de signos, símbolos, sonidos, gestos o reglas utilizado en la comunicación, p. ej., un idioma (DCAT-AP 3.0)."@es ;
                                            rdfs:label "Linguistic System"@en ,
                                                       "Sistema Lingüístico"@es .


###  http://purl.org/dc/terms/Location
<http://purl.org/dc/terms/Location> rdf:type owl:Class ;
                                    rdfs:comment "A spatial region or named place. Used for dct:spatial coverage of datasets (DCAT-AP 3.0)."@en ,
                                                 "Una región espacial o lugar con nombre. Usado para la cobertura dct:spatial de datasets (DCAT-AP 3.0)."@es ;
                                    rdfs:label "Location"@en ,
                                               "Ubicación"@es .


###  http://purl.org/dc/terms/MediaTypeOrExtent
<http://purl.org/dc/terms/MediaTypeOrExtent> rdf:type owl:Class ;
                                             rdfs:comment "A media type or extent. Used for dct:format on distributions (DCAT-AP 3.0)."@en ,
                                                          "Un tipo de medio o extensión. Usado para dct:format en distribuciones (DCAT-AP 3.0)."@es ;
                                             rdfs:label "Media Type or Extent"@en ,
                                                        "Tipo de Medio o Extensión"@es .


###  http://purl.org/dc/terms/RightsStatement
<http://purl.org/dc/terms/RightsStatement> rdf:type owl:Class ;
                                           rdfs:comment "A statement about the intellectual property rights (IPR) held in or over a resource (DCAT-AP 3.0)."@en ,
                                                        "Una declaración sobre los derechos de propiedad intelectual (DPI) sobre un recurso (DCAT-AP 3.0)."@es ;
                                           rdfs:label "Declaración de Derechos"@es ,
                                                      "Rights Statement"@en .


###  http://purl.org/dc/terms/Standard
<http://purl.org/dc/terms/Standard> rdf:type owl:Class .


###  http://qudt.org/vocab/unit/Unit
<http://qudt.org/vocab/unit/Unit> rdf:type owl:Class .


###  http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter
<http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter> rdf:type owl:Class .


###  http://www.opmw.org/ontology/WorkflowTemplate
<http://www.opmw.org/ontology/WorkflowTemplate> rdf:type owl:Class .


###  http://www.w3.org/2000/01/rdf-schema#Resource
rdfs:Resource rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  http://www.w3.org/2006/time#DurationDescription
<http://www.w3.org/2006/time#DurationDescription> rdf:type owl:Class ;
                                                  rdfs:comment "A description of the extent of a time duration using calendar/clock terms (OWL-Time)."@en ,
                                                               "Una descripción de la extensión de una duración temporal usando términos de calendario/reloj (OWL-Time)."@es ;
                                                  rdfs:label "Descripción de Duración"@es ,
                                                             "Duration Description"@en .


###  http://www.w3.org/2006/time#Interval
<http://www.w3.org/2006/time#Interval> rdf:type owl:Class .


###  http://www.w3.org/2006/vcard/ns#Kind
<http://www.w3.org/2006/vcard/ns#Kind> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#Catalog
<http://www.w3.org/ns/dcat#Catalog> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://www.w3.org/ns/dcat#Dataset> ;
                                    rdfs:comment "A curated collection of metadata about datasets and data services (DCAT-AP 3.0). In the CRED model, a Catalog aggregates all semantic resources of a data space."@en ,
                                                 "Una colección curada de metadatos sobre conjuntos de datos y servicios de datos (DCAT-AP 3.0). En el modelo CRED, un Catálogo agrega todos los recursos semánticos de un espacio de datos."@es ;
                                    rdfs:label "Catalog"@en ,
                                               "Catálogo"@es .


###  http://www.w3.org/ns/dcat#DataService
<http://www.w3.org/ns/dcat#DataService> rdf:type owl:Class ;
                                        rdfs:subClassOf <http://www.w3.org/ns/dcat#Resource> ;
                                        rdfs:comment "A collection of operations accessible through an interface (API) that provides access to one or more datasets or data processing functions (DCAT-AP 3.0)."@en ,
                                                     "Una colección de operaciones accesibles a través de una interfaz (API) que proporciona acceso a uno o más conjuntos de datos o funciones de procesamiento de datos (DCAT-AP 3.0)."@es ;
                                        rdfs:label "Data Service"@en ,
                                                   "Servicio de Datos"@es .


###  http://www.w3.org/ns/dcat#Dataset
<http://www.w3.org/ns/dcat#Dataset> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://www.w3.org/ns/dcat#Resource> .


###  http://www.w3.org/ns/dcat#Distribution
<http://www.w3.org/ns/dcat#Distribution> rdf:type owl:Class ;
                                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                           owl:onProperty :declaresDataClass ;
                                                           owl:allValuesFrom <https://w3id.org/BIGOWLData/Data>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasMetric ;
                                                           owl:allValuesFrom :Metric
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasFieldMapping ;
                                                           owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://www.w3.org/ns/dcat#spatialResolutionInMeters> ;
                                                           owl:allValuesFrom xsd:decimal
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://www.w3.org/ns/dcat#temporalResolution> ;
                                                           owl:allValuesFrom xsd:duration
                                                         ] .


###  http://www.w3.org/ns/dcat#Resource
<http://www.w3.org/ns/dcat#Resource> rdf:type owl:Class ;
                                     rdfs:comment "Recurso publicado o curado por un solo agente (DCAT 3). En DCAT-AP, esta es la clase base abstracta para Dataset y DataService."@es ,
                                                  "Resource published or curated by a single agent (DCAT 3). In DCAT-AP, this is the abstract base class for Dataset and DataService."@en ;
                                     rdfs:label "Recurso"@es ,
                                                "Resource"@en .


###  http://www.w3.org/ns/dqv#Metric
<http://www.w3.org/ns/dqv#Metric> rdf:type owl:Class .


###  http://www.w3.org/ns/dqv#QualityMeasurement
<http://www.w3.org/ns/dqv#QualityMeasurement> rdf:type owl:Class .


###  http://www.w3.org/ns/dqv#QualityMetadata
<http://www.w3.org/ns/dqv#QualityMetadata> rdf:type owl:Class .


###  http://www.w3.org/ns/dqv#QualityMetric
<http://www.w3.org/ns/dqv#QualityMetric> rdf:type owl:Class .


###  http://www.w3.org/ns/locn#Geometry
<http://www.w3.org/ns/locn#Geometry> rdf:type owl:Class .


###  http://www.w3.org/ns/odrl/2/Asset
<http://www.w3.org/ns/odrl/2/Asset> rdf:type owl:Class ;
                                    rdfs:comment "An abstract concept of content that can be subject to an ODRL Policy (ODRL 2.2). In DCAT, Catalog, Dataset and Distribution are assets."@en ,
                                                 "Un concepto abstracto de contenido que puede estar sujeto a una Política ODRL (ODRL 2.2). En DCAT, Catalog, Dataset y Distribution son activos."@es ;
                                    rdfs:label "Activo"@es ,
                                               "Asset"@en .


###  http://www.w3.org/ns/odrl/2/Constraint
<http://www.w3.org/ns/odrl/2/Constraint> rdf:type owl:Class ;
                                         rdfs:comment "A Boolean expression that refines the semantics of an ODRL Rule (ODRL 2.2)."@en ,
                                                      "Una expresión booleana que refina la semántica de una Regla ODRL (ODRL 2.2)."@es ;
                                         rdfs:label "Constraint"@en ,
                                                    "Restricción"@es .


###  http://www.w3.org/ns/odrl/2/Offer
<http://www.w3.org/ns/odrl/2/Offer> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Policy> ;
                                    rdfs:comment "A Policy that proposes terms of use for an Asset (ODRL 2.2). In the CRED model, used to attach usage conditions to Datasets and Distributions."@en ,
                                                 "Una Política que propone términos de uso para un Activo (ODRL 2.2). En el modelo CRED, se usa para adjuntar condiciones de uso a Datasets y Distribuciones."@es ;
                                    rdfs:label "Oferta"@es ,
                                               "Offer"@en .


###  http://www.w3.org/ns/odrl/2/Policy
<http://www.w3.org/ns/odrl/2/Policy> rdf:type owl:Class ;
                                     rdfs:comment "A non-empty group of Permissions and/or Prohibitions and/or Obligations (ODRL 2.2). Base class for Offer, Agreement, etc."@en ,
                                                  "Un grupo no vacío de Permisos y/o Prohibiciones y/o Obligaciones (ODRL 2.2). Clase base para Offer, Agreement, etc."@es ;
                                     rdfs:label "Policy"@en ,
                                                "Política"@es .


###  http://www.w3.org/ns/odrl/2/Rule
<http://www.w3.org/ns/odrl/2/Rule> rdf:type owl:Class ;
                                   rdfs:comment "An abstract concept for a Permission, Prohibition, or Obligation (ODRL 2.2)."@en ,
                                                "Un concepto abstracto para un Permiso, Prohibición u Obligación (ODRL 2.2)."@es ;
                                   rdfs:label "Regla"@es ,
                                              "Rule"@en .


###  http://www.w3.org/ns/org#Organization
<http://www.w3.org/ns/org#Organization> rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/FeatureOfInterest
<http://www.w3.org/ns/sosa/FeatureOfInterest> rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/ObservableProperty
<http://www.w3.org/ns/sosa/ObservableProperty> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Agent
<http://xmlns.com/foaf/0.1/Agent> rdf:type owl:Class ;
                                  rdfs:comment "An agent (person, organization, or software) that is associated with a resource as publisher, creator, or contact (FOAF / DCAT-AP 3.0)."@en ,
                                               "Un agente (persona, organización, o software) asociado con un recurso como editor, creador o contacto (FOAF / DCAT-AP 3.0)."@es ;
                                  rdfs:label "Agent"@en ,
                                             "Agente"@es .


###  http://xmlns.com/foaf/0.1/Document
<http://xmlns.com/foaf/0.1/Document> rdf:type owl:Class .


###  https://w3id.org/BIGOWLData/Column
<https://w3id.org/BIGOWLData/Column> rdf:type owl:Class .


###  https://w3id.org/BIGOWLData/Data
<https://w3id.org/BIGOWLData/Data> rdf:type owl:Class .


###  https://w3id.org/BIGOWLWorkflows/Component
<https://w3id.org/BIGOWLWorkflows/Component> rdf:type owl:Class .


###  https://w3id.org/EDAAnOWL/Accuracy
:Accuracy rdf:type owl:Class ;
          rdfs:subClassOf :QualityMetric .


###  https://w3id.org/EDAAnOWL/AnalyzerApp
:AnalyzerApp rdf:type owl:Class ;
             rdfs:subClassOf :DataApp ,
                             <https://w3id.org/idsa/core/SmartDataApp> ;
             rdfs:comment "A smart data app for descriptive/diagnostic analysis (profiling, summarization, outlier detection)."@en ,
                          "Una aplicación de datos inteligente para análisis descriptivo/diagnóstico (perfilado, resumen, detección de valores atípicos)."@es ;
             rdfs:label "Analyzer App"@en ,
                        "Aplicación Analizadora"@es .


###  https://w3id.org/EDAAnOWL/CertificationReport
:CertificationReport rdf:type owl:Class ;
                     rdfs:comment "A report attesting that a resource or profile complies with a specific standard or regulation (e.g., Gaia-X)."@en ,
                                  "Un informe que atestigua que un recurso o perfil cumple con un estándar o regulación específica (p. ej., Gaia-X)."@es ;
                     rdfs:label "Certification Report"@en ,
                                "Informe de Certificación"@es .


###  https://w3id.org/EDAAnOWL/Completeness
:Completeness rdf:type owl:Class ;
              rdfs:subClassOf :QualityMetric .


###  https://w3id.org/EDAAnOWL/ConstraintOperator
:ConstraintOperator rdf:type owl:Class .


###  https://w3id.org/EDAAnOWL/DataApp
:DataApp rdf:type owl:Class ;
         rdfs:subClassOf <https://w3id.org/idsa/core/DataApp> ;
         rdfs:comment "Especialización de ids:DataApp para EDAAnOWL. Permite la declaración de requisitos de entrada (hasInputProfile), perfiles de salida (producesProfile) y métricas de rendimiento (hasPerformanceMetric)."@es ,
                      "Specialization of ids:DataApp for EDAAnOWL. Enables declaration of input requirements (hasInputProfile), output profiles (producesProfile), and performance metrics (hasPerformanceMetric)."@en ;
         rdfs:label "Aplicación de Datos"@es ,
                    "Data App"@en .


###  https://w3id.org/EDAAnOWL/DataAsset
:DataAsset rdf:type owl:Class ;
           rdfs:subClassOf <https://w3id.org/idsa/core/DataResource> ;
           rdfs:comment "Especializa ids:DataResource para añadir la capa semántica específica de EDAAnOWL. Los perfiles se vinculan mediante ids:representation → dcat:Distribution → hasFieldMapping → mapsToSpecification. Puede vincularse a la DataApp que lo generó usando prov:wasGeneratedBy."@es ,
                        "Specialises ids:DataResource to add the EDAAnOWL domain-specific semantic layer. Profiles are linked via ids:representation → dcat:Distribution → hasFieldMapping → mapsToSpecification. Can be linked to the DataApp that generated it using prov:wasGeneratedBy."@en ;
           rdfs:label "Activo de Datos"@es ,
                      "Data Asset"@en .


###  https://w3id.org/EDAAnOWL/DataConstraint
:DataConstraint rdf:type owl:Class ;
                rdfs:subClassOf <http://org.semanticweb.owlapi/error#Error1> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :constraintMetricType ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :MetricType
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :constraintValue ;
                                  owl:cardinality "1"^^xsd:nonNegativeInteger
                                ] ;
                rdfs:comment "Define una restricción de umbral de calidad (p. ej., completitud >= 0.9) para ser utilizada en el matchmaking."@es ,
                             "Defines a quality threshold constraint (e.g., completeness >= 0.9) to be used in matchmaking."@en ;
                rdfs:label "Data Constraint"@en ,
                           "Restricción de Calidad"@es .


###  https://w3id.org/EDAAnOWL/DataProfile
:DataProfile rdf:type owl:Class ;
             rdfs:comment "A grouping of multiple DataSpecifications. Useful to represent the set of variables that a dataset offers or an application requires."@en ,
                          "Una agrupación de múltiples DataSpecifications. Útil para representar el conjunto de variables que ofrece un dataset o requiere una aplicación."@es ;
             rdfs:label "Data Profile"@en ,
                        "Perfil de Datos"@es .


###  https://w3id.org/EDAAnOWL/DataRepresentation
:DataRepresentation rdf:type owl:Class ;
                    rdfs:subClassOf <https://w3id.org/idsa/core/DataRepresentation> ;
                    rdfs:comment """Physical representation of (structured) data. Specializes ids:DataRepresentation 
    from the IDSA taxonomy to add EDAAnOWL-specific semantics for data profiles and quality metrics.
    
    Alignment: ids:DataRepresentation extends dcat:Distribution (W3C DCAT 2+), 
    ensuring interoperability with DCAT-based catalogs while maintaining IDSA compliance."""@en ,
                                 """Representación física de datos (estructurados). Especializa ids:DataRepresentation 
    de la taxonomía IDSA para añadir semántica específica de EDAAnOWL para perfiles de datos y métricas de calidad.
    
    Alineación: ids:DataRepresentation extiende dcat:Distribution (W3C DCAT 2+), 
    asegurando interoperabilidad con catálogos basados en DCAT mientras mantiene conformidad IDSA."""@es ;
                    rdfs:label "Data Representation"@en ,
                               "Representación de Datos"@es .


###  https://w3id.org/EDAAnOWL/DataSpecification
:DataSpecification rdf:type owl:Class ;
                   rdfs:subClassOf <http://purl.org/dc/terms/Standard> ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasFeatureOfInterest ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :FeatureOfInterest
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasObservableProperty ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :ObservableProperty
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasDataType ;
                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass rdfs:Resource
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasMetricStandard ;
                                     owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                   ] ;
                   rdfs:comment """Atomic and reusable semantic unit that describes WHAT is being observed (Feature of Interest), WHICH property is measured (Observable Property), and HOW it is represented (Data Type, Metric Standard).
    
DataSpecifications are now schema-agnostic. They no longer contain mapping information (mapsField) or technical distribution details (resolutions, CRS), which have been moved to Distribution or FieldMapping."""@en ,
                                """Unidad semántica atómica y reutilizable que describe QUÉ se está observando (Feature of Interest), QUÉ propiedad se mide (Observable Property) y CÓMO se representa (Tipo de Dato, Estándar de Métrica).
    
Los DataSpecifications son ahora independientes del esquema. Ya no contienen información de mapeo (mapsField) ni detalles técnicos de la distribución (resoluciones, CRS), los cuales se han movido a Distribution o FieldMapping."""@es ;
                   rdfs:label "Data Specification"@en ,
                              "Perfil de Datos"@es .


###  https://w3id.org/EDAAnOWL/FeatureOfInterest
:FeatureOfInterest rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.w3.org/ns/sosa/FeatureOfInterest> ;
                   rdfs:comment "De lo que se habla o lo que se observa (el objeto real o fenómeno). Ejemplos: una naranja, una parcela, un lote de aceite. RECOMENDADO: Usar SIEX o AGROVOC para clasificar el tipo de objeto."@es ,
                                "The phenomenon or entity being observed or described (the 'thing' itself). Examples: an orange, a plot of land, a batch of oil. RECOMMENDED: Use SIEX or AGROVOC to classify the object type."@en ;
                   rdfs:label "Característica de Interés"@es ,
                              "Feature of Interest"@en .


###  https://w3id.org/EDAAnOWL/FieldMapping
:FieldMapping rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :hasMetric ;
                                owl:allValuesFrom :Metric
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :mapsToSpecification ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :DataSpecification
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :mapsField ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "La clase 'puente' que instancia un DataSpecification reutilizable para un campo específico en una distribución. Mapea el concepto semántico a un identificador físico (mapsField) y proporciona métricas de calidad específicas del campo."@es ,
                           "The 'bridge' class that instantiates a reusable DataSpecification for a specific field in a distribution. It maps the semantic concept to a physical identifier (mapsField) and provides field-specific quality metrics."@en ;
              rdfs:label "Field Mapping"@en ,
                         "Vínculo de Perfil"@es .


###  https://w3id.org/EDAAnOWL/InputProfile
:InputProfile rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :hasDataConstraint ;
                                owl:allValuesFrom :DataConstraint
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasDataSpecification ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :DataSpecification
                              ] ;
              rdfs:comment "Define un requisito estructurado para una entrada de DataApp, especificando exactamente qué DataSpecification se necesita y qué umbrales de calidad deben cumplirse."@es ,
                           "Defines a structured requirement for a DataApp input, specifying exactly which DataSpecification is needed and what quality thresholds must be met."@en ;
              rdfs:label "Input Profile"@en ,
                         "Requisito de Entrada"@es .


###  https://w3id.org/EDAAnOWL/Metric
:Metric rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/dqv#QualityMeasurement> ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :metricName ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :metricValue ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "A class representing a single, measurable characteristic (measurement) of an asset or profile. Aligned with dqv:QualityMeasurement. Use :metricType to link to the standardized metric definition (dqv:Metric)."@en ,
                     "Una clase que representa una característica única y medible (medición) de un activo o perfil. Alineada con dqv:QualityMeasurement. Use :metricType para vincular a la definición de métrica estandarizada (dqv:Metric)."@es ;
        rdfs:label "Metric (Measurement)"@en ,
                   "Métrica (Medición)"@es .


###  https://w3id.org/EDAAnOWL/MetricType
:MetricType rdf:type owl:Class ;
            rdfs:subClassOf <http://www.w3.org/ns/dqv#Metric> ;
            rdfs:comment "A controlled vocabulary term for standardized metric definitions (e.g., completeness, recordCount, cloudCoverage). Aligned with dqv:Metric. RECOMMENDED: Use external vocabularies like DDI (SummaryStatisticType), STATO (Statistical Methods Ontology), or W3C DQV for quality metrics. Use :metricType to link a measurement (:Metric) to its definition."@en ,
                         "Un término de vocabulario controlado para definiciones de métricas estandarizadas (p. ej., completitud, recuento de registros, cobertura de nubes). Alineado con dqv:Metric. RECOMENDADO: Usar vocabularios externos como DDI (SummaryStatisticType), STATO (Statistical Methods Ontology) o W3C DQV para métricas de calidad. Use :metricType para vincular una medición (:Metric) con su definición."@es ;
            rdfs:label "Definición de Métrica (Tipo)"@es ,
                       "Metric Definition (Type)"@en .


###  https://w3id.org/EDAAnOWL/ObservableProperty
:ObservableProperty rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/sosa/ObservableProperty> ;
                    rdfs:comment "La variable semántica que describe un activo de datos o que un servicio requiere/produce. RECOMENDADO: Usar AGROVOC para conceptos agrícolas o EuroSciVoc para ciencia general."@es ,
                                 "The semantic variable that a data asset describes or a service requires/produces. RECOMMENDED: Use AGROVOC for agricultural concepts or EuroSciVoc for general science."@en ;
                    rdfs:label "Observable Property"@en ,
                               "Propiedad Observable"@es .


###  https://w3id.org/EDAAnOWL/ObservationMetric
:ObservationMetric rdf:type owl:Class ;
                   rdfs:comment "Statistical or aggregation metric of the observation (e.g., DailyAverage, Maximum, Instantaneous)."@en ;
                   rdfs:label "Observation Metric"@en .


###  https://w3id.org/EDAAnOWL/OutputProfile
:OutputProfile rdf:type owl:Class ;
               rdfs:subClassOf :DataProfile ;
               rdfs:comment "Specifies the profile of output data a DataApp produces."@en ;
               rdfs:label "Output Profile"@en .


###  https://w3id.org/EDAAnOWL/PerformanceMetric
:PerformanceMetric rdf:type owl:Class ;
                   rdfs:subClassOf :Metric ;
                   rdfs:comment "A metric that describes the performance of a DataApp or service (e.g., accuracy, execution time)."@en ,
                                "Una métrica que describe el rendimiento de una DataApp o servicio (p. ej., precisión, tiempo de ejecución)."@es ;
                   rdfs:label "Métrica de Rendimiento"@es ,
                              "Performance Metric"@en .


###  https://w3id.org/EDAAnOWL/PredictionApp
:PredictionApp rdf:type owl:Class ;
               rdfs:subClassOf :DataApp ,
                               <https://w3id.org/idsa/core/SmartDataApp> ;
               rdfs:comment "A smart data app that produces predictions/inferences from input data using a model or algorithm."@en ,
                            "Una aplicación de datos inteligente que produce predicciones/inferencias a partir de datos de entrada usando un modelo o algoritmo."@es ;
               rdfs:label "Aplicación de Predicción"@es ,
                          "Prediction App"@en .


###  https://w3id.org/EDAAnOWL/QualityMetric
:QualityMetric rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/ns/dqv#QualityMetric> ,
                               :MetricType ;
               rdfs:comment "A quality metric definition describing a qualitative or quantitative aspect of data quality (e.g., completeness, uniqueness, record count). Aligned with dqv:QualityMetric. Individual measurements belong to :Metric / dqv:QualityMeasurement and should link here via :metricType."@en ,
                            "Una métrica que describe un aspecto cualitativo o cuantitativo de la calidad de datos (p. ej., completitud, unicidad, recuento de registros). Alineada con dqv:QualityMetric."@es ;
               rdfs:label "Métrica de Calidad"@es ,
                          "Quality Metric"@en .


###  https://w3id.org/EDAAnOWL/QualityReport
:QualityReport rdf:type owl:Class ;
               rdfs:comment "An external, structured quality report containing metadata about a quality assessment (e.g., a PDF report URL, a quality score)."@en ,
                            "Un informe de calidad externo y estructurado que contiene metadatos sobre una evaluación de calidad (p. ej., una URL de informe PDF, una puntuación de calidad)."@es ;
               rdfs:label "Informe de Calidad"@es ,
                          "Quality Report"@en .


###  https://w3id.org/EDAAnOWL/SpatialTemporalAsset
:SpatialTemporalAsset rdf:type owl:Class ;
                      rdfs:subClassOf :DataAsset ;
                      rdfs:comment "Subclase de DataAsset para datos con cobertura espacial y temporal, como datos de Observación de la Tierra."@es ,
                                   "Subclass of DataAsset for data with spatial and temporal coverage, such as Earth Observation data."@en ;
                      rdfs:label "Activo Espacio-Temporal"@es ,
                                 "Spatial Temporal Asset"@en .


###  https://w3id.org/EDAAnOWL/Uniqueness
:Uniqueness rdf:type owl:Class ;
            rdfs:subClassOf :QualityMetric .


###  https://w3id.org/EDAAnOWL/VerifiableDataSpecification
:VerifiableDataSpecification rdf:type owl:Class ;
                             rdfs:subClassOf :DataSpecification ;
                             rdfs:comment "A DataSpecification that is intended to be cryptographically verified. It should be linked to a Verifiable Credential using :hasCredential. This enables trusted quality assertions in data spaces by separating the profile metadata from its cryptographic proof."@en ,
                                          "Un DataSpecification destinado a ser verificado criptográficamente. Debe vincularse a una Credencial Verificable usando :hasCredential. Esto permite aserciones de calidad confiables en espacios de datos separando los metadatos del perfil de su prueba criptográfica."@es ;
                             rdfs:label "Perfil de Datos Verificable"@es ,
                                        "Verifiable Data Specification"@en .


###  https://w3id.org/EDAAnOWL/VisualizationApp
:VisualizationApp rdf:type owl:Class ;
                  rdfs:subClassOf :DataApp ,
                                  <https://w3id.org/idsa/core/SmartDataApp> ;
                  rdfs:comment "A smart data app that renders data into visual views/reports without altering underlying data."@en ,
                               "Una aplicación de datos inteligente que renderiza datos en vistas/informes visuales sin alterar los datos subyacentes."@es ;
                  rdfs:label "Aplicación de Visualización"@es ,
                             "Visualization App"@en .


###  https://w3id.org/idsa/core/AppEndpoint
<https://w3id.org/idsa/core/AppEndpoint> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/idsa/core/Endpoint> .


###  https://w3id.org/idsa/core/AppRepresentation
<https://w3id.org/idsa/core/AppRepresentation> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/idsa/core/SoftwareRepresentation> .


###  https://w3id.org/idsa/core/AppResource
<https://w3id.org/idsa/core/AppResource> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/idsa/core/Resource> .


###  https://w3id.org/idsa/core/AppRoute
<https://w3id.org/idsa/core/AppRoute> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/idsa/core/Described> .


###  https://w3id.org/idsa/core/Artifact
<https://w3id.org/idsa/core/Artifact> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Asset> ,
                                                      <https://w3id.org/idsa/core/Described> ,
                                                      <https://w3id.org/idsa/core/RepresentationInstance> .


###  https://w3id.org/idsa/core/ConnectorEndpoint
<https://w3id.org/idsa/core/ConnectorEndpoint> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/idsa/core/Endpoint> .


###  https://w3id.org/idsa/core/ContractOffer
<https://w3id.org/idsa/core/ContractOffer> rdf:type owl:Class .


###  https://w3id.org/idsa/core/DataApp
<https://w3id.org/idsa/core/DataApp> rdf:type owl:Class .


###  https://w3id.org/idsa/core/DataRepresentation
<https://w3id.org/idsa/core/DataRepresentation> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.w3.org/ns/dcat#Distribution> .


###  https://w3id.org/idsa/core/DataResource
<https://w3id.org/idsa/core/DataResource> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/idsa/core/Resource> .


###  https://w3id.org/idsa/core/Described
<https://w3id.org/idsa/core/Described> rdf:type owl:Class .


###  https://w3id.org/idsa/core/DescribedSemantically
<https://w3id.org/idsa/core/DescribedSemantically> rdf:type owl:Class .


###  https://w3id.org/idsa/core/DigitalContent
<https://w3id.org/idsa/core/DigitalContent> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://www.w3.org/ns/dcat#Dataset> ,
                                                            <https://w3id.org/idsa/core/Described> .


###  https://w3id.org/idsa/core/Endpoint
<https://w3id.org/idsa/core/Endpoint> rdf:type owl:Class .


###  https://w3id.org/idsa/core/ManagedEntity
<https://w3id.org/idsa/core/ManagedEntity> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/idsa/core/Described> .


###  https://w3id.org/idsa/core/RepresentationInstance
<https://w3id.org/idsa/core/RepresentationInstance> rdf:type owl:Class .


###  https://w3id.org/idsa/core/Resource
<https://w3id.org/idsa/core/Resource> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Asset> ,
                                                      <https://w3id.org/idsa/core/DescribedSemantically> ,
                                                      <https://w3id.org/idsa/core/DigitalContent> ,
                                                      <https://w3id.org/idsa/core/ManagedEntity> .


###  https://w3id.org/idsa/core/RouteStep
<https://w3id.org/idsa/core/RouteStep> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/idsa/core/AppRoute> .


###  https://w3id.org/idsa/core/SmartDataApp
<https://w3id.org/idsa/core/SmartDataApp> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/idsa/core/DataApp> .


###  https://w3id.org/idsa/core/SoftwareRepresentation
<https://w3id.org/idsa/core/SoftwareRepresentation> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.w3.org/ns/dcat#Distribution> .


