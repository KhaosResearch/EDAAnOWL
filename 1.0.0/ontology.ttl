###  https://w3id.org/EDAAnOWL/
<https://w3id.org/EDAAnOWL/> rdf:type owl:NamedIndividual ;
                             <http://purl.org/dc/terms/creator> <https://github.com/MartinM10> ,
                                                                <https://khaos.uma.es/> ,
                                                                <https://www.linkedin.com/in/martin-jeronimo-salvachua/> ;
                             <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                             <http://purl.org/dc/terms/description> "Ontology for data spaces that bridges the IDSA Information Model with the BIGOWL analytical family. Version 1.0.0 introduces atomic reusable DataSpecifications linked to Distributions via FieldMappings, enabling a 'Profile Library' approach where semantic logic is separated from physical schema (mapsField). It also adds advanced matchmaking with DataConstraints for DataApps."@en ,
                                                                    "Ontología para espacios de datos que conecta el Modelo de Información IDSA con la familia analítica BIGOWL. La versión 1.0.0 introduce Perfiles de Datos atómicos y reutilizables vinculados a las Distribuciones mediante FieldMappings, permitiendo un enfoque de 'Librería de Perfiles' donde la lógica semántica se separa del esquema físico (mapsField). También añade matchmaking avanzado con DataConstraints para Aplicaciones de Datos."@es ;
                             <http://purl.org/dc/terms/modified> "2026-03-12"^^xsd:date ;
                             <http://purl.org/dc/terms/title> "EDAAnOWL Ontology"@en ,
                                                              "Ontología EDAAnOWL"@es .


