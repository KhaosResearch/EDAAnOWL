     -->


    


    <!-- http://purl.org/dc/terms/alternative -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/alternative"/>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An unambiguous reference to the resource within a given context (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una referencia inequívoca al recurso dentro de un contexto dado (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="es">identificador</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/issued">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">La fecha de publicación formal del recurso (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The date of formal issuance/publication of the resource (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">date issued</rdfs:label>
        <rdfs:label xml:lang="es">fecha de publicación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/adms#versionNotes -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/adms#versionNotes">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A description of changes between this version and the previous version (ADMS).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción de los cambios entre esta versión y la versión anterior (ADMS).</rdfs:comment>
        <rdfs:label xml:lang="es">notas de versión</rdfs:label>
        <rdfs:label xml:lang="en">version notes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#byteSize -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#byteSize">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="es">El tamaño de una Distribución en bytes (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The size of a Distribution in bytes (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">byte size</rdfs:label>
        <rdfs:label xml:lang="es">tamaño en bytes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#keyword -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#keyword">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A keyword or tag describing the Dataset (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una palabra clave o etiqueta que describe el Dataset (DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">keyword</rdfs:label>
        <rdfs:label xml:lang="es">palabra clave</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#spatialResolutionInDegrees -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#spatialResolutionInDegrees">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#spatialResolutionInMeters -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#spatialResolutionInMeters">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#temporalResolution -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#temporalResolution">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dqv#value -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dqv#value"/>
    


    <!-- http://www.w3.org/ns/prov#generatedAtTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#generatedAtTime"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">El nombre de un Agente (persona u organización) (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The name of an Agent (person or organization) (FOAF / DCAT-AP 3.0).</rdfs:comment>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <rdfs:label xml:lang="es">nombre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/thumbnailUrl -->


    <owl:DatatypeProperty rdf:about="https://schema.org/thumbnailUrl">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/accessType -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/accessType">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :accessTypeConcept instead. Indicates the primary access mode for the resource (e.g., download, compute, ...).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :accessTypeConcept en su lugar. Indica el modo de acceso principal para el recurso (p. ej., descarga, cómputo, ...).</rdfs:comment>
        <rdfs:label xml:lang="en">access type (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">tipo de acceso (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/alternativeName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/alternativeName">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/alternative"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Alternative title or name for a resource.</rdfs:comment>
        <rdfs:comment xml:lang="es">Título o nombre alternativo para un recurso.</rdfs:comment>
        <rdfs:label xml:lang="en">alternate name</rdfs:label>
        <rdfs:label xml:lang="es">nombre alternativo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/anonymizationTechnique -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/anonymizationTechnique">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">La técnica utilizada para anonimizar datos personales (p. ej., &apos;k-anonymity&apos;, &apos;privacidad diferencial&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">La técnica utilizada para anonimizar los datos (por ejemplo, k-anonimato, privacidad diferencial).</rdfs:comment>
        <rdfs:comment xml:lang="en">The technique used to anonymize personal data (e.g., &apos;k-anonymity&apos;, &apos;differential privacy&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The technique used to anonymize the data (e.g., k-anonymity, differential privacy).</rdfs:comment>
        <rdfs:label xml:lang="en">anonymization technique</rdfs:label>
        <rdfs:label xml:lang="es">técnica de anonimización</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/appliesToFeature -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/appliesToFeature">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :appliesToFeatureConcept for formal schema pointers. Indicates the specific feature, column, or attribute to which a metric refers (e.g., &apos;column_name&apos;, &apos;user.address.city&apos;, &apos;$.user.address.city&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :appliesToFeatureConcept para punteros formales a esquema. Indica la característica, columna o atributo específico al que se refiere una métrica (p. ej., &apos;column_name&apos;, &apos;user.address.city&apos;, &apos;$.user.address.city&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">applies to feature (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">se aplica a característica (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/auditLogAvailable -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/auditLogAvailable">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si los registros de auditoría para el uso del recurso están disponibles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates if audit logs for the resource usage are available.</rdfs:comment>
        <rdfs:label xml:lang="en">audit log available</rdfs:label>
        <rdfs:label xml:lang="es">registro de auditoría disponible</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/certificationLevel -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/certificationLevel">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/CertificationReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El nivel de certificación alcanzado (p. ej., &apos;Gaia-X Label 1&apos;, &apos;Gold&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The level of certification achieved (e.g., &apos;Gaia-X Label 1&apos;, &apos;Gold&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">certification level</rdfs:label>
        <rdfs:label xml:lang="es">nivel de certificación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/collectionMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/collectionMethod">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El método utilizado para recolectar los datos (p. ej., &apos;sensor&apos;, &apos;encuesta&apos;, &apos;satélite&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="en">The method used to collect the data (e.g., &apos;sensor&apos;, &apos;survey&apos;, &apos;satellite&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">collection method</rdfs:label>
        <rdfs:label xml:lang="es">método de recolección</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/computedAt -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/computedAt">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#generatedAtTime"/>
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La marca de tiempo que indica cuándo se calculó o validó el valor de la métrica. Alineada con prov:generatedAtTime para interoperabilidad de procedencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">The timestamp indicating when the metric&apos;s value was computed or validated. Aligned with prov:generatedAtTime for provenance interoperability.</rdfs:comment>
        <rdfs:label xml:lang="es">calculado en</rdfs:label>
        <rdfs:label xml:lang="en">computed at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/containsPersonalData -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/containsPersonalData">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el conjunto de datos contiene datos personales (GDPR).</rdfs:comment>
        <rdfs:comment xml:lang="es">Indica si el recurso incluye información de identificación personal (PII).</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the dataset contains personal data (GDPR).</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the resource includes Personally Identifiable Information (PII).</rdfs:comment>
        <rdfs:label xml:lang="en">contains personal data</rdfs:label>
        <rdfs:label xml:lang="es">contiene datos personales</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasCRS -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/hasCRS">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/isAlive -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/isAlive">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el conjunto de datos se mantiene activamente y espera actualizaciones futuras.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates if the dataset is actively maintained and expects future updates.</rdfs:comment>
        <rdfs:label xml:lang="es">está activo</rdfs:label>
        <rdfs:label xml:lang="en">is alive</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/isStreaming -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/isStreaming">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si los datos se proporcionan en tiempo real como un flujo continuo (streaming) en lugar de un conjunto de datos estático.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the data is provided in real-time as a continuous stream instead of a static dataset.</rdfs:comment>
        <rdfs:label xml:lang="es">es flujo continuo (streaming)</rdfs:label>
        <rdfs:label xml:lang="en">is streaming</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/knownLimitations -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/knownLimitations">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Descripción legible de cualquier limitación conocida, sesgo o problema de calidad del recurso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Human-readable description of any known limitations, biases, or quality issues of the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">known limitations</rdfs:label>
        <rdfs:label xml:lang="es">limitaciones conocidas</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricName">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable name or identifier for the metric (e.g., &apos;recordCount&apos;, &apos;missing_ratio&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">Un nombre o identificador legible para la métrica (p. ej., &apos;recordCount&apos;, &apos;missing_ratio&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">metric name</rdfs:label>
        <rdfs:label xml:lang="es">nombre de métrica</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricUnit -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricUnit">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use :hasMetricUnit with semantic URIs instead. The unit of measurement for the metric value (e.g., &apos;%&apos;, &apos;kg/ha&apos;, &apos;ppm&apos;).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use :hasMetricUnit con URIs semánticas en su lugar. La unidad de medida para el valor de la métrica (p. ej., &apos;%&apos;, &apos;kg/ha&apos;, &apos;ppm&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">metric unit (deprecated)</rdfs:label>
        <rdfs:label xml:lang="es">unidad de métrica (obsoleto)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/metricValue">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dqv#value"/>
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="es">El valor de la medición de la métrica. Alineado con dqv:value para interoperabilidad DQV. El rango es rdfs:Literal para soportar múltiples tipos de datos (p. ej., xsd:boolean, xsd:integer, xsd:string, xsd:decimal).</rdfs:comment>
        <rdfs:comment xml:lang="en">The value of the metric measurement. Aligned with dqv:value for DQV interoperability. Range is rdfs:Literal to support multiple datatypes (e.g., xsd:boolean, xsd:integer, xsd:string, xsd:decimal).</rdfs:comment>
        <rdfs:label xml:lang="en">metric value</rdfs:label>
        <rdfs:label xml:lang="es">valor de métrica</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/nullPercentage -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/nullPercentage">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="es">El porcentaje de valores nulos en una columna (0.0 a 1.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The percentage of null values in a column (0.0 to 1.0).</rdfs:comment>
        <rdfs:label xml:lang="en">null percentage</rdfs:label>
        <rdfs:label xml:lang="es">porcentaje de nulos</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/paymentModelDescription -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/paymentModelDescription">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable description of the pricing or payment model (e.g., &apos;Monthly Subscription&apos;, &apos;Pay-per-use&apos;). This complements the formal ODRL policy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción legible del modelo de precios o pago (p. ej., &apos;Suscripción Mensual&apos;, &apos;Pago por uso&apos;). Esto complementa la política formal ODRL.</rdfs:comment>
        <rdfs:label xml:lang="es">descripción del modelo de pago</rdfs:label>
        <rdfs:label xml:lang="en">payment model description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileCRS -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileCRS">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">CRS de perfil</rdfs:label>
        <rdfs:label xml:lang="en">profile CRS</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileSpatialResolution -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileSpatialResolution">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Deprecated. Use dcat:spatialResolutionInMeters or dcat:spatialResolutionInDegrees.</rdfs:comment>
        <rdfs:comment xml:lang="es">Obsoleto. Use dcat:spatialResolutionInMeters o dcat:spatialResolutionInDegrees.</rdfs:comment>
        <rdfs:label xml:lang="en">profile spatial resolution</rdfs:label>
        <rdfs:label xml:lang="es">resolución espacial de perfil</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/profileTemporalResolution -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/profileTemporalResolution">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="en">Deprecated. Use dcat:temporalResolution for temporal resolution of datasets/profiles.</rdfs:comment>
        <rdfs:comment xml:lang="es">Obsoleto. Use dcat:temporalResolution para la resolución temporal de conjuntos de datos/perfiles.</rdfs:comment>
        <rdfs:label xml:lang="en">profile temporal resolution</rdfs:label>
        <rdfs:label xml:lang="es">resolución temporal de perfil</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/dcat#temporalResolution"/>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/qualityReportURI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/qualityReportURI">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/QualityReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="es">El URI del informe de calidad completo y legible (p. ej., un documento PDF o HTML).</rdfs:comment>
        <rdfs:comment xml:lang="en">The URI of the full, human-readable quality report (e.g., a PDF or HTML document).</rdfs:comment>
        <rdfs:label xml:lang="es">URI de informe de calidad</rdfs:label>
        <rdfs:label xml:lang="en">quality report URI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/qualityScore -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/qualityScore">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/QualityReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A quantitative quality score (e.g., 0-100) assigned by the external quality report.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una puntuación de calidad cuantitativa (p. ej., 0-100) asignada por el informe de calidad externo.</rdfs:comment>
        <rdfs:label xml:lang="es">puntuación de calidad</rdfs:label>
        <rdfs:label xml:lang="en">quality score</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/recommendedUse -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/recommendedUse">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Descripción legible de los casos de uso previstos o recomendados para el recurso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Human-readable description of the intended or recommended use cases for the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">recommended use</rdfs:label>
        <rdfs:label xml:lang="es">uso recomendado</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/refundPolicy -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/refundPolicy">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A text description of the refund policy applicable to the resource.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una descripción textual de la política de reembolso aplicable al recurso.</rdfs:comment>
        <rdfs:label xml:lang="es">política de reembolso</rdfs:label>
        <rdfs:label xml:lang="en">refund policy</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/reportDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/reportDate">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/CertificationReport"/>
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/QualityReport"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha en que se emitió el informe.</rdfs:comment>
        <rdfs:comment xml:lang="en">The date when the report was issued.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha del informe</rdfs:label>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/sampleValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/sampleValue">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A representative sample value for a column.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un valor de muestra representativo para una columna.</rdfs:comment>
        <rdfs:label xml:lang="en">sample value</rdfs:label>
        <rdfs:label xml:lang="es">valor de muestra</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/securityClassification -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/securityClassification">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El nivel de clasificación de seguridad del recurso (por ejemplo, Público, Confidencial).</rdfs:comment>
        <rdfs:comment xml:lang="en">The security classification level of the resource (e.g., Public, Confidential).</rdfs:comment>
        <rdfs:label xml:lang="es">clasificación de seguridad</rdfs:label>
        <rdfs:label xml:lang="en">security classification</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/spatialGranularity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/spatialGranularity">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">granularidad espacial</rdfs:label>
        <rdfs:label xml:lang="en">spatial granularity</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/EDAAnOWL/uniquenessRatio -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/EDAAnOWL/uniquenessRatio">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLData/Column"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="es">El ratio de valores únicos frente al total de filas en una columna (0.0 a 1.0).</rdfs:comment>
        <rdfs:comment xml:lang="en">The ratio of unique values to total rows in a column (0.0 to 1.0).</rdfs:comment>
        <rdfs:label xml:lang="es">ratio de unicidad</rdfs:label>
        <rdfs:label xml:lang="en">uniqueness ratio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/accessURL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/accessURL">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Endpoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/idsa/core/appDocumentation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/idsa/core/appDocumentation">
