    "@language" : "en",
    "@value" : "binds profile"
  }, {
    "@language" : "es",
    "@value" : "vincula perfil"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataSpecification"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/measuresProperty",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a metric (measurement) to the observable property it is quantifying. This indirectly associates a Unit of Measure (via Metric) with a physical phenomenon (ObservableProperty)."
  }, {
    "@language" : "es",
    "@value" : "Vincula una métrica (medición) con la propiedad observable que está cuantificando. De este modo, se asocia de forma indirecta una Unidad de Medida (vía Metric) con un fenómeno físico (ObservableProperty)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "measures property"
  }, {
    "@language" : "es",
    "@value" : "mide la propiedad"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/ObservableProperty"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/metric-types",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
