  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Define el valor umbral para una restricción de calidad."
  }, {
    "@language" : "en",
    "@value" : "Defines the threshold value for a quality constraint."
  } ],
