  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a resource to the activity or DataApp that generated it. In EDAAnOWL, typically links a DataAsset to the DataApp that produced it. Compatible with DCAT-AP-ES (prov:Activity) and EDAAnOWL (edaan:DataApp)."
  }, {
    "@language" : "es",
    "@value" : "Vincula un recurso con la actividad o DataApp que lo generó. En EDAAnOWL, típicamente vincula un DataAsset con la DataApp que lo produjo. Compatible con DCAT-AP-ES (prov:Activity) y EDAAnOWL (edaan:DataApp)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "fue generado por"
  }, {
    "@language" : "en",
    "@value" : "was generated by"
  } ]
