    "@value" : "tipo de métrica de restricción"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/MetricType"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/constraintOperator",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a quality constraint to a formal comparison operator (e.g., :GreaterOrEqual, :Equal). Replaces the previous string-based approach."
  }, {
    "@language" : "es",
    "@value" : "Vincula una restricción de calidad con un operador de comparación formal (p. ej., :GreaterOrEqual, :Equal). Reemplaza el enfoque anterior basado en strings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataConstraint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "constraint operator"
  }, {
    "@language" : "es",
    "@value" : "operador de restricción"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/ConstraintOperator"
  } ]
}, {
