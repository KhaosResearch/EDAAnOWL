    "@value" : "técnica de anonimización"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/appliesToFeature",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Use :appliesToFeatureConcept for formal schema pointers. Indicates the specific feature, column, or attribute to which a metric refers (e.g., 'column_name', 'user.address.city', '$.user.address.city')."
  }, {
    "@language" : "es",
    "@value" : "OBSOLETO: Use :appliesToFeatureConcept para punteros formales a esquema. Indica la característica, columna o atributo específico al que se refiere una métrica (p. ej., 'column_name', 'user.address.city', '$.user.address.city')."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "applies to feature (deprecated)"
  }, {
    "@language" : "es",
    "@value" : "se aplica a característica (obsoleto)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/2002/07/owl#deprecated" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/appliesToFeatureConcept",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a metric to a formal schema element (as a SKOS Concept) describing the feature/column it applies to. Use this when a formal schema definition exists. For simple JSONPath strings, the deprecated :appliesToFeature (string) may still be used."
  }, {
    "@language" : "es",
    "@value" : "Vincula una métrica con un elemento de esquema formal (como un Concepto SKOS) que describe la característica/columna a la que aplica. Use esto cuando exista una definición de esquema formal. Para strings JSONPath simples, aún puede usarse la obsoleta :appliesToFeature (string)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "applies to feature (concept)"
  }, {
    "@language" : "es",
    "@value" : "se aplica a característica (concepto)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/auditLogAvailable",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Indica si los registros de auditoría para el uso del activo o DataApp están disponibles."
