  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a DataAsset, Metric, or DataSpecification to the specific characteristic or phenomenon being measured. Used to define atomic semantic specifications."
  }, {
    "@language" : "es",
    "@value" : "Vincula un activo de datos, métrica o Perfil de Datos con el fenómeno o característica específica que se mide. Se usa para definir especificaciones semánticas atómicas."
  } ],
