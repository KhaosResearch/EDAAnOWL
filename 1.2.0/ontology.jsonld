  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/metricName",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A human-readable name or identifier for the metric (e.g., 'recordCount', 'missing_ratio')."
  }, {
    "@language" : "es",
    "@value" : "Un nombre o identificador legible para la métrica (p. ej., 'recordCount', 'missing_ratio')."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "metric name"
  }, {
    "@language" : "es",
    "@value" : "nombre de métrica"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/metricType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a Metric measurement to a standardized MetricType definition from the controlled vocabulary. Aligned with dqv:isMeasurementOf for DQV interoperability."
  }, {
    "@language" : "es",
