    "@id" : "http://www.w3.org/2001/XMLSchema#dateTime"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#generatedAtTime"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/conformsToSchema",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Use dcat:Distribution with dct:conformsTo instead. Links a profile to a formal technical schema (e.g., JSON Schema, XSD, SQL DDL)."
  }, {
    "@language" : "es",
    "@value" : "OBSOLETO: Use dcat:Distribution con dct:conformsTo en su lugar. Vincula un perfil con un esquema técnico formal (p. ej., JSON Schema, XSD, SQL DDL)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataSpecification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "conforms to schema (deprecated)"
  }, {
    "@language" : "es",
    "@value" : "se ajusta al esquema (obsoleto)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/dc/terms/conformsTo"
  } ],
  "http://www.w3.org/2002/07/owl#deprecated" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/constraintMetricType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Identifica el tipo de métrica de calidad al que se aplica una restricción."
  }, {
    "@language" : "en",
    "@value" : "Identifies the type of quality metric a constraint applies to."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataConstraint"
