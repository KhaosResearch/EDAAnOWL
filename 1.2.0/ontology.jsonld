  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Technical schema details belong to the Distribution or FieldMapping layer. Identifies the technology or standard of the associated technical schema."
  }, {
