}, {
  "@id" : "https://w3id.org/EDAAnOWL/spatialGranularityConcept",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a resource to a SKOS concept describing its spatial granularity.\n\nRECOMMENDED vocabularies (DCAT-AP 3.0.1):\n- EU NUTS: http://publications.europa.eu/resource/authority/nuts\n- INSPIRE Codelists: http://inspire.ec.europa.eu/codelist/\n- ISO 3166 (Countries): http://publications.europa.eu/resource/authority/country\n\nExamples: NUTS level 1 (country), NUTS level 2 (region), NUTS level 3 (province)."
  }, {
    "@language" : "es",
    "@value" : "Vincula un recurso con un concepto SKOS que describe su granularidad espacial.\n\nVocabularios RECOMENDADOS (DCAT-AP 3.0.1):\n- EU NUTS: http://publications.europa.eu/resource/authority/nuts\n- INSPIRE Codelsits: http://inspire.ec.europa.eu/codelist/\n- ISO 3166 (Countries): http://publications.europa.eu/resource/authority/country\n\nEjemplos: NUTS nivel 1 (país), NUTS nivel 2 (región), NUTS nivel 3 (provincia)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/idsa/core/Resource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "granularidad espacial (concepto)"
  }, {
    "@language" : "en",
    "@value" : "spatial granularity (concept)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/supportContact",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
