  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "El identificador físico (nombre de columna, JSONPath, XPath) del campo en la distribución que corresponde al perfil atómico vinculado."
  }, {
    "@language" : "en",
    "@value" : "The physical identifier (column name, JSONPath, XPath) of the field in the distribution that corresponds to the bound atomic profile."
  } ],
