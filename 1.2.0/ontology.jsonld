    "@id" : "https://w3id.org/EDAAnOWL/FieldMapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "maps to field"
  }, {
    "@language" : "es",
    "@value" : "se mapea al campo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/mapsToSpecification",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a FieldMapping to the atomic reusable DataSpecification it instantiates for a specific field."
  }, {
    "@language" : "es",
    "@value" : "Vincula un FieldMapping con el DataSpecification atómico reutilizable que instancia para un campo específico."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/FieldMapping"
  } ],
