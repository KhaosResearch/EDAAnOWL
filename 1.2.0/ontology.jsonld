  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Metric representing the degree to which data values are unique."
  }, {
    "@language" : "es",
    "@value" : "Métrica que representa el grado en que los valores de los datos son únicos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Unicidad"
  }, {
