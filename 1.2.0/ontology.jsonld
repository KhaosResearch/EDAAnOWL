  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a BIGOWL Component to an EDAAnOWL DataRepresentation it consumes as input. Use this for data flows."
  }, {
    "@language" : "es",
    "@value" : "Vincula un Componente BIGOWL con una DataRepresentation EDAAnOWL que consume como entrada. Use esto para flujos de datos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/BIGOWLWorkflows/Component"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "consume representación de datos"
  }, {
    "@language" : "en",
    "@value" : "consumes data representation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataRepresentation"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/consumesResource",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Use consumesDataRepresentation or consumesAppRepresentation instead. Links a BIGOWL Component to an IDSA Representation it consumes as input."
  }, {
    "@language" : "es",
    "@value" : "OBSOLETO: Use consumesDataRepresentation o consumesAppRepresentation en su lugar. Vincula un Componente BIGOWL con una Representación IDSA que consume como entrada."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/BIGOWLWorkflows/Component"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "consume representación (obsoleto)"
  }, {
    "@language" : "en",
    "@value" : "consumes representation (deprecated)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/ns/dcat#Distribution"
  } ],
  "http://www.w3.org/2002/07/owl#deprecated" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/containsPersonalData",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Indica si el recurso (especificación, activo o App) incluye información de identificación personal (PII) o datos sujetos a GDPR."
  }, {
    "@language" : "en",
    "@value" : "Indicates whether the resource (specification, asset or App) includes Personally Identifiable Information (PII) or data subject to GDPR."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid44"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "contains personal data"
  }, {
    "@language" : "es",
    "@value" : "contiene datos personales"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#boolean"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/declaresDataClass",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a DataSpecification to a BIGOWL Data class (e.g., bigdat:TabularDataSet, bigdat:Image)."
  }, {
    "@language" : "es",
    "@value" : "Vincula un DataSpecification con una clase de Datos BIGOWL (p. ej., bigdat:TabularDataSet, bigdat:Image)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "declara clase de datos"
  }, {
    "@language" : "en",
    "@value" : "declares data class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/BIGOWLData/Data"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/externalQualityReport",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a resource to a structured object describing an external quality report."
  }, {
    "@language" : "es",
    "@value" : "Vincula un recurso con un objeto estructurado que describe un informe de calidad externo."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/idsa/core/Resource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "external quality report"
  }, {
    "@language" : "es",
    "@value" : "informe de calidad externo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/QualityReport"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasCRS",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a resource (Profile, Distribution, or Asset) to a SKOS Concept representing its Coordinate Reference System (e.g., EPSG:4326)."
  }, {
    "@language" : "es",
    "@value" : "Vincula un recurso (Perfil, Distribución o Activo) con un concepto SKOS que representa su Sistema de Referencia de Coordenadas (p. ej., EPSG:4326)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has CRS"
  }, {
    "@language" : "es",
    "@value" : "tiene CRS"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasCertification",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a Data Asset, Data App or Data Specification to a Certification Report attesting compliance with a standard (e.g., Gaia-X Label)."
  }, {
    "@language" : "es",
    "@value" : "Vincula un Activo de Datos, una Data App o una Especificación de Datos con un Informe de Certificación que atestigua el cumplimiento de un estándar (p. ej., Etiqueta Gaia-X)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid1"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has certification"
  }, {
    "@language" : "es",
    "@value" : "tiene certificación"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/CertificationReport"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasConstraint",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an input requirement to a specific quality or technical constraint that must be met by the data."
  }, {
    "@language" : "es",
    "@value" : "Vincula un requisito de entrada con una restricción técnica o de calidad específica que deben cumplir los datos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/InputProfile"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has constraint"
  }, {
    "@language" : "es",
    "@value" : "tiene restricción"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataConstraint"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasCredential",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a data space entity to a Verifiable Credential attesting its properties, quality metrics, or compliance certifications."
  }, {
    "@language" : "es",
    "@value" : "Vincula una entidad de espacio de datos con una Credencial Verificable que certifica sus propiedades, métricas de calidad o certificaciones de conformidad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has credential"
  }, {
    "@language" : "es",
    "@value" : "tiene credencial"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://www.w3.org/2018/credentials#VerifiableCredential"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasDPIA",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an asset or DataApp to its Data Protection Impact Assessment (DPIA) document."
  }, {
    "@language" : "es",
    "@value" : "Vincula un activo o DataApp con su documento de Evaluación de Impacto de Protección de Datos (DPIA)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid9"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has DPIA"
  }, {
    "@language" : "es",
    "@value" : "tiene DPIA"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Document"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasDataConstraint",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "LEGACY: Use :hasConstraint instead. Links an input requirement to a specific quality threshold that must be met by the data."
  }, {
    "@language" : "es",
    "@value" : "LEGADO: Use :hasConstraint en su lugar. Vincula un requisito de entrada con un umbral de calidad específico que deben cumplir los datos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/InputProfile"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has quality constraint (legacy)"
  }, {
    "@language" : "es",
    "@value" : "tiene restricción de calidad (legado)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataConstraint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/hasConstraint"
  } ],
  "http://www.w3.org/2002/07/owl#deprecated" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasDataSpecification",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a DataProfile (or any of its subclasses: InputProfile, OutputProfile) to the DataSpecifications it contains or requires."
  }, {
    "@language" : "es",
    "@value" : "Vincula un DataProfile (o cualquiera de sus subclases: InputProfile, OutputProfile) con las DataSpecifications que contiene o requiere."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataProfile"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has data specification"
  }, {
    "@language" : "es",
    "@value" : "tiene especificación de datos"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataSpecification"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasDataType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Physical data type encoding of the field in the distribution (e.g., xsd:float, xsd:dateTime)."
  }, {
    "@language" : "es",
    "@value" : "Tipo de dato físico del campo en la distribución (p. ej., xsd:float, xsd:dateTime)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/FieldMapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has data type"
  }, {
    "@language" : "es",
    "@value" : "tiene tipo de dato"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2000/01/rdf-schema#Datatype"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasDomainSector",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A sub-property of dcat:theme linking a resource to its domain sector.\n\nRECOMMENDED: Use EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):\n  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agriculture\n  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energy\n  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Health\n  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transport\n  http://publications.europa.eu/resource/authority/data-theme/ENVI  # Environment\n  http://publications.europa.eu/resource/authority/data-theme/TECH  # Science/Technology\n\nReference: http://publications.europa.eu/resource/authority/data-theme"
  }, {
    "@language" : "es",
    "@value" : "Una sub-propiedad de dcat:theme que vincula un recurso con su sector de dominio.\n\nRECOMENDADO: Usar EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):\n  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agricultura\n  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energía\n  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Salud\n  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transporte\n\nReferencia: http://publications.europa.eu/resource/authority/data-theme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid12"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has domain sector"
  }, {
    "@language" : "es",
    "@value" : "tiene sector de dominio"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/ns/dcat#theme"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasFeatureOfInterest",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a DataAsset, Metric, or DataSpecification to the entity or phenomenon it concerns (e.g., a specific crop or product). Used to define atomic semantic specifications."
  }, {
    "@language" : "es",
    "@value" : "Vincula un activo de datos, métrica o Perfil de Datos con la entidad o fenómeno sobre el que versa (p. ej., un cultivo específico). Se usa para definir especificaciones semánticas atómicas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has feature of interest"
  }, {
    "@language" : "es",
    "@value" : "tiene característica de interés"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/FeatureOfInterest"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasFieldMapping",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a distribution to a FieldMapping, which maps an atomic semantic profile to a specific field in the physical file."
  }, {
    "@language" : "es",
    "@value" : "Vincula una distribución con un FieldMapping, que mapea un perfil semántico atómico a un campo específico en el archivo físico."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/ns/dcat#Distribution"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has field mapping"
  }, {
    "@language" : "es",
    "@value" : "tiene mapeo de campo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/FieldMapping"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasInputProfile",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a DataApp to a structured input requirement, aggregating a required profile and optional quality constraints."
  }, {
    "@language" : "es",
    "@value" : "Vincula una DataApp con un requisito de entrada estructurado, agregando un perfil requerido y restricciones de calidad opcionales."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataApp"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has input requirement"
  }, {
    "@language" : "es",
    "@value" : "tiene requisito de entrada"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/InputProfile"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasMetric",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a FieldMapping, DataSpecification, DataAsset, or Distribution to a quality, performance, or descriptive metric."
  }, {
    "@language" : "es",
    "@value" : "Vincula un FieldMapping, DataSpecification, DataAsset o Distribution con una métrica de calidad, rendimiento o descriptiva."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid15"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has metric"
  }, {
    "@language" : "es",
    "@value" : "tiene métrica"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/Metric"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasMetricStandard",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a metric or field-level value constraint to the standard or reference system used for its value. It can be a unit of measurement (QUDT) or a concept scheme/vocabulary (SKOS). Unifies the previous hasMetricUnit and usesVocabulary properties."
  }, {
    "@language" : "es",
    "@value" : "Vincula una métrica o perfil con el estándar o sistema de referencia utilizado para su valor. Puede ser una unidad de medida (QUDT) o un esquema de conceptos/vocabulario (SKOS). Unifica las propiedades anteriores hasMetricUnit y usesVocabulary."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has metric standard"
  }, {
    "@language" : "es",
    "@value" : "tiene estándar de métrica"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/hasMetricUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Use :hasMetricStandard instead. The unit of measurement for the metric value referencing a URI (e.g., qudt:KiloGM, unit:PERCENT)."
  }, {
    "@language" : "es",
    "@value" : "OBSOLETO: Use :hasMetricStandard en su lugar. La unidad de medida para el valor de la métrica referenciando una URI (p. ej., qudt:KiloGM, unit:PERCENT)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/Metric"
  } ],
