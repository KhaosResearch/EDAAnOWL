}, {
  "@id" : "https://w3id.org/EDAAnOWL/VerifiableDataSpecification",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A DataSpecification that is intended to be cryptographically verified. It should be linked to a Verifiable Credential using :hasCredential. This enables trusted quality assertions in data spaces by separating the profile metadata from its cryptographic proof."
  }, {
    "@language" : "es",
    "@value" : "Un DataSpecification destinado a ser verificado criptográficamente. Debe vincularse a una Credencial Verificable usando :hasCredential. Esto permite aserciones de calidad confiables en espacios de datos separando los metadatos del perfil de su prueba criptográfica."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Perfil de Datos Verificable"
  }, {
    "@language" : "en",
    "@value" : "Verifiable Data Specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataSpecification"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/VisualizationApp",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A smart data app that renders data into visual views/reports without altering underlying data."
  }, {
    "@language" : "es",
    "@value" : "Una aplicación de datos inteligente que renderiza datos en vistas/informes visuales sin alterar los datos subyacentes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Aplicación de Visualización"
  }, {
    "@language" : "en",
    "@value" : "Visualization App"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataApp"
  }, {
    "@id" : "https://w3id.org/idsa/core/SmartDataApp"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/accessType",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "DEPRECATED: Use :accessTypeConcept instead. Indicates the primary access mode for the resource (e.g., download, compute, ...)."
  }, {
    "@language" : "es",
    "@value" : "OBSOLETO: Use :accessTypeConcept en su lugar. Indica el modo de acceso principal para el recurso (p. ej., descarga, cómputo, ...)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/idsa/core/Resource"
  } ],
