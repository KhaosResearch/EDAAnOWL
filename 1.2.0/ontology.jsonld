  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Alternative title or name for a resource."
  }, {
    "@language" : "es",
    "@value" : "Título o nombre alternativo para un recurso."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/idsa/core/Resource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "alternate name"
  }, {
    "@language" : "es",
    "@value" : "nombre alternativo"
  } ],
