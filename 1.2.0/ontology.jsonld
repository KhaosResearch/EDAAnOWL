    "@id" : "http://purl.org/dc/terms/alternative"
  } ]
}, {
  "@id" : "https://w3id.org/EDAAnOWL/anonymizationTechnique",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "La técnica utilizada para anonimizar datos personales (p. ej., 'k-anonymity', 'privacidad diferencial')."
  }, {
    "@language" : "en",
    "@value" : "The technique used to anonymize personal data (e.g., 'k-anonymity', 'differential privacy')."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/EDAAnOWL/DataSpecification"
  }, {
    "@id" : "https://w3id.org/idsa/core/Resource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
