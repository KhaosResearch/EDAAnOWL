    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/conformsTo -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/conformsTo"/>
    


    <!-- http://purl.org/dc/terms/source -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/subject -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/subject"/>
    


    <!-- http://www.w3.org/ns/dcat#contactPoint -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#contactPoint"/>
    


    <!-- http://www.w3.org/ns/dcat#theme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#theme"/>
    


    <!-- http://www.w3.org/ns/dqv#isMeasurementOf -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dqv#isMeasurementOf"/>
    


    <!-- http://www.w3.org/ns/prov#wasDerivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataAsset"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataAsset"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataAsset"/>
        <rdfs:range rdf:resource="https://w3id.org/idsa/core/DataApp"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/accessTypeConcept -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/accessTypeConcept">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Links a resource to a SKOS concept describing its access mode (e.g., &apos;download&apos;, &apos;compute-in-place&apos;). Replaces the deprecated :accessType string property.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un recurso con un concepto SKOS que describe su modo de acceso (p. ej., &apos;descarga&apos;, &apos;cómputo-in-situ&apos;). Reemplaza la propiedad string obsoleta :accessType.</rdfs:comment>
        <rdfs:label xml:lang="en">access type (concept)</rdfs:label>
        <rdfs:label xml:lang="es">tipo de acceso (concepto)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/appliesToFeatureConcept -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/appliesToFeatureConcept">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Links a metric to a formal schema element (as a SKOS Concept) describing the feature/column it applies to. Use this when a formal schema definition exists. For simple JSONPath strings, the deprecated :appliesToFeature (string) may still be used.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una métrica con un elemento de esquema formal (como un Concepto SKOS) que describe la característica/columna a la que aplica. Use esto cuando exista una definición de esquema formal. Para strings JSONPath simples, aún puede usarse la obsoleta :appliesToFeature (string).</rdfs:comment>
        <rdfs:label xml:lang="en">applies to feature (concept)</rdfs:label>
        <rdfs:label xml:lang="es">se aplica a característica (concepto)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/conformsToProfile -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/conformsToProfile">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/conformsTo"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:comment xml:lang="en">Links a distribution/representation to a DataProfile that describes its structure and characteristics. In IDSA/DCAT, technical profiles are associated with the concrete delivery form (Distribution), not the abstract product (Resource).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una distribución/representación con un DataProfile que describe su estructura y características. En IDSA/DCAT, los perfiles técnicos se asocian con la forma concreta de entrega (Distribution), no con el producto abstracto (Resource).</rdfs:comment>
        <rdfs:label xml:lang="en">conforms to profile</rdfs:label>
        <rdfs:label xml:lang="es">se ajusta al perfil</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/consumesAppRepresentation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/consumesAppRepresentation">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="https://w3id.org/idsa/core/AppRepresentation"/>
        <rdfs:comment xml:lang="en">Links a BIGOWL Component to an IDSA AppRepresentation it consumes. Use this for software/app flows.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Componente BIGOWL con una AppRepresentation IDSA que consume. Use esto para flujos de software/apps.</rdfs:comment>
        <rdfs:label xml:lang="es">consume representación de app</rdfs:label>
        <rdfs:label xml:lang="en">consumes app representation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/consumesDataRepresentation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/consumesDataRepresentation">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataRepresentation"/>
        <rdfs:comment xml:lang="en">Links a BIGOWL Component to an EDAAnOWL DataRepresentation it consumes as input. Use this for data flows.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Componente BIGOWL con una DataRepresentation EDAAnOWL que consume como entrada. Use esto para flujos de datos.</rdfs:comment>
        <rdfs:label xml:lang="es">consume representación de datos</rdfs:label>
        <rdfs:label xml:lang="en">consumes data representation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/consumesResource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/consumesResource">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use consumesDataRepresentation or consumesAppRepresentation instead. Links a BIGOWL Component to an IDSA Representation it consumes as input.</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use consumesDataRepresentation o consumesAppRepresentation en su lugar. Vincula un Componente BIGOWL con una Representación IDSA que consume como entrada.</rdfs:comment>
        <rdfs:label xml:lang="es">consume representación (obsoleto)</rdfs:label>
        <rdfs:label xml:lang="en">consumes representation (deprecated)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/declaresDataClass -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/declaresDataClass">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/BIGOWLData/Data"/>
        <rdfs:comment xml:lang="en">Links a DataProfile to a BIGOWL Data class (e.g., bigdat:TabularDataSet, bigdat:Image).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un DataProfile con una clase de Datos BIGOWL (p. ej., bigdat:TabularDataSet, bigdat:Image).</rdfs:comment>
        <rdfs:label xml:lang="es">declara clase de datos</rdfs:label>
        <rdfs:label xml:lang="en">declares data class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/declaresObservedProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/declaresObservedProperty">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Links a DataProfile to a semantic concept it describes, typically from a controlled vocabulary (e.g., an AGROVOC term).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un DataProfile con un concepto semántico que describe, típicamente de un vocabulario controlado (p. ej., un término AGROVOC).</rdfs:comment>
        <rdfs:label xml:lang="es">declara propiedad observada</rdfs:label>
        <rdfs:label xml:lang="en">declares observed property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/externalQualityReport -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/externalQualityReport">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/QualityReport"/>
        <rdfs:comment xml:lang="en">Links a resource to a structured object describing an external quality report.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un recurso con un objeto estructurado que describe un informe de calidad externo.</rdfs:comment>
        <rdfs:label xml:lang="en">external quality report</rdfs:label>
        <rdfs:label xml:lang="es">informe de calidad externo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasCRS -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasCRS">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasCertification -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasCertification">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/CertificationReport"/>
        <rdfs:comment xml:lang="en">Links a Data Profile to a Certification Report attesting compliance with a standard (e.g., Gaia-X Label).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Perfil de Datos con un Informe de Certificación que atestigua el cumplimiento de un estándar (p. ej., Etiqueta Gaia-X).</rdfs:comment>
        <rdfs:label xml:lang="en">has certification</rdfs:label>
        <rdfs:label xml:lang="es">tiene certificación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasCredential -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasCredential">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/DataAsset"/>
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/DataProfile"/>
                    <rdf:Description rdf:about="https://w3id.org/idsa/core/DataApp"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://www.w3.org/2018/credentials#VerifiableCredential"/>
        <rdfs:comment xml:lang="en">Links a data space entity to a Verifiable Credential attesting its properties, quality metrics, or compliance certifications.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una entidad de espacio de datos con una Credencial Verificable que certifica sus propiedades, métricas de calidad o certificaciones de conformidad.</rdfs:comment>
        <rdfs:label xml:lang="en">has credential</rdfs:label>
        <rdfs:label xml:lang="es">tiene credencial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasDPIA -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasDPIA">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:comment xml:lang="en">Links the resource to its Data Protection Impact Assessment (DPIA) document.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula el recurso con su documento de Evaluación de Impacto de Protección de Datos (DPIA).</rdfs:comment>
        <rdfs:label xml:lang="en">has DPIA</rdfs:label>
        <rdfs:label xml:lang="es">tiene DPIA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasDomainSector -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasDomainSector">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dcat#theme"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/idsa/core/DataApp"/>
                    <rdf:Description rdf:about="https://w3id.org/idsa/core/Resource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">A sub-property of dcat:theme linking a resource to its domain sector.

RECOMMENDED: Use EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):
  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agriculture
  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energy
  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Health
  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transport
  http://publications.europa.eu/resource/authority/data-theme/ENVI  # Environment
  http://publications.europa.eu/resource/authority/data-theme/TECH  # Science/Technology

Reference: http://publications.europa.eu/resource/authority/data-theme</rdfs:comment>
        <rdfs:comment xml:lang="es">Una sub-propiedad de dcat:theme que vincula un recurso con su sector de dominio.

RECOMENDADO: Usar EU Publications Office Data Theme NAL (DCAT-AP 3.0.1):
  http://publications.europa.eu/resource/authority/data-theme/AGRI  # Agricultura
  http://publications.europa.eu/resource/authority/data-theme/ENER  # Energía
  http://publications.europa.eu/resource/authority/data-theme/HEAL  # Salud
  http://publications.europa.eu/resource/authority/data-theme/TRAN  # Transporte

Referencia: http://publications.europa.eu/resource/authority/data-theme</rdfs:comment>
        <rdfs:label xml:lang="en">has domain sector</rdfs:label>
        <rdfs:label xml:lang="es">tiene sector de dominio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasMetric">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:comment xml:lang="en">Links a Data Profile to a specific quality, performance, or descriptive metric.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Perfil de Datos con una métrica específica de calidad, rendimiento o descriptiva.</rdfs:comment>
        <rdfs:label xml:lang="en">has metric</rdfs:label>
        <rdfs:label xml:lang="es">tiene métrica</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasPerformanceMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasPerformanceMetric">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/EDAAnOWL/hasMetric"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/PerformanceMetric"/>
        <rdfs:comment xml:lang="en">Links a DataApp to a specific performance metric (e.g., accuracy, execution time).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una DataApp con una métrica de rendimiento específica (p. ej., precisión, tiempo de ejecución).</rdfs:comment>
        <rdfs:label xml:lang="en">has performance metric</rdfs:label>
        <rdfs:label xml:lang="es">tiene métrica de rendimiento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasSpatialCoverage -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasSpatialCoverage">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/SpatialTemporalAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/locn#Geometry"/>
        <rdfs:comment xml:lang="es">Define la cobertura espacial del activo de datos requerido por las CUs de Observación de la Tierra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the spatial coverage of the data asset required by Earth Observation CUs.</rdfs:comment>
        <rdfs:label xml:lang="en">has spatial coverage</rdfs:label>
        <rdfs:label xml:lang="es">tiene cobertura espacial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/hasTemporalCoverage -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/hasTemporalCoverage">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/SpatialTemporalAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="es">Define la cobertura temporal del activo de datos requerido por las CUs de Observación de la Tierra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the temporal coverage of the data asset required by Earth Observation CUs.</rdfs:comment>
        <rdfs:label xml:lang="en">has temporal coverage</rdfs:label>
        <rdfs:label xml:lang="es">tiene cobertura temporal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/implementsComponent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/implementsComponent">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:comment xml:lang="en">Links an IDSA DataApp to the BIGOWL workflow Component it implements.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una DataApp IDSA con el Componente de flujo de trabajo BIGOWL que implementa.</rdfs:comment>
        <rdfs:label xml:lang="es">implementa componente</rdfs:label>
        <rdfs:label xml:lang="en">implements component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/legalContact -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/legalContact">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dcat#contactPoint"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/vcard/ns#Kind"/>
        <rdfs:comment xml:lang="en">A specific contact point for legal inquiries about the resource.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un punto de contacto específico para consultas legales sobre el recurso.</rdfs:comment>
        <rdfs:label xml:lang="es">contacto legal</rdfs:label>
        <rdfs:label xml:lang="en">legal contact</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/metricType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/metricType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dqv#isMeasurementOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/MetricType"/>
        <rdfs:comment xml:lang="en">Links a Metric measurement to a standardized MetricType definition from the controlled vocabulary. Aligned with dqv:isMeasurementOf for DQV interoperability.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una medición de Métrica con una definición de MetricType estandarizada del vocabulario controlado. Alineada con dqv:isMeasurementOf para interoperabilidad DQV.</rdfs:comment>
        <rdfs:label xml:lang="en">metric type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de métrica</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/parameter -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/parameter">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="http://www.e-lico.eu/ontologies/dmo/DMOP/DMOP.owl#Parameter"/>
        <rdfs:comment xml:lang="en">Links a DataApp to an execution parameter it accepts.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una DataApp con un parámetro de ejecución que acepta.</rdfs:comment>
        <rdfs:label xml:lang="en">parameter</rdfs:label>
        <rdfs:label xml:lang="es">parámetro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/producesAppRepresentation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/producesAppRepresentation">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="https://w3id.org/idsa/core/AppRepresentation"/>
        <rdfs:comment xml:lang="en">Links a BIGOWL Component to an IDSA AppRepresentation it produces. Use this for software/app flows.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Componente BIGOWL con una AppRepresentation IDSA que produce. Use esto para flujos de software/apps.</rdfs:comment>
        <rdfs:label xml:lang="es">produce representación de app</rdfs:label>
        <rdfs:label xml:lang="en">produces app representation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/producesDataRepresentation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/producesDataRepresentation">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataRepresentation"/>
        <rdfs:comment xml:lang="en">Links a BIGOWL Component to an EDAAnOWL DataRepresentation it produces as output. Use this for data flows.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un Componente BIGOWL con una DataRepresentation EDAAnOWL que produce como salida. Use esto para flujos de datos.</rdfs:comment>
        <rdfs:label xml:lang="es">produce representación de datos</rdfs:label>
        <rdfs:label xml:lang="en">produces data representation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/producesObservableProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/producesObservableProperty">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/SmartDataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/ObservableProperty"/>
        <rdfs:comment xml:lang="es">Define la firma semántica de la SALIDA de un servicio (p. ej., produce Crop_Forecast).</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the semantic signature of the OUTPUT of a service (e.g., produces Crop_Forecast).</rdfs:comment>
        <rdfs:label xml:lang="es">produce propiedad observable</rdfs:label>
        <rdfs:label xml:lang="en">produces observable property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/producesProfile -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/producesProfile">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:comment xml:lang="en">Links a DataApp to a DataProfile it produces as output.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una DataApp con un DataProfile que produce como salida.</rdfs:comment>
        <rdfs:label xml:lang="es">produce perfil</rdfs:label>
        <rdfs:label xml:lang="en">produces profile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/producesResource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/producesResource">
        <rdfs:domain rdf:resource="https://w3id.org/BIGOWLWorkflows/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:comment xml:lang="en">DEPRECATED: Use producesDataRepresentation or producesAppRepresentation instead. Links a BIGOWL Component to an IDSA Representation it produces as output.</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Use producesDataRepresentation o producesAppRepresentation en su lugar. Vincula un Componente BIGOWL con una Representación IDSA que produce como salida.</rdfs:comment>
        <rdfs:label xml:lang="es">produce representación (obsoleto)</rdfs:label>
        <rdfs:label xml:lang="en">produces representation (deprecated)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/realizesWorkflow -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/realizesWorkflow">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="http://www.opmw.org/ontology/WorkflowTemplate"/>
        <rdfs:comment xml:lang="en">DEPRECATED: A DataApp implements a Component, not a Workflow.

Use :implementsComponent instead to link a DataApp to the BIGOWL Component it implements.
A Workflow is a pipeline composed of multiple Components connected via Tasks.

If you need to indicate workflow membership, consider using bigwf:hasComponent (inverse).</rdfs:comment>
        <rdfs:comment xml:lang="es">OBSOLETO: Una DataApp implementa un Component, no un Workflow.

Use :implementsComponent para vincular una DataApp con el Component BIGOWL que implementa.
Un Workflow es un pipeline compuesto por múltiples Components conectados via Tasks.</rdfs:comment>
        <rdfs:label xml:lang="es">realiza flujo de trabajo (obsoleto)</rdfs:label>
        <rdfs:label xml:lang="en">realizes workflow (deprecated)</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/reportingEntity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/reportingEntity">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/CertificationReport"/>
                    <rdf:Description rdf:about="https://w3id.org/EDAAnOWL/QualityReport"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/ns/org#Organization"/>
        <rdfs:comment xml:lang="es">La organización que emitió el informe de calidad o certificación.</rdfs:comment>
        <rdfs:comment xml:lang="en">The organization that issued the quality or certification report.</rdfs:comment>
        <rdfs:label xml:lang="es">entidad reportadora</rdfs:label>
        <rdfs:label xml:lang="en">reporting entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/requiresObservableProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/requiresObservableProperty">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/SmartDataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/ObservableProperty"/>
        <rdfs:comment xml:lang="es">Define la firma semántica de la ENTRADA para un servicio (p. ej., requiere NDVI).</rdfs:comment>
        <rdfs:comment xml:lang="en">Defines the semantic signature of INPUT for a service (e.g., requires NDVI).</rdfs:comment>
        <rdfs:label xml:lang="es">requiere propiedad observable</rdfs:label>
        <rdfs:label xml:lang="en">requires observable property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/requiresProfile -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/requiresProfile">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/DataProfile"/>
        <rdfs:comment xml:lang="en">Links a DataApp to a DataProfile it requires as input.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una DataApp con un DataProfile que requiere como entrada.</rdfs:comment>
        <rdfs:label xml:lang="es">requiere perfil</rdfs:label>
        <rdfs:label xml:lang="en">requires profile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/servesObservableProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/servesObservableProperty">
        <rdfs:domain rdf:resource="https://w3id.org/EDAAnOWL/DataAsset"/>
        <rdfs:range rdf:resource="https://w3id.org/EDAAnOWL/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Links a data asset (DataAsset) to the semantic variable it describes (e.g., NDVI).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un activo de datos (DataAsset) con la variable semántica que describe (p. ej., NDVI).</rdfs:comment>
        <rdfs:label xml:lang="en">serves observable property</rdfs:label>
        <rdfs:label xml:lang="es">sirve propiedad observable</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/spatialGranularityConcept -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/spatialGranularityConcept">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Links a resource to a SKOS concept describing its spatial granularity.

RECOMMENDED vocabularies:
- EU NUTS: http://publications.europa.eu/resource/authority/nuts
- INSPIRE: http://inspire.ec.europa.eu/codelist/
- ISO 3166: http://publications.europa.eu/resource/authority/country

Examples: NUTS level 1 (country), NUTS level 2 (region), NUTS level 3 (province).</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un recurso con un concepto SKOS que describe su granularidad espacial.

Vocabularios RECOMENDADOS:
- EU NUTS: http://publications.europa.eu/resource/authority/nuts
- INSPIRE: http://inspire.ec.europa.eu/codelist/
- ISO 3166: http://publications.europa.eu/resource/authority/country</rdfs:comment>
        <rdfs:label xml:lang="es">granularidad espacial (concepto)</rdfs:label>
        <rdfs:label xml:lang="en">spatial granularity (concept)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/supportContact -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/supportContact">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/dcat#contactPoint"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/vcard/ns#Kind"/>
        <rdfs:comment xml:lang="es">Punto de contacto estándar para soporte, usando vCard (fn, email, telephone, URL).</rdfs:comment>
        <rdfs:comment xml:lang="en">Standard contact point for support, using vCard (fn, email, telephone, URL).</rdfs:comment>
        <rdfs:label xml:lang="es">contacto de soporte</rdfs:label>
        <rdfs:label xml:lang="en">support contact</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/EDAAnOWL/topic -->


    <owl:ObjectProperty rdf:about="https://w3id.org/EDAAnOWL/topic">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/subject"/>
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">A sub-property of dct:subject for linking a resource to a descriptive SKOS concept (e.g., from AGROVOC).</rdfs:comment>
        <rdfs:comment xml:lang="es">Una sub-propiedad de dct:subject para vincular un recurso con un concepto SKOS descriptivo (p. ej., de AGROVOC).</rdfs:comment>
        <rdfs:label xml:lang="es">tema</rdfs:label>
        <rdfs:label xml:lang="en">topic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/idsa/core/appEndpoint -->


    <owl:ObjectProperty rdf:about="https://w3id.org/idsa/core/appEndpoint">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/DataApp"/>
        <rdfs:range rdf:resource="https://w3id.org/idsa/core/AppEndpoint"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/idsa/core/contractOffer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/idsa/core/contractOffer">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/Resource"/>
        <rdfs:range rdf:resource="https://w3id.org/idsa/core/ContractOffer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/idsa/core/dataAppInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/idsa/core/dataAppInformation">
        <rdfs:domain rdf:resource="https://w3id.org/idsa/core/AppRepresentation"/>
